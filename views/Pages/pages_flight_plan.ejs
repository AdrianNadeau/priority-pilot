<%- contentFor('HeaderCss') %>

<style>
  html,
  body {
    height: 100%;
    margin: 0;
    padding: 0;
  }
  #gantt_here {
    width: 100%;
    height: 800px;
  }
  /* ✅ Default phase (parent) bars will remain blue */
  .gantt_task_line {
    background-color: #007bff; /* Default blue for phases */
  }

  /* ✅ Custom colors for projects */
  .green .gantt_task_content {
    background-color: #28a745 !important;
    color: white;
  }

  .yellow .gantt_task_content {
    background-color: #ffc107 !important;
    color: black;
  }

  .red .gantt_task_content {
    background-color: #dc3545 !important;
    color: white;
  }

  .no-status .gantt_task_content {
    background-color: #6c757d !important;
    color: white;
  }
</style>

<%- contentFor('breadcrumb') %> <%- contentFor('body') %>
<div class="page-content-wrapper">
  <div class="container-fluid">
    
    <!-- Filter Display Section -->
    <div class="row">
        <div class="col-md-12" style="min-height: 50px; padding-bottom: 15px;">
            <div class="mini-stat clearfix" style="background-color: #e3f2fd; border: 1px solid #2196f3; border-radius: 4px; padding: 10px;">
                <div class="mini-stat-info d-flex align-items-center">
                    <div class="d-flex align-items-center">
                        <span class="counter" style="color: black; margin-right: 20px;"><strong>Filter:</strong></span>
                        
                        <div class="d-flex align-items-center" style="margin-right: 15px;">
                            <strong style="margin-right: 10px;">From:</strong>
                            <input type="text" class="form-control datepicker" id="from_date" name="from_date" placeholder="From" style="width: 150px;" value="<%= currentFromDate || '' %>">
                        </div>
                        
                        <div class="d-flex align-items-center" style="margin-right: 15px;">
                            <strong style="margin-right: 10px;">To:</strong>
                            <input type="text" class="form-control datepicker" id="to_date" name="to_date" placeholder="To" style="width: 150px;" value="<%= currentToDate || '' %>">
                        </div>
                        
                        <div class="d-flex">
                            <button type="button" class="btn btn-primary btn-sm" style="margin-right: 5px;" onclick="filterDashboard()">Filter</button>
                            <button type="button" class="btn btn-secondary btn-sm" onclick="clearFilters()">Clear</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Filtered Date Range Totals Section -->
    <% if (currentFromDate || currentToDate) { %>
    <div class="row" style="margin-top: 15px;">
        <div class="col-md-12">
            <div class="alert alert-success" style="margin-bottom: 15px; padding: 15px; background-color: #d4edda; border: 1px solid #28a745; border-radius: 4px;">
                <div style="display: flex; align-items: center; justify-content: space-between;">
                    <div style="display: flex; align-items: center;">
                        <i class="mdi mdi-calculator" style="margin-right: 8px; font-size: 20px; color: #155724;"></i>
                        <strong style="color: #155724; font-size: 16px;">Filtered Date Range:</strong>
                        <span style="color: #155724; margin-left: 10px; font-weight: 500;">
                            <% if (currentFromDate && currentToDate) { %>
                                <%= currentFromDate %> to <%= currentToDate %>
                            <% } else if (currentFromDate) { %>
                                From <%= currentFromDate %>
                            <% } else if (currentToDate) { %>
                                To <%= currentToDate %>
                            <% } %>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <% } %>
    
    <div id="gantt_here" style="width: 1200px; height: 800px"></div>
  </div>
</div>

<%- contentFor('FooterJs') %>

<!-- Flatpickr CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<!-- Flatpickr JS -->
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
  // Filter functions
  function filterDashboard() {
    const fromDate = document.getElementById('from_date').value;
    const toDate = document.getElementById('to_date').value;
    
    // Send filter data to server to save in persons table
    fetch('/update-filter', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        from_date: fromDate,
        to_date: toDate
      })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        console.log('Filter preferences saved successfully');
        // Redirect to current page with filters
        window.location.href = window.location.pathname;
      } else {
        console.error('Error saving filter preferences:', data.message);
        // Still redirect to try to apply filters
        const params = new URLSearchParams();
        if (fromDate) params.append('from_date', fromDate);
        if (toDate) params.append('to_date', toDate);
        const queryString = params.toString();
        const url = queryString ? `${window.location.pathname}?${queryString}` : window.location.pathname;
        window.location.href = url;
      }
    })
    .catch(error => {
      console.error('Error:', error);
      // Fallback: redirect with query parameters
      const params = new URLSearchParams();
      if (fromDate) params.append('from_date', fromDate);
      if (toDate) params.append('to_date', toDate);
      const queryString = params.toString();
      const url = queryString ? `${window.location.pathname}?${queryString}` : window.location.pathname;
      window.location.href = url;
    });
  }
  
  function clearFilters() {
    // Clear the input fields first
    document.getElementById('from_date').value = '';
    document.getElementById('to_date').value = '';
    
    // Send clear filter data to server to update persons table
    fetch('/update-filter', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        from_date: null,
        to_date: null
      })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        console.log('Filter preferences cleared successfully');
        // Redirect to current page without filters
        window.location.href = window.location.pathname;
      } else {
        console.error('Error clearing filter preferences:', data.message);
        // Still redirect even if there's an error to reset the page
        window.location.href = window.location.pathname;
      }
    })
    .catch(error => {
      console.error('Error clearing filters:', error);
      // Still redirect even if there's an error to reset the page
      window.location.href = window.location.pathname;
    });
  }

  // Initialize Flatpickr for date inputs
  flatpickr(".datepicker", {
    dateFormat: "Y-m-d", // Format the date as YYYY-MM-DD
    allowInput: true, // Allow manual input if needed
    allowInvalidPreload: true, // Allow invalid dates to be preloaded
  });
</script>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    // Fetch project data from your API
    fetch("/projects/flightview/ganttChart/")
      .then((response) => response.json())
      .then((pData) => {
        console.log(pData); // Debug: Log the fetched data
        const projects = pData.companyProjects;

        const phaseMapping = {
          2: { id: 2, text: "Planning", open: false, type: "phase" },
          3: { id: 3, text: "Discovery", open: false, type: "phase" },
          4: { id: 4, text: "Delivery", open: false, type: "phase" },
        };

        const categories = Object.values(phaseMapping);

        const filteredProjects = projects.filter(
          (project) => {
            // Filter by phase
            const validPhase = project.phase_id_fk === 2 ||
                              project.phase_id_fk === 3 ||
                              project.phase_id_fk === 4;
            
            // Additional date validation to ensure we have valid dates
            const hasValidStartDate = project.start_date && new Date(project.start_date) instanceof Date && !isNaN(new Date(project.start_date));
            const hasValidEndDate = project.end_date && new Date(project.end_date) instanceof Date && !isNaN(new Date(project.end_date));
            
            return validPhase && hasValidStartDate && hasValidEndDate;
          }
        );

        const colorMapping = {
          Green: "#28a745",
          Yellow: "#ffc107",
          Red: "#dc3545",
        };

        const tasks = {
          data: filteredProjects.map((project) => {
            const phaseId = phaseMapping[project.phase_id_fk]?.id;

            return {
              id: project.id + 1000,
              text: project.project_name,
              start_date: new Date(project.start_date).toLocaleDateString(
                "en-GB",
              ),
              duration: Math.ceil(
                (new Date(project.end_date) - new Date(project.start_date)) /
                  (1000 * 60 * 60 * 24),
              ),
              parent: phaseId || null,
              color: colorMapping[project.health] || "#000000",
              health: project.health,
              type: "task",
              next_milestone_date: project.next_milestone_date,
              next_milestone_date_details: project.next_milestone_date_details,
            };
          }),
          links: [],
        };

        const sortedData = [...categories, ...tasks.data].sort((a, b) =>
          a.id === 2 ? -1 : 1,
        );

        gantt.plugins({ tooltip: true });
        gantt.init("gantt_here");
        gantt.templates.tooltip_text = function (start, end, task) {
          if (task.type === "phase") return "";
          const milestone = task.next_milestone_date
            ? moment(task.next_milestone_date).format("DD MMM, YYYY")
            : "N/A";
          const details = task.next_milestone_date_details || "No details available";
          return `
            <b>${task.text}</b><br/>
            <b>Next Milestone:</b> ${milestone}<br/>
            <b>Details:</b> ${details}
          `;
        };
        gantt.parse({ data: sortedData });

        gantt.templates.task_class = function (start, end, task) {
          if (task.type === "phase") return "";

          if (task.health && typeof task.health === "string") {
            return task.health.toLowerCase();
          }

          return "no-status";
        };
      });
  });

  gantt.config.scales = [
    { unit: "month", step: 1, format: "%M %Y" },
    {
      unit: "quarter",
      step: 1,
      format: function (date) {
        const quarter = Math.floor(date.getMonth() / 3) + 1;
        return "Q" + quarter;
      },
    },
  ];

  gantt.config.scale_height = 60;
  gantt.config.readonly = true;
  gantt.config.columns = [
    { name: "text", label: "Project Name", tree: true, width: "200" },
  ];
  document
    .getElementById("btnPrintPage")
    .addEventListener("click", function () {
      const portfolioTitleElement = document.querySelector(".portfolio-title");

      if (!portfolioTitleElement) {
        console.error("Portfolio title element not found!");
        return;
      }

      const portfolioName = portfolioTitleElement.textContent.trim();

      // Create a style element for the print header
      const style = document.createElement("style");
      style.setAttribute("type", "text/css");
      style.setAttribute("media", "print");

      // Add CSS for the print header
      const css = `
      @page {
        margin-top: 3cm; /* Adjust top margin to make space for the header */
      }
      body::before {
        content: "${portfolioName}";
        display: block;
        text-align: center; /* Center the header */
        font-weight: bold;
        font-size: 1.5em;
        margin-bottom: 1cm; /* Add space between the header and content */
      }
    `;

      style.appendChild(document.createTextNode(css));
      document.head.appendChild(style);

      // Trigger the print dialog
      window.print();

      // Remove the style element after printing
      setTimeout(() => {
        document.head.removeChild(style);
      }, 100); // Short delay to ensure the print dialog is handled
    }); 
</script>

<%- contentFor('BottomJs') %>
