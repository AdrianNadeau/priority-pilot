<%- contentFor('HeaderCss') %>

<style>
  html,
  body {
    height: 100%;
    margin: 0;
    padding: 0;
  }
  #gantt_here {
    width: 100%;
    height: 800px;
  }
  /* ✅ Default phase (parent) bars will remain blue */
  .gantt_task_line {
    background-color: #007bff; /* Default blue for phases */
  }

  /* ✅ Custom colors for projects */
  .green .gantt_task_content {
    background-color: #28a745 !important;
    color: white;
  }

  .yellow .gantt_task_content {
    background-color: #ffc107 !important;
    color: black;
  }

  .red .gantt_task_content {
    background-color: #dc3545 !important;
    color: white;
  }

  .no-status .gantt_task_content {
    background-color: #6c757d !important;
    color: white;
  }
</style>

<%- contentFor('breadcrumb') %> <%- contentFor('body') %>
<div class="page-content-wrapper">
  <div class="container-fluid">
    <!-- Filter Display Section -->
    <!-- Date Range Row -->
    <div
      class="row mb-2 align-items-center"
      style="
        margin-left: 0px;
        margin-right: 0px;
        min-height: 50px;
        height: 50px;
        background: hsl(197, 70%, 91%);
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
      "
    >
      <div class="col-md-12 d-flex align-items-center">
        <span
          class="mdi mdi-calendar-check"
          style="font-size: 1.5rem; margin-right: 8px"
        ></span>
        <span style="font-weight: 500; margin-right: 12px">Date Range: </span>
        <span class="text-muted" style="margin-right: 8px">Start:</span>
        <input
          type="text"
          class="form-control flatpickr-input active"
          id="from_date"
          name="from_date"
          placeholder="YYYY-MM-DD"
          style="width: 150px; margin-right: 10px"
          value="<%= currentFromDate || '' %>"
        />
        <span style="font-weight: 500; margin-right: 8px">End:</span>
        <input
          type="text"
          class="form-control flatpickr-input active"
          id="to_date"
          name="to_date"
          placeholder="YYYY-MM-DD"
          style="width: 150px; margin-right: 10px"
          value="<%= currentToDate || ''%>"
        />
        <button
          type="button"
          class="btn btn-primary btn-sm"
          style="margin-left: 10px"
          id="updateBtn"
          onclick="filterDashboard()"
        >
          Update
        </button>
        <span
          id="dayCount"
          style="margin-left: 15px; font-weight: 500; color: #495057"
        ></span>
      </div>
    </div>

    <div id="gantt_here" style="width: 1200px; height: 800px"></div>
  </div>
</div>

<script>
  // Calculate and display day count
  window.updateDayCount = function () {
    const fromDate = document.getElementById("from_date")
      ? document.getElementById("from_date").value
      : "";
    const toDate = document.getElementById("to_date")
      ? document.getElementById("to_date").value
      : "";
    const dayCountSpan = document.getElementById("dayCount");

    if (!dayCountSpan) {
      return;
    }

    if (fromDate && toDate) {
      // Parse dates in Y-m-d format
      const from = new Date(fromDate);
      const to = new Date(toDate);

      if (!isNaN(from.getTime()) && !isNaN(to.getTime())) {
        const diffTime = Math.abs(to - from);
        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;
        const dayText = `(${diffDays} day${diffDays !== 1 ? "s" : ""})`;
        dayCountSpan.textContent = dayText;
      } else {
        dayCountSpan.textContent = "";
      }
    } else {
      dayCountSpan.textContent = "";
    }
  };

  // Filter functions
  function filterDashboard() {
    const fromDate = document.getElementById("from_date").value;
    const toDate = document.getElementById("to_date").value;

    // Update day count display
    updateDayCount();

    // Dates are already in Y-m-d format from Flatpickr
    function convertDateFormat(dateStr) {
      // Flatpickr already provides Y-m-d format
      return dateStr;
    }

    // Send filter data to server to save in persons table
    fetch("/update-filter", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        from_date: convertDateFormat(fromDate),
        to_date: convertDateFormat(toDate),
      }),
    })
      .then((response) => response.json())
      .then((data) => {
        if (data.success) {
          console.log("Filter preferences saved successfully");
          // Redirect to current page with filters
          window.location.href = window.location.pathname;
        } else {
          console.error("Error saving filter preferences:", data.message);
          // Still redirect to try to apply filters
          const params = new URLSearchParams();
          if (fromDate) params.append("from_date", convertDateFormat(fromDate));
          if (toDate) params.append("to_date", convertDateFormat(toDate));
          const queryString = params.toString();
          const url = queryString
            ? `${window.location.pathname}?${queryString}`
            : window.location.pathname;
          window.location.href = url;
        }
      })
      .catch((error) => {
        console.error("Error:", error);
        // Fallback: redirect with query parameters
        const params = new URLSearchParams();
        if (fromDate) params.append("from_date", convertDateFormat(fromDate));
        if (toDate) params.append("to_date", convertDateFormat(toDate));
        const queryString = params.toString();
        const url = queryString
          ? `${window.location.pathname}?${queryString}`
          : window.location.pathname;
        window.location.href = url;
      });
  }

  // Flatpickr initialization
  document.addEventListener("DOMContentLoaded", function () {
    // Initialize date pickers with Flatpickr
    flatpickr("#from_date", {
      dateFormat: "Y-m-d",
      defaultDate: document.getElementById("from_date").value || null,
      onChange: updateDayCount,
    });

    flatpickr("#to_date", {
      dateFormat: "Y-m-d",
      defaultDate: document.getElementById("to_date").value || null,
      onChange: updateDayCount,
    });

    // Update day count on page load if dates exist
    if (
      document.getElementById("from_date").value &&
      document.getElementById("to_date").value
    ) {
      updateDayCount();
    }
  });
</script>
<script>
  // Wait for gantt to be available
  function waitForGantt(callback, maxWait = 5000) {
    const startTime = Date.now();
    const checkInterval = setInterval(() => {
      if (typeof gantt !== 'undefined') {
        clearInterval(checkInterval);
        console.log("Gantt library loaded");
        callback();
      } else if (Date.now() - startTime > maxWait) {
        clearInterval(checkInterval);
        console.error("Gantt library failed to load within", maxWait, "ms");
      }
    }, 100);
  }

  document.addEventListener("DOMContentLoaded", function () {
    console.log("DOMContentLoaded fired on flight plan page");
    console.log("gantt object available:", typeof gantt);

    // Wait for gantt library if not available yet
    if (typeof gantt === 'undefined') {
      console.log("Gantt not available yet, waiting...");
      waitForGantt(initializeGantt);
      return;
    }

    initializeGantt();
  });

  function initializeGantt() {
    console.log("initializeGantt() called");
    console.log("gantt available:", typeof gantt);

        fetch("/projects/flightview/ganttChart/")
      .then((response) => {
        console.log("Fetch response status:", response.status);
        return response.json();
      })
      .then((pData) => {
        console.log("Gantt data received:", pData);

        const projects = pData.companyProjects;

        const phaseMapping = {
          3: { id: 3, text: "Discovery", open: false, type: "phase" },
          4: { id: 4, text: "Delivery", open: false, type: "phase" },
        };

        const categories = Object.values(phaseMapping);

        const filteredProjects = projects.filter((project) => {
          const validPhase = [3, 4].includes(project.phase_id_fk);

          const hasValidStartDate =
            project.start_date && !isNaN(new Date(project.start_date));
          const hasValidEndDate =
            project.end_date && !isNaN(new Date(project.end_date));

          return validPhase && hasValidStartDate && hasValidEndDate;
        });

        const colorMapping = {
          Green: "#28a745",
          Yellow: "#ffc107",
          Red: "#dc3545",
        };

        const tasks = {
          data: filteredProjects.map((project) => {
            const phaseId = phaseMapping[project.phase_id_fk]?.id;

            return {
              id: project.id + 1000,
              text: project.project_name,
              start_date: new Date(project.start_date).toLocaleDateString(
                "en-GB",
              ),
              duration: Math.ceil(
                (new Date(project.end_date) - new Date(project.start_date)) /
                  (1000 * 60 * 60 * 24),
              ),
              parent: phaseId,
              color: colorMapping[project.health] || "#000000",
              health: project.health,
              type: "task",
              next_milestone_date: project.next_milestone_date,
              next_milestone_date_details: project.next_milestone_date_details,
            };
          }),
          links: [],
        };

        const ganttData = [...categories, ...tasks.data];

        /* ------------------ GANTT CONFIG ------------------ */

        gantt.config.scales = [
          { unit: "month", step: 1, format: "%M %Y" },
          {
            unit: "quarter",
            step: 1,
            format: function (date) {
              return "Q" + (Math.floor(date.getMonth() / 3) + 1);
            },
          },
        ];

        gantt.config.scale_height = 60;
        gantt.config.readonly = true;
        gantt.config.columns = [
          { name: "text", label: "Project Name", tree: true, width: 210 },
        ];

        gantt.plugins({ tooltip: true });

        /* ------------------ TEMPLATES ------------------ */

        gantt.templates.tooltip_text = function (start, end, task) {
          if (task.type === "phase") return "";

          const milestone = task.next_milestone_date
            ? moment(task.next_milestone_date).format("DD MMM, YYYY")
            : "N/A";

          const details =
            task.next_milestone_date_details || "No details available";

          return `
          <b>${task.text}</b><br/>
          <b>Next Milestone:</b> ${milestone}<br/>
          <b>Details:</b> ${details}
        `;
        };

        gantt.templates.task_class = function (start, end, task) {
          if (task.type === "phase") return "";

          if (typeof task.health === "string") {
            return task.health.toLowerCase();
          }

          return "no-status";
        };

        /* ------------------ INIT ------------------ */

        console.log("Initializing gantt with", ganttData.length, "items");
        gantt.init("gantt_here");
        gantt.parse({ data: ganttData });
        console.log("Gantt setup complete");
      })
      .catch((error) => {
        console.error("Error fetching or processing gantt data:", error);
      });
  }
</script>
<script>
  document
    .getElementById("btnPrintPage")
    .addEventListener("click", function () {
      const portfolioTitleElement = document.querySelector(".portfolio-title");

      if (!portfolioTitleElement) {
        console.error("Portfolio title element not found!");
        return;
      }

      const portfolioName = portfolioTitleElement.textContent.trim();

      // Create a style element for the print header
      const style = document.createElement("style");
      style.setAttribute("type", "text/css");
      style.setAttribute("media", "print");

      // Add CSS for the print header
      const css = `
      @page {
          margin-top: 3cm; /* Adjust top margin to make space for the header */
      }
      body::before {
        content: "${portfolioName}";
        display: block;
        text-align: center; /* Center the header */
        font-weight: bold;
        font-size: 1.5em;
        margin-bottom: 1cm; /* Add space between the header and content */
      }
    `;

      style.appendChild(document.createTextNode(css));
      document.head.appendChild(style);

      // Trigger the print dialog
      window.print();

      // Remove the style element after printing
      setTimeout(() => {
        document.head.removeChild(style);
      }, 100); // Short delay to ensure the print dialog is handled
    });
</script>
<%- contentFor('FooterJs') %> <%- contentFor('BottomJs') %>
