<%- contentFor('HeaderCss') %>
        <% if (projects.length > 0) { %>
        <button type="button" class="btn btn-primary waves-effect waves-light" id="btnExportProjects">Download Report</button>
        <% } %>
    </div>
    <div class="row">
      <div class="col-lg-12">
        <div class="card-body" style="border:0px !important;">
          <% if (projects.length === 0) { %>
          <div class="alert alert-warning" role="alert">
            <strong>No projects found!</strong> Please <a href="#" id="openAddProjectModal">add one project</a> to get started.
          </div>
          <% } else { %>
          <div class="table-responsive">
            <table class="table mb-0">
              <thead>
                <tr>
                  <!-- <th>ID</th> -->
                  <th>Name</th>
                  <th>Prime</th>
                  <th>Sponsor</th>
                  <th>Start</th>
                  <th>End</th>
                  <th>Phase</th>
                  <th>Cost</th>
                  <th>Status</th>
                </tr>
              </thead>
              <% projects.length%>
              <% projects.forEach(function(project) { %>
              <tbody>
                <tr style="cursor: pointer;">
                  <td style="display: none;"><%= project.id %></td>
                  <td><%= project.project_name %></td>
                  <% if (project.prime_last_name) { %>
                  <td><%= project.prime_last_name %>, <%= project.prime_first_name %></td>
                  <% } else { %>
                  <td>N/A</td>
                  <% } %>
                  <% if (project.sponsor_last_name) { %>
                  <td><%= project.sponsor_last_name %>, <%= project.sponsor_first_name %></td>
                  <% } else { %>
                  <td>N/A</td>
                  <% } %>
                  <td>
                    <% if (project.start_date) { %>
                    <%= new Date(project.start_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                    <% } %>
                  </td>
                  <td>
                    <% if (project.end_date) { %>
                    <%= new Date(project.end_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                    <% } %>
                  </td>
                  <td><%= project.phase_name %></td>
                  <td>$<%= project.project_cost %></td>
                  <td>
                    <% if (project.can_update_status) { %>
                      <i data-toggle="modal" data-target="#myModal_<%= project.id %>" style="cursor:pointer;color:#34b871 !important;"  class="mdi mdi-note-plus"></i>
                      <i data-toggle="modal" data-target="#StatusUpdatesModal" class="mdi mdi-eye js-status-eye" data-project-id="<%= project.id %>" style="cursor:pointer;color:#34b871 !important;"></i>
                    <% } else { %>
                      <i class="mdi mdi-eye js-status-eye" data-project-id="<%= project.id %>" style="cursor:pointer;color:#34b871 !important;width:24px; height:24px;"></i>
                    <% } %>
                  </td>
                </tr>
              </tbody>
              <!-- Modal for adding status (admin or authorized users) -->
              <div id="myModal_<%= project.id %>" class="modal fade" href="#" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
                <div class="modal-dialog">
                  <div class="modal-content">
                    <form action="/statuses" class="needs-validation" novalidate id="addStatusForm_<%= project.id %>" method="POST">
                      <input type="hidden" name="prime_only" value="n">
                      <div class="modal-header">
                        <h5 class="modal-title mt-0" id="myModalLabel">Add Status</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                      </div>
                      <div class="modal-body">
                        <input type="hidden" name="project_id" value="<%= project.id %>">
                        <input type="hidden" name="prime_id_fk" value="<%= project.prime_id_fk %>">
                        <div class="row">
                          <div class="col-md-12">
                            <div class="form-group">
                              <i class="bi bi-calendar-check"></i>
                              <input
                                type="text"
                                required
                                class="form-control datepicker"
                                id="status_date_<%= project.id %>"
                                name="status_date"
                                placeholder="Status Date"
                              />
                              <div class="invalid-feedback">Please select a valid status date.</div>
                              <strong>Prime:</strong> <%= project.prime_last_name ? `${project.prime_last_name}, ${project.prime_first_name}` : "N/A" %>
                            </div>
                            <div class="form-group">
                              <strong>Accomplishments:</strong>
                              <textarea class="form-control" maxlength="3000" name="status_accomplishments" id="accomplishments_<%= project.id %>" required rows="3" placeholder="Enter accomplishments..."></textarea>
                              <div class="invalid-feedback">Please enter accomplishments.</div>
                            </div>
                            <div class="form-group">
                              <strong>Issues:</strong>
                              <textarea class="form-control" maxlength="3000" name="issue" id="issue_<%= project.id %>" rows="3" required placeholder="Enter issues..."></textarea>
                              <div class="invalid-feedback">Please enter issues.</div>
                            </div>
                            <div class="form-group">
                              <strong>Actions:</strong>
                              <textarea class="form-control" maxlength="3000" name="actions" id="actions_<%= project.id %>" rows="3" required placeholder="Enter actions..."></textarea>
                              <div class="invalid-feedback">Please enter actions.</div>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                              <div class="form-group needs-validation" novalidate>
                                <strong>Progress:</strong>
                                <select style="width:100px !important;" class="form-control" id="progress_<%= project.id %>" name="progress" required>
                                  <option value="">Select</option>
                                  <% for (let i = 10; i <= 100; i += 10) { %>
                                    <option value="<%= i %>"><%= i %></option>
                                  <% } %>
                                </select>
                                <div class="invalid-feedback">Please select a progress value.</div>
                              </div>
                              <div class="form-group" style="margin-left: 10px;">
                                <strong>Health:</strong>
                                <select style="width:100px !important;padding-left:10px;" class="form-control" id="health_<%= project.id %>" required name="health">
                                  <option value="">Select</option>
                                  <option value="green">Green</option>
                                  <option value="yellow">Yellow</option>
                                  <option value="red">Red</option>
                                </select>
                                <div class="invalid-feedback">Please select a health status.</div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                      <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary">Save changes</button>
                      </div>
                    </form>
                  </div>
                </div>
              </div>
              <% }); %>
            </table>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <div class="row">
    <div class="col-md-6 m-t-30">
      <!-- project modal content -->
      <div id="addProject" class="modal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content" style="width: 900px;">
            <div class="modal-header">
              <h5 class="modal-title mt-0">Add Project</h5>
              <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
            </div>
            <div class="modal-body">
              <div class="container">
                <div class="container">
                  <form action="/projects" class="needs-validation" novalidate method="POST">
                    <input type="hidden" name="funnelPage" id="funnelPage" value="n">
                    <div class="row">
                      <div class="col-md-6">
                        <!-- Left Column -->
                        <div class="form-group">
                          <label for="project_name">Project Name:</label> <span class="required_star">*</span>
                          <input type="text" class="form-control" id="project_name" maxlength="25" name="project_name" required>
                          <div class="invalid-feedback">
                            Please enter project name.
                          </div>
                        </div>
                        <div class="form-group">
                          <label for="headline">Headline:</label>
                          <input type="text" class="form-control" id="headline" name="headline" maxlength="250">
                        </div>
                        <div class="form-group">
                          <label for="why">Why:</label>
                          <textarea class="form-control" id="why" name="why"></textarea>
                        </div>
                        <div class="form-group">
                          <label for="what">What:</label>
                          <textarea class="form-control" id="what" name="what"></textarea>
                        </div>

                        <div class="form-group" id="date_section">
                          <label for="dates">Start Date and End Date: <span class="required_star">*</span></label>
                          <div class="form-row">
                            <div class="col">
                              <i class="bi bi-calendar-check"></i><input type="text" class="form-control start_datepicker" id="start_date" name="start_date" placeholder="Start Date">
                              <div class="invalid-feedback">
                                Start Date is required.
                              </div>
                            </div>
                            <div class="col">
                              <input type="text" required class="form-control end_datepicker" id="end_date" name="end_date" placeholder="End Date">
                              <div class="invalid-feedback">
                                End Date is required.   
                              </div>
                            </div>
                            <div class="col">
                              <input type="text" class="form-control nms_datepicker" id="next_milestone_date" name="next_milestone_date" placeholder="Milestone Date">
                            </div>
                          </div>
                          <div><span class="required_star" id ="dates_required" style="display:none;">Start and End dates are required</span></span></div>
                        </div>
                      </div>
                      <div class="col-md-6">
                        <!-- Right Column -->
                        <div class="form-row">
                          <div class="col">
                            <div class="form-group">
                              <label for="phase">Phase:</label>
                              <select name="phase_id_fk" id="phase_id_fk" class="form-control">
                                <% phases.forEach(function(phase){ %>
                                <option value="<%= phase.id %>"><%= phase.phase_name %></option>
                                <% }) %>
                              </select>
                            </div>
                          </div>
                          <div class="col">
                            <div class="form-group">
                              <label for="priority">Priority:</label>
                              <select name="priority_id_fk" id="priority_id_fk" class="form-control">
                                <% priorities.forEach(function(priority){ %>
                                <option value="<%= priority.id %>"><%= priority.priority_name %></option>
                                <% }) %>
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col">
                            <div class="form-group">
                              <label for="sponsor">Sponsor:</label>
                              <select name="sponsor_id_fk" id="sponsor_id_fk" class="form-control">
                                <% sponsors.forEach(function(sponsor){ %>
                                <option value="<%= sponsor.id %>"><%= sponsor.last_name %>, <%= sponsor.first_name %></option>
                                <% }) %>
                              </select>
                            </div>
                          </div>
                          <div class="col">
                            <div class="form-group">
                              <label for="prime">Prime:</label>
                              <select name="prime_id_fk" id="prime_id_fk" class="form-control">
                                <% primes.forEach(function(prime){ %>
                                <option value="<%= prime.id %>"><%= prime.last_name %>, <%= prime.first_name %></option>
                                <% }) %>
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col">
                            <div class="form-group">
                              <label for="effort">Effort (PH)</label>
                              <input type="text" class="form-control" id="effort" oninput="formatNumberWithCommas(this);" name="effort" value="0">
                            </div>
                          </div>
                          <div class="col">
                            <div class="form-group">
                              <label for="project_cost">Cost ($)</label>
                              <input type="text" class="form-control" id="project_cost" oninput="formatNumberWithCommas(this);" name="project_cost" value="0">
                            </div>
                          </div>
                          <div class="col">
                            <div class="form-group">
                              <label for="benefit">Benefit (ROI or $)</label>
                              <input type="text" class="form-control" id="benefit" oninput="formatNumberWithCommas(this);" name="benefit" value="0">
                            </div>
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col">
                            <div class="form-group">
                              <label for="tag_1">Tag 1:</label>
                              <select name="tag_1" id="tag_1" class="form-control">
                                <% if (tags && tags.length > 0) { %>
                                <% tags.forEach(function(tag){ %>
                                <option value="<%= tag.id %>"><%= tag.tag_name %></option>
                                <% }) %>
                                <% } else { %>
                                <option value="">No tags available</option>
                                <% } %>
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col">
                            <div class="form-group">
                              <label for="tag_2">Tag 2:</label>
                              <select name="tag_2" id="tag_2" class="form-control">
                                <% if (tags && tags.length > 0) { %>
                                <% tags.forEach(function(tag){ %>
                                <option value="<%= tag.id %>"><%= tag.tag_name %></option>
                                <% }) %>
                                <% } else { %>
                                <option value="">No tags available</option>
                                <% } %>
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col">
                            <div class="form-group">
                              <label for="tag_3">Tag 3:</label>
                              <select name="tag_3" id="tag_3" class="form-control">
                                <% if (tags && tags.length > 0) { %>
                                <% tags.forEach(function(tag){ %>
                                <option value="<%= tag.id %>"><%= tag.tag_name %></option>
                                <% }) %>
                                <% } else { %>
                                <option value="">No tags available</option>
                                <% } %>
                              </select>
                            </div>
                            <div class="form-group">
                              <label for="reference">Reference:</label>
                              <input type="text" class="form-control" id="reference" name="reference">
                              <div class="invalid-feedback">
                                Please enter project name.
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="modal-footer">
                      <button type="button" class="btn btn-secondary waves-effect" data-dismiss="modal">Cancel</button>
                      <button class="btn btn-primary w-md waves-effect waves-light" type="submit">Submit</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- contentFor('FooterJs') %> <%- contentFor('BottomJs') %>

<!-- Merged script block content -->
<script>
  document.addEventListener("DOMContentLoaded", function() {
    'use strict';
   var forms = document.querySelectorAll(".needs-validation");

    // Loop over them and prevent submission
    Array.prototype.slice.call(forms).forEach(function (form) {
      form.addEventListener(
        "submit",
        function (event) {
          if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
          }

          form.classList.add("was-validated");
        },
        false,
      );
    });
    //add event listenter for export
    // Add null check for export button
const exportBtn = document.getElementById('btnExportProjects');
if (exportBtn) {
  exportBtn.addEventListener('click', function() {
    fetch('/projects/export/export-project-list/')
      .then(response => {
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        return response.blob();
      })
      .then(blob => {
        const today = new Date();
        const formattedDate = `${today.getFullYear()}-${String(today.getDate()).padStart(2, '0')}-${String(today.getMonth() + 1).padStart(2, '0')}`;
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.style.display = 'none';
        a.href = url;
        a.download = `projects-export-${formattedDate}.csv`;
        document.body.appendChild(a);
        a.click();
        window.URL.revokeObjectURL(url);
        console.log("Export successful");
      })
      .catch(error => {
        console.error('Error fetching project data:', error);
      });
  });
}
    // Numeric input validation for specific fields
    const numericFields = ['project_cost', 'effort', 'benefit'];
    numericFields.forEach(function(fieldId) {
        document.getElementById(fieldId).addEventListener('keydown', function(event) {
            if (![46, 8, 9, 27, 13, 110, 190].includes(event.keyCode) &&
                !((event.keyCode >= 48 && event.keyCode <= 57) || (event.keyCode >= 96 && event.keyCode <= 105)) &&
                !(event.ctrlKey || event.metaKey)) {
                alert("Only numbers are allowed.")
                event.preventDefault();
            }
        });
    });

    // Table row click navigation to edit page
    document.querySelectorAll(".table tbody tr").forEach(function(row) {
        row.addEventListener('click', function() {
            var id = row.cells[0].textContent;
            window.location.replace('/projects/edit/' + id);
        });
    });

    // Input formatting with commas for project cost and benefit
    ['project_cost', 'benefit'].forEach(function(fieldId) {
        document.getElementById(fieldId).addEventListener('input', function () {
            let input = this.value.replace(/[^0-9.]/g, '');
            if (input.includes('.')) {
                const parts = input.split('.');
                parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ',');
                input = parts.join('.');
            } else {
                input = input.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
            }
            this.value = input;
        });
    });
    console.log("Initializing flatpickr");
    // Initialize Flatpickr for all datepicker inputs
    flatpickr(".datepicker", {
      dateFormat: "Y-m-d", // Format the date as YYYY-MM-DD
      allowInput: true,     // Allow manual input if needed
      allowInvalidPreload: true, // Allow invalid dates to be preloaded
    });
    flatpickr(".start_datepicker", {
      dateFormat: "Y-m-d", // Format the date as YYYY-MM-DD
      allowInput: true,     // Allow manual input if needed
      allowInvalidPreload: true, // Allow invalid dates to be preloaded
    });
    flatpickr(".end_datepicker", {
      dateFormat: "Y-m-d", // Format the date as YYYY-MM-DD
      allowInput: true,     // Allow manual input if needed
      allowInvalidPreload: true, // Allow invalid dates to be preloaded
    });
    flatpickr(".nms_datepicker", {
      dateFormat: "Y-m-d", // Format the date as YYYY-MM-DD
      allowInput: true,     // Allow manual input if needed
      allowInvalidPreload: true, // Allow invalid dates to be preloaded
    });

  // Show or hide date_section based on phase selection
  window.phaseSelect = document.getElementById("phase_id_fk");
  window.dateSection = document.getElementById("date_section");
  window.startDateInput = document.getElementById('start_date');
  window.endDateInput = document.getElementById('end_date');
  window.nextMilestoneDateInput = document.getElementById('next_milestone_date');
  window.dateRequired = document.getElementById('dates_required');

  window.toggleDateSection = function() {
      if (phaseSelect.value == "1" || phaseSelect.value == "6") {
        // Phase is pitch, hide dates and clear validation messages
    dateSection.style.display = 'none';
    startDateInput.required = false;
    endDateInput.required = false;
    dateRequired.style.display = 'none';
    startDateInput.value = "";
    endDateInput.value = "";
    nextMilestoneDateInput.value = "";
      } else {
        // Phase is not pitch, show dates and set required
        dateSection.style.display = 'block';
        startDateInput.required = true;
        endDateInput.required = true;
        if (!startDateInput.value) {
          // Set the placeholder
          startDateInput.placeholder = "Start Date";
        }
        if (!endDateInput.value) {
          endDateInput.placeholder = "End Date";
        }
        if (!nextMilestoneDateInput.value) {
          nextMilestoneDateInput.placeholder = "Milestone Date";
        }
      }
    }

  // End of DOMContentLoaded handler
  });

  </script>

  <!-- Status modals -->
