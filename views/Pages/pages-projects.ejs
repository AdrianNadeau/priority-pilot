<%- contentFor('HeaderCss') %>
<style>
  .sortable {
    cur                    <th class="sortable" data-column="project_name" data-sort="default">Name <span class="sort-arrow">↓</span></th>
                    <th class="sortable" data-column="prime_name" data-sort="default">Prime <span class="sort-arrow">↓</span></th>
                    <th class="sortable" data-column="sponsor_name" data-sort="default">Sponsor <span class="sort-arrow">↓</span></th>
                    <th class="sortable" data-column="start_date" data-sort="default">Start <span class="sort-arrow">↓</span></th>
                    <th class="sortable" data-column="end_date" data-sort="default">End <span class="sort-arrow">↓</span></th>
                    <th class="sortable" data-column="phase_name" data-sort="default">Phase <span class="sort-arrow">↓</span></th>
                    <th class="sortable" data-column="project_cost" data-sort="default">Cost <span class="sort-arrow">↓</span></th>inter;
    position: relative;
    user-select: none;
    padding: 12px 8px !important;
    background-color: #f8f9fa;
    border-bottom: 2px solid #dee2e6 !important;
  }
  .sortable:hover {
    background-color: #e9ecef !important;
    cursor:pointer
  }
  .sort-arrow {
    display: inline-block;
    margin-left: 8px;
    font-size: 16px;
    font-weight: bold;
    color: #6c757d;
    vertical-align: middle;
    min-width: 12px;
    text-align: center;
    transition: color 0.2s ease, transform 0.1s ease;
  }
  .sort-arrow:hover {
    color: #007bff !important;
    transform: scale(1.1);
    cursor:pointer
  }
  .sort-arrow.active {
    color: #007bff !important;
    cursor:pointer
  }
  .table thead th {
    font-weight: 600;
    vertical-align: middle;
  }
</style>

<%- contentFor('breadcrumb') %>
<%- contentFor('body') %>
<div class="page-content-wrapper">
  <div class="container-fluid">
    <div class="page-buttons">
      <button type="button" class="btn btn-primary waves-effect waves-light" data-toggle="modal" data-target="#addProject" id="btnAddProject">Add Project</button>
      <% if (projects.length > 0) { %>
        <button type="button" class="btn btn-primary waves-effect waves-light" id="btnExportProjects">Download Report</button>
      <% } %>
    </div>

    <div class="row">
      <div class="col-lg-12">
        <div class="card-body" style="border:0px !important;">
          <% if (projects.length === 0) { %>
            <div class="alert alert-warning" role="alert">
              <strong>No projects found!</strong> Please <a href="#" id="openAddProjectModal">add one project</a> to get started.
            </div>
          <% } else { %>
            <div class="table-responsive">
              <table class="table mb-0">
                <thead>
                  <tr>
                    <th class="sortable" data-column="project_name" data-sort="default">Name <i class="sort-arrow fa fa-sort"></i></th>
                    <th class="sortable" data-column="prime_name" data-sort="default">Prime <i class="sort-arrow fa fa-sort"></i></th>
                    <th class="sortable" data-column="sponsor_name" data-sort="default">Sponsor <i class="sort-arrow fa fa-sort"></i></th>
                    <th class="sortable" data-column="start_date" data-sort="default">Start <i class="sort-arrow fa fa-sort"></i></th>
                    <th class="sortable" data-column="end_date" data-sort="default">End <i class="sort-arrow fa fa-sort"></i></th>
                    <th class="sortable" data-column="phase_name" data-sort="default">Phase <i class="sort-arrow fa fa-sort"></i></th>
                    <th class="sortable" data-column="project_cost" data-sort="default">Cost <i class="sort-arrow fa fa-sort"></i></th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% projects.forEach(function(project) { %>
                    <tr style="cursor: pointer;">
                      <td style="display: none;"><%= project.id %></td>
                      <td><%= project.project_name %></td>
                      <td><%= project.prime_last_name ? `${project.prime_last_name}, ${project.prime_first_name}` : "N/A" %></td>
                      <td><%= project.sponsor_last_name ? `${project.sponsor_last_name}, ${project.sponsor_first_name}` : "N/A" %></td>
                      <td><%= project.start_date ? new Date(project.start_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : "" %></td>
                      <td><%= project.end_date ? new Date(project.end_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : "" %></td>
                      <td><%= project.phase_name %></td>
                      <td>$<%= project.project_cost %></td>
                      <td>
                        <% if (project.can_update_status) { %>
                          <i data-toggle="modal" data-target="#myModal_<%= project.id %>" style="cursor:pointer;color:#34b871 !important;" class="mdi mdi-note-plus"></i>
                        <% } %>
                        <% if (project.can_view) { %>
                          <i data-toggle="modal" data-target="#StatusUpdatesModal" class="mdi mdi-eye js-status-eye" data-project-id="<%= project.id %>" style="cursor:pointer;color:#34b871 !important;"></i>
                        <% } %>
                      </td>
                    </tr>
                    <!-- Status Modal for each project ... -->
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- contentFor('FooterJs') %> 
<%- contentFor('BottomJs') %>

<script>
document.addEventListener("DOMContentLoaded", function() {
  'use strict';

  // Form validation
  var forms = document.querySelectorAll(".needs-validation");
  Array.prototype.slice.call(forms).forEach(function (form) {
    form.addEventListener("submit", function (event) {
      if (!form.checkValidity()) {
        event.preventDefault();
        event.stopPropagation();
      }
      form.classList.add("was-validated");
    });
  });

  // Export button
  const exportBtn = document.getElementById('btnExportProjects');
  if (exportBtn) {
    exportBtn.addEventListener('click', function() {
      fetch('/projects/export/export-project-list/')
        .then(response => {
          if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
          return response.blob();
        })
        .then(blob => {
          const today = new Date();
          const formattedDate = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
          const url = window.URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.style.display = 'none';
          a.href = url;
          a.download = `projects-export-${formattedDate}.csv`;
          document.body.appendChild(a);
          a.click();
          window.URL.revokeObjectURL(url);
          console.log("Export successful");
        })
        .catch(error => {
          console.error('Error fetching project data:', error);
        });
    });
  }

  // Table sorting
  function initTableSorting() {
    const headers = document.querySelectorAll('.sortable');
    headers.forEach(header => {
      header.addEventListener('click', function() {
        const column = header.getAttribute('data-column');
        let direction = header.getAttribute('data-sort');
        direction = direction === 'asc' ? 'desc' : 'asc';
        sortTable(column, direction);
        headers.forEach(h => {
          h.setAttribute('data-sort', 'default');
          h.querySelector('.sort-arrow').className = 'sort-arrow default';
        });
        header.setAttribute('data-sort', direction);
        header.querySelector('.sort-arrow').className = `sort-arrow active ${direction}`;
      });
    });
  }

  function sortTable(column, direction) {
    const table = document.querySelector('.table');
    const tbody = table.querySelector('tbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    const columnIndex = Array.from(table.querySelectorAll('th')).findIndex(th => th.getAttribute('data-column') === column);

    rows.sort((a, b) => {
      const aText = a.cells[columnIndex + 1].textContent.trim();
      const bText = b.cells[columnIndex + 1].textContent.trim();
      if (!isNaN(parseFloat(aText)) && !isNaN(parseFloat(bText))) {
        return direction === 'asc'
          ? parseFloat(aText) - parseFloat(bText)
          : parseFloat(bText) - parseFloat(aText);
      }
      return direction === 'asc'
        ? aText.localeCompare(bText)
        : bText.localeCompare(aText);
    });

    rows.forEach(row => tbody.appendChild(row));
  }

  try { initTableSorting(); } catch (error) {
    console.log('Error initializing table sorting:', error);
  }

  // Numeric validation
  ['project_cost', 'effort', 'benefit'].forEach(function(fieldId) {
    const el = document.getElementById(fieldId);
    if (!el) return;
    el.addEventListener('keydown', function(event) {
      if (![46,8,9,27,13,110,190].includes(event.keyCode) &&
          !((event.keyCode >= 48 && event.keyCode <= 57) || (event.keyCode >= 96 && event.keyCode <= 105)) &&
          !(event.ctrlKey || event.metaKey)) {
        event.preventDefault();
        alert("Only numbers are allowed.");
      }
    });
  });

  // Row navigation
  document.querySelectorAll(".table tbody tr").forEach(function(row) {
    row.addEventListener('click', function(e) {
      if (e.target.closest('[data-toggle="modal"]') || e.target.closest('.js-status-eye')) return;
      var id = row.cells[0].textContent;
      window.location.replace('/projects/edit/' + id);
    });
  });

  // Flatpickr init
  flatpickr(".datepicker, .start_datepicker, .end_datepicker, .nms_datepicker", {
    dateFormat: "Y-m-d",
    allowInput: true,
    allowInvalidPreload: true
  });

  // Phase toggle
  window.phaseSelect = document.getElementById("phase_id_fk");
  window.dateSection = document.getElementById("date_section");
  window.startDateInput = document.getElementById('start_date');
  window.endDateInput = document.getElementById('end_date');
  window.nextMilestoneDateInput = document.getElementById('next_milestone_date');
  window.dateRequired = document.getElementById('dates_required');

  window.toggleDateSection = function() {
    if (phaseSelect.value == "1" || phaseSelect.value == "6") {
      dateSection.style.display = 'none';
      startDateInput.required = false;
      endDateInput.required = false;
      dateRequired.style.display = 'none';
      startDateInput.value = "";
      endDateInput.value = "";
      nextMilestoneDateInput.value = "";
    } else {
      dateSection.style.display = 'block';
      startDateInput.required = true;
      endDateInput.required = true;
    }
  }

  // Table sorting functionality
  document.querySelectorAll('.sortable').forEach(header => {
    header.addEventListener('click', function() {
      const column = this.dataset.column;
      const arrow = this.querySelector('.sort-arrow');
      const isCurrentlyDefault = arrow.classList.contains('fa-sort');
      const isCurrentlyUp = arrow.classList.contains('fa-sort-up');
      const isCurrentlyDown = arrow.classList.contains('fa-sort-down');
      
      // Determine sort direction and OPPOSITE icon (showing what happens next)
      let newSort, newIconClass;
      if (isCurrentlyDefault || isCurrentlyUp) {
        // If default or showing up arrow, sort descending and show down arrow
        newSort = 'desc';
        newIconClass = 'fa-sort-down';
      } else {
        // If showing down arrow, sort ascending and show up arrow
        newSort = 'asc';
        newIconClass = 'fa-sort-up';
      }
      
      // Reset other headers to default state
      document.querySelectorAll('.sortable').forEach(h => {
        if (h !== this) {
          h.dataset.sort = 'default';
          const otherArrow = h.querySelector('.sort-arrow');
          otherArrow.classList.remove('active', 'fa-sort-up', 'fa-sort-down');
          if (!otherArrow.classList.contains('fa')) {
            otherArrow.classList.add('fa');
          }
          otherArrow.classList.add('fa-sort');
        }
      });
      
      // Update current header
      this.dataset.sort = newSort;
      arrow.classList.remove('fa-sort-up', 'fa-sort-down', 'fa-sort');
      if (!arrow.classList.contains('fa')) {
        arrow.classList.add('fa');
      }
      arrow.classList.add('active', newIconClass);
      
      // Sort table
      sortTable(column, newSort);
    });
  });

  function sortTable(column, direction) {
    const table = document.querySelector('.table tbody');
    if (!table) return;
    
    const rows = Array.from(table.querySelectorAll('tr'));
    rows.sort((a, b) => {
      let aVal, bVal;
      
      switch(column) {
        case 'project_name': aVal = a.cells[1].textContent; bVal = b.cells[1].textContent; break;
        case 'prime_name': aVal = a.cells[2].textContent; bVal = b.cells[2].textContent; break;
        case 'sponsor_name': aVal = a.cells[3].textContent; bVal = b.cells[3].textContent; break;
        case 'start_date': 
          aVal = a.cells[4].textContent ? new Date(a.cells[4].textContent) : new Date(0);
          bVal = b.cells[4].textContent ? new Date(b.cells[4].textContent) : new Date(0);
          break;
        case 'end_date': 
          aVal = a.cells[5].textContent ? new Date(a.cells[5].textContent) : new Date(0);
          bVal = b.cells[5].textContent ? new Date(b.cells[5].textContent) : new Date(0);
          break;
        case 'phase_name': aVal = a.cells[6].textContent; bVal = b.cells[6].textContent; break;
        case 'project_cost': 
          aVal = parseFloat(a.cells[7].textContent.replace(/[$,]/g, '')) || 0;
          bVal = parseFloat(b.cells[7].textContent.replace(/[$,]/g, '')) || 0;
          break;
        default: return 0;
      }
      
      if (typeof aVal === 'string' && typeof bVal === 'string') {
        return direction === 'asc' ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
      }
      
      return direction === 'asc' ? (aVal < bVal ? -1 : 1) : (bVal < aVal ? -1 : 1);
    });
    
    table.innerHTML = '';
    rows.forEach(row => table.appendChild(row));
  }

});
</script>
