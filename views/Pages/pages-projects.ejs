
<!-- ================= HEADER CSS ================= -->

<%- contentFor('HeaderCss') %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

<style>
   /* ===== SORT ARROWS ===== */
  .sort-arrow {
    margin-left: 6px;
    font-size: 0.75rem;
    opacity: 0.4;
    transition: transform 0.35s ease, opacity 0.35s ease;
  }

  th.sorted-asc .sort-arrow {
    transform: rotate(180deg);
    opacity: 1;
  }

  th.sorted-desc .sort-arrow {
    transform: rotate(0deg);
    opacity: 1;
  }

  /* ===== SLOW SORT ANIMATION ===== */
  tbody tr {
    transition: transform 0.35s ease, opacity 0.35s ease;
  }

  tbody.sorting tr {
    opacity: 0.6;
  }
</style>

<!-- ================= BREADCRUMB / BODY ================= -->

<%- contentFor('breadcrumb') %>
<%- contentFor('body') %>

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<div class="page-content-wrapper">
  <div class="container-fluid">

<!-- ACTION BUTTONS -->
<div class="row mt-2 mb-3">
  <div class="col-md-12">
    <button class="btn btn-primary" data-toggle="modal" data-target="#addProject">Add Project</button>
    <button class="btn btn-success" id="btnExportProjects">
      <i class="mdi mdi-download mr-1"></i> Download Report
    </button>
  </div>
</div>

<!-- DATE FILTER -->
<div class="row mb-2 align-items-center" style="background:hsl(197,70%,91%); height:50px;">
  <div class="col-md-12 d-flex align-items-center">
    <strong class="mr-2">Date Range:</strong>
    <input id="from_date" class="form-control mr-2" style="width:150px" value="<%= currentFromDate %>">
    <input id="to_date" class="form-control mr-2" style="width:150px" value="<%= currentToDate %>">
    <button class="btn btn-primary btn-sm" id="btnFilter" onclick="filterDashboard()">Update</button>
    <span id="dayCount" class="ml-3 font-weight-bold"></span>
  </div>
</div>

<!-- PROJECT TABLE -->
<div class="row">
  <div class="col-lg-12">
    <div class="card-body">

      <% if (!projects || projects.length === 0) { %>
        <div class="alert alert-warning">No projects found.</div>
      <% } else { %>

      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th class="sortable" data-column="project_name">Name <i class="sort-arrow mdi mdi-sort"></i></th>
              <th class="sortable" data-column="prime_name">Prime <i class="sort-arrow mdi mdi-sort"></i></th>
              <th class="sortable" data-column="sponsor_name">Sponsor <i class="sort-arrow mdi mdi-sort"></i></th>
              <th class="sortable" data-column="start_date">Start <i class="sort-arrow mdi mdi-sort"></i></th>
              <th class="sortable" data-column="end_date">End <i class="sort-arrow mdi mdi-sort"></i></th>
              <th class="sortable" data-column="phase_name">Phase <i class="sort-arrow mdi mdi-sort"></i></th>
              <th class="sortable" data-column="project_cost">Cost <i class="sort-arrow mdi mdi-sort"></i></th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% projects.forEach(function(project) { %>
            <tr class="project-row" data-project-id="<%= project.id %>" onclick="if(!event.target.closest('i, button, a')) window.location.href='/projects/edit/<%= project.id %>';" style="cursor: pointer;">
              <td><%= project.project_name %></td>
              <td><%= project.prime_name %></td>
              <td><%= project.sponsor_name %></td>
              <td><%= project.start_date ? new Date(project.start_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '' %></td>
              <td><%= project.end_date ? new Date(project.end_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '' %></td>
              <td><%= project.phase_name %></td>
              <td>$<%= project.project_cost %></td>
              <td onclick="event.stopPropagation();">
                <i class="mdi mdi-eye js-status-eye" data-project-id="<%= project.id %>" style="cursor: pointer;"></i>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>

    </div>
  </div>
</div>


  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  document.getElementById('btnFilter').addEventListener('click', filterDashboard);
  console.log('DOM loaded - initializing projects page');

  /* DATE PICKERS */
  flatpickr('#from_date', { dateFormat: 'Y-m-d', onChange: updateDayCount });
  flatpickr('#to_date', { dateFormat: 'Y-m-d', onChange: updateDayCount });

  function updateDayCount() {
    const from = from_date.value;
    const to = to_date.value;
    if (!from || !to) return dayCount.textContent = '';
    const diff = Math.abs(new Date(to) - new Date(from));
    const days = Math.ceil(diff / 86400000) + 1;
    dayCount.textContent = '(' + days + ' day' + (days !== 1 ? 's' : '') + ')';
  }

  /* ROW CLICK NAVIGATION */
  const rows = document.querySelectorAll('.project-row');
  console.log('Found project rows:', rows.length);
  
  rows.forEach(row => {
    row.addEventListener('click', function (e) {
      console.log('Row clicked', e.target);
      if (e.target.closest('i') || e.target.closest('button') || e.target.closest('a')) {
        console.log('Ignoring click on interactive element');
        return;
      }
      const id = this.dataset.projectId;
      console.log('Navigating to project:', id);
      if (id) window.location.href = '/projects/edit/' + id;
    });
  });

  /* TABLE SORTING */
  document.querySelectorAll('th.sortable').forEach(th => {
    th.addEventListener('click', function() {
      const table = th.closest('table');
      const tbody = table.querySelector('tbody');
      const rows = Array.from(tbody.querySelectorAll('tr'));
      const column = th.dataset.column;
      const columnIndex = Array.from(th.parentNode.children).indexOf(th);
      const isAsc = !th.classList.contains('sorted-asc');
      
      // Reset other headers
      document.querySelectorAll('th.sortable').forEach(h => {
        if(h !== th) h.classList.remove('sorted-asc', 'sorted-desc');
      });
      
      // Toggle current header
      th.classList.remove('sorted-asc', 'sorted-desc');
      th.classList.add(isAsc ? 'sorted-asc' : 'sorted-desc');
      
      // Sort rows
      rows.sort((a, b) => {
        let aVal = a.children[columnIndex].innerText.trim();
        let bVal = b.children[columnIndex].innerText.trim();
        
        // Handle dates
        if (column.includes('date')) {
            aVal = new Date(aVal).getTime() || 0;
            bVal = new Date(bVal).getTime() || 0;
        } 
        // Handle currency/numbers
        else if (column.includes('cost')) {
            aVal = parseFloat(aVal.replace(/[^0-9.-]+/g,"")) || 0;
            bVal = parseFloat(bVal.replace(/[^0-9.-]+/g,"")) || 0;
        }
        
        if (aVal < bVal) return isAsc ? -1 : 1;
        if (aVal > bVal) return isAsc ? 1 : -1;
        return 0;
      });
      
      // Re-append rows
      tbody.innerHTML = '';
      rows.forEach(row => tbody.appendChild(row));
    });
  });

  // Export button
  const exportBtn = document.getElementById('btnExportProjects');
  if (exportBtn) {
    exportBtn.addEventListener('click', function() {
      fetch('/projects/export/export-project-list/')
        .then(response => {
          if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
          return response.blob();
        })
        .then(blob => {
          console.log('Blob received:', blob);
          const today = new Date();
          const formattedDate = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
          const url = window.URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.style.display = 'none';
          a.href = url;
          a.download = `projects-export-${formattedDate}.csv`;
          document.body.appendChild(a);
          a.click();
          window.URL.revokeObjectURL(url);
          console.log("Export successful");
        })
        .catch(error => {
          console.error('Error fetching project data:', error);
        });
    });
  }

});

function filterDashboard() {
  const fromDate = document.getElementById('from_date').value;
  const toDate = document.getElementById('to_date').value;

  fetch('/update-filter', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ from_date: fromDate, to_date: toDate })
  })
  .then(res => res.json())
  .then(() => window.location.reload())
  .catch(() => window.location.reload());
}

</script>
<!-- ================= FOOTER JS ================= -->

<%- contentFor('FooterJs') %>
<%- contentFor('BottomJs') %>
