<!-- PROJECT TABLE -->
<div class="row">
  <div class="col-lg-12">
    <div class="card-body">

      <% if (!projects || projects.length === 0) { %>
        <div class="alert alert-warning">No projects found.</div>
      <% } else { %>

      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th class="sortable" data-column="project_name">Name <i class="sort-arrow mdi mdi-sort-alphabetical-ascending"></i></th>
              <th class="sortable" data-column="prime_name">Prime <i class="sort-arrow mdi mdi-sort-alphabetical-ascending"></i></th>
              <th class="sortable" data-column="sponsor_name">Sponsor <i class="sort-arrow mdi mdi-sort-alphabetical-ascending"></i></th>
              <th class="sortable" data-column="start_date">Start <i class="sort-arrow mdi mdi-sort-alphabetical-ascending"></i></th>
              <th class="sortable" data-column="end_date">End <i class="sort-arrow mdi mdi-sort-alphabetical-ascending"></i></th>
              <th class="sortable" data-column="phase_name">Phase <i class="sort-arrow mdi mdi-sort-alphabetical-ascending"></i></th>
              <th class="sortable" data-column="project_cost">Cost <i class="sort-arrow mdi mdi-sort-alphabetical-ascending"></i></th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% projects.forEach(function(project) { %>
            <tr class="project-row" data-project-id="<%= project.id %>" onclick="window.location.replace='/projects/edit/<%= project.id %>';" style="cursor: pointer;">
              <td><%= project.project_name %></td>
              <td><%= project.prime_first_name %> <%= project.prime_last_name %></td>
              <td><%= project.sponsor_first_name %> <%= project.sponsor_last_name %></td>
              <td><%= project.start_date ? new Date(project.start_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '' %></td>
              <td><%= project.end_date ? new Date(project.end_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '' %></td>
              <td><%= project.phase_name %></td>
              <td>$<%= project.project_cost %></td>
              <td>
                <% if (project.can_update_status) { %>
                  <i data-toggle="modal" data-target="#myModal_<%= project.id %>" style="cursor:pointer;color:#34b871 !important;" class="mdi mdi-note-plus"></i>
                <% } %>
                <% if (project.can_view) { %>
                  <i data-toggle="modal" data-target="#StatusUpdatesModal" class="mdi mdi-eye js-status-eye" data-project-id="<%= project.id %>" style="cursor:pointer;color:#34b871 !important;"></i>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>

    </div>
  </div>
</div>


  </div>
</div>

