
<!-- ================= HEADER CSS ================= -->

<%- contentFor('HeaderCss') %>

<style>
   /* ===== SORT ARROWS ===== */
  .sort-arrow {
    margin-left: 6px;
    font-size: 0.85rem;
    opacity: 0.4;
    transition: opacity 0.35s ease;
  }

  th.sorted-asc .sort-arrow::before {
    content: '';
  }

  th.sorted-asc .sort-arrow {
    opacity: 1;
  }

  th.sorted-desc .sort-arrow {
    opacity: 1;
  }

  /* ===== SLOW SORT ANIMATION ===== */
  tbody tr {
    transition: transform 0.35s ease, opacity 0.35s ease;
  }

  tbody.sorting tr {
    opacity: 0.6;
  }
</style>

<!-- ================= BREADCRUMB / BODY ================= -->

<%- contentFor('breadcrumb') %>
<%- contentFor('body') %>

<!-- Initialize sorting immediately -->
<script>
  console.log('Script loading - before DOM ready');
  
  window.updateProjectDayCount = function() {
    console.log('updateProjectDayCount called');
    const fromInput = document.getElementById('from_date');
    const toInput = document.getElementById('to_date');
    const dayCountSpan = document.getElementById('dayCount');
    
    if (!fromInput || !toInput || !dayCountSpan) {
      console.log('Missing elements for day count');
      return;
    }
    
    const from = fromInput.value;
    const to = toInput.value;
    
    console.log('From:', from, 'To:', to);
    
    if (!from || !to) {
      dayCountSpan.textContent = '';
      return;
    }
    
    const diff = Math.abs(new Date(to) - new Date(from));
    const days = Math.ceil(diff / 86400000) + 1;
    dayCountSpan.textContent = '(' + days + ' day' + (days !== 1 ? 's' : '') + ')';
  };
  
  window.handleSortClick = function(e) {
    const th = e.currentTarget;
    console.log('Sort clicked:', th.textContent.trim());
    e.preventDefault();
    e.stopPropagation();
    
    const table = th.closest('table');
    const tbody = table.querySelector('tbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    const column = th.dataset.column;
    const columnIndex = Array.from(th.parentNode.children).indexOf(th);
    
    console.log('Column:', column, 'Index:', columnIndex, 'Rows:', rows.length);
    
    let isAsc = true;
    if (th.classList.contains('sorted-asc')) {
      isAsc = false;
    } else if (th.classList.contains('sorted-desc')) {
      isAsc = true;
    }
    
    console.log('Direction:', isAsc ? 'ASC' : 'DESC');
    
    document.querySelectorAll('th.sortable').forEach(h => {
      if(h !== th) {
        h.classList.remove('sorted-asc', 'sorted-desc');
        const icon = h.querySelector('.sort-arrow');
        if (icon) {
          icon.className = 'sort-arrow mdi mdi-sort-alphabetical-ascending';
        }
      }
    });
    
    th.classList.remove('sorted-asc', 'sorted-desc');
    th.classList.add(isAsc ? 'sorted-asc' : 'sorted-desc');
    
    const icon = th.querySelector('.sort-arrow');
    if (icon) {
      icon.className = isAsc ? 'sort-arrow mdi mdi-sort-alphabetical-ascending' : 'sort-arrow mdi mdi-sort-alphabetical-descending';
      console.log('Icon updated');
    }
    
    rows.sort((a, b) => {
      let aVal = a.children[columnIndex].innerText.trim();
      let bVal = b.children[columnIndex].innerText.trim();
      
      if (column.includes('date')) {
        aVal = new Date(aVal).getTime() || 0;
        bVal = new Date(bVal).getTime() || 0;
      } else if (column.includes('cost')) {
        aVal = parseFloat(aVal.replace(/[^0-9.-]+/g,"")) || 0;
        bVal = parseFloat(bVal.replace(/[^0-9.-]+/g,"")) || 0;
      }
      
      if (aVal < bVal) return isAsc ? -1 : 1;
      if (aVal > bVal) return isAsc ? 1 : -1;
      return 0;
    });
    
    console.log('Rows sorted, appending');
    rows.forEach(row => tbody.appendChild(row));
    console.log('Sort complete');
  };
  
  window.initDatepickers = function() {
    console.log('Initializing date inputs...');
    
    const fromInput = document.getElementById('from_date');
    const toInput = document.getElementById('to_date');
    
    console.log('from_date element:', fromInput);
    console.log('to_date element:', toInput);
    
    try {
      // Add change listeners for day count calculation
      if (fromInput) {
        fromInput.addEventListener('change', window.updateProjectDayCount);
        console.log('from_date listener added');
      }
      
      if (toInput) {
        toInput.addEventListener('change', window.updateProjectDayCount);
        console.log('to_date listener added');
      }
      
      console.log('Date pickers initialized successfully');
    } catch(e) {
      console.error('ERROR initializing datepickers:', e);
    }
  };
</script>

<div class="page-content-wrapper">
  <div class="container-fluid">

<!-- ACTION BUTTONS -->
