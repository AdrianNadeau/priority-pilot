<%- contentFor('HeaderCss') %>
<!-- Flatpickr CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<style>
  .sortable {
    cursor: pointer;
    position: relative;
    user-select: none;
    padding: 12px 8px !important;
    background-color: #f8f9fa;
    border-bottom: 2px solid #dee2e6 !important;
    font-weight: bold;
    color: #6c757d;
    vertical-align: middle;
  }
  .sortable:hover {
    background-color: #e9ecef !important;
    cursor: pointer;
  }
  .sort-arrow {
    min-width: 12px;
    color: #6c757d;
    transform: scale(1.1);
    cursor: pointer;
  }
  .sort-arrow.active {
    color: #007bff !important;
    cursor: pointer;
  }
  .table thead th {
    font-weight: 600;
    vertical-align: middle;
  }
</style>

<%- contentFor('breadcrumb') %>
<%- contentFor('body') %>
<div class="page-content-wrapper">
  <div class="container-fluid">
    
    <!-- Action Buttons -->
    <div class="row mt-2 mb-3" style="margin-left: 0px;margin-right:0px;">
      <div class="col-md-12">
        <button type="button" class="btn btn-primary waves-effect waves-light" data-toggle="modal" data-target="#addProject" id="btnAddProject" style="margin-right: 10px;">Add Project</button>
        <button
          type="button"
          class="btn btn-success waves-effect waves-light"
          id="btnPrintPage"
          name="btnPrintPage"
        >
          <i class="mdi mdi-download mr-1"></i> Download Report
        </button>
      </div>
    </div>
   
    <!-- Date Range Row -->
    <div class="row mb-2 align-items-center" style="margin-left: 0px;margin-right:0px;min-height: 50px;height:50px;background:hsl(197, 70%, 91%); box-shadow: 0 1px 2px rgba(0,0,0,0.04);">
      <div class="col-md-12 d-flex align-items-center">
        <span class="mdi mdi-calendar-check" style="font-size: 1.5rem; margin-right: 8px;"></span>
        <span style="font-weight: 500; margin-right: 12px;">Date Range: </span>
        <span class="text-muted" style="margin-right: 8px;">Start:</span>
        <input type="text" class="form-control datepicker" id="from_date" name="from_date" placeholder="From" style="width: 150px; margin-right: 10px;" value="<%= currentFromDate %>">
        <span style="font-weight: 500; margin-right: 8px;">End:</span>
        <input type="text" class="form-control datepicker" id="to_date" name="to_date" placeholder="To" style="width: 150px; margin-right: 10px;" value="<%= currentToDate %>">
        <button type="button" class="btn btn-primary btn-sm" style="margin-left: 10px;" id="updateBtn" onclick="filterDashboard()">Update</button>
        <span id="dayCount" style="margin-left: 15px; font-weight: 500; color: #495057;"></span>
      </div>
    </div>
    
   
    <div class="page-buttons">
      
    </div>

    <div class="row">
      <div class="col-lg-12">
        <div class="card-body" style="border:0px !important;">
          <% if (projects.length === 0) { %>
            <div class="alert alert-warning" role="alert">
              <strong>No projects found!</strong> Please <a href="#" id="openAddProjectModal">add one project</a> to get started.
            </div>
          <% } else { %>
            <div class="table-responsive">
              <table class="table mb-0">
                <thead>
                  <tr>
                    <th class="sortable" data-column="project_name" data-sort="default">Name <i class="sort-arrow fa fa-sort"></i></th>
                    <th class="sortable" data-column="prime_name" data-sort="default">Prime <i class="sort-arrow fa fa-sort"></i></th>
                    <th class="sortable" data-column="sponsor_name" data-sort="default">Sponsor <i class="sort-arrow fa fa-sort"></i></th>
                    <th class="sortable" data-column="start_date" data-sort="default">Start <i class="sort-arrow fa fa-sort"></i></th>
                    <th class="sortable" data-column="end_date" data-sort="default">End <i class="sort-arrow fa fa-sort"></i></th>
                    <th class="sortable" data-column="phase_name" data-sort="default">Phase <i class="sort-arrow fa fa-sort"></i></th>
                    <th class="sortable" data-column="project_cost" data-sort="default">Cost <i class="sort-arrow fa fa-sort"></i></th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% projects.forEach(function(project) { %>
                    <tr style="cursor: pointer;">
                      <td style="display: none;"><%= project.id %></td>
                      <td><%= project.project_name %></td>
                      <td><%= project.prime_last_name ? `${project.prime_last_name}, ${project.prime_first_name}` : "N/A" %></td>
                      <td><%= project.sponsor_last_name ? `${project.sponsor_last_name}, ${project.sponsor_first_name}` : "N/A" %></td>
                      <td><%= project.start_date ? new Date(project.start_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : "" %></td>
                      <td><%= project.end_date ? new Date(project.end_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : "" %></td>
                      <td><%= project.phase_name %></td>
                      <td>$<%= project.project_cost %></td>
                      <td>
                        <% if (project.can_update_status) { %>
                          <i data-toggle="modal" data-target="#myModal_<%= project.id %>" style="cursor:pointer;color:#34b871 !important;" class="mdi mdi-note-plus"></i>
                        <% } %>
                        <% if (project.can_view) { %>
                          <i data-toggle="modal" data-target="#StatusUpdatesModal" class="mdi mdi-eye js-status-eye" data-project-id="<%= project.id %>" style="cursor:pointer;color:#34b871 !important;"></i>
                        <% } %>
                      </td>
                    </tr>
                    <!-- Status Modal for each project ... -->
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Status Updates Modal -->
<div id="StatusUpdatesModal" class="modal fade" href="#" tabindex="-1" role="dialog" aria-labelledby="StatusUpdatesModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="StatusUpdatesModalLabel"><strong>Status Updates</strong></h5>
        <button type="button" class="close" data-dismiss="modal">×</button>
      </div>
      <div class="modal-body" id="statusUpdates">
        <!-- dynamic status -->
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- View Status Modal -->
