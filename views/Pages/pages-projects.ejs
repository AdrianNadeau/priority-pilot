              <div class="form-group">
                <strong>Accomplishments:</strong>
                <textarea class="form-control" maxlength="3000" name="status_accomplishments" id="accomplishments_<%= project.id %>" required rows="3" placeholder="Enter accomplishments..."></textarea>
                <div class="invalid-feedback">
                  Please enter accomplishments.
                </div>
              </div>
              <div class="form-group">
                <strong>Issues:</strong>
                <textarea class="form-control" maxlength="3000" name="issue" id="issue_<%= project.id %>" rows="3" required placeholder="Enter issues..."></textarea>
                <div class="invalid-feedback">
                  Please enter issues.
                </div>
              </div>
              <div class="form-group">
                <strong>Actions:</strong>
                <textarea class="form-control" maxlength="3000" name="actions" id="actions_<%= project.id %>" rows="3" required placeholder="Enter actions..."></textarea>
                <div class="invalid-feedback">
                  Please enter actions.
                </div>
              </div>
              
              <div class="d-flex align-items-center gap-2">
