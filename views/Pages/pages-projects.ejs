            </div>
            <div class="form-group">
              <label for="status_progress"><strong>Progress</strong></label>
              <input type="text" id="view_status_progress" class="form-control" disabled>
            </div>
            <div class="form-group">
              <label for="status_health"><strong>Health</strong></label>
