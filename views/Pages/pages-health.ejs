<!-- Flatpickr JS -->
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
// Initialize Flatpickr for date inputs
flatpickr(".datepicker", {
 dateFormat: "Y-m-d", // Format the date as YYYY-MM-DD
      allowInput: true, // Allow manual input if needed
      allowInvalidPreload: true, // Allow invalid dates to be preloaded
});

// Filter functionality
function filterHealth() {
    const startDate = document.getElementById('from_date').value;
    const endDate = document.getElementById('to_date').value;
    
    // Build the query parameters
    const params = new URLSearchParams();
    if (startDate) params.append('from_date', startDate);
    if (endDate) params.append('to_date', endDate);
    
    // Show loading state
    const container = document.getElementById('healthTableContainer');
    container.innerHTML = '<div class="text-center"><div class="spinner-border" role="status"><span class="sr-only">Loading...</span></div></div>';
    
    // Make AJAX request to get filtered data
    fetch(`/projects/health/data?${params.toString()}`)
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                updateHealthTable(data.projects);
            } else {
                console.error('Error:', data.error);
                // Fallback: reload the page with filter parameters
                window.location.href = `/projects/health?${params.toString()}`;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            // Fallback: reload the page with filter parameters
            window.location.href = `/projects/health?${params.toString()}`;
        });
}

function updateHealthTable(projects) {
    const container = document.getElementById('healthTableContainer');
    
    if (!projects || projects.length === 0) {
        container.innerHTML = '<div class="alert alert-danger">No projects found for the selected date range.</div>';
        return;
    }
    
    let tableHTML = `
        <div class="table-responsive">
            <table class="table mb-12">
                <tbody>
                    <tr>
                        <th>Project</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>NMS</th>
                        <th>Status</th>
                        <th>Prime</th>
                        <th>Sponsor</th>
                        <th>Issues</th>
                        <th>Actions</th>
                        <th>Progress</th>
                    </tr>`;
    
    let currentPhase = '';
    
    projects.forEach(project => {
        if (project.phase_name === 'Planning' || project.phase_name === 'Discovery' || project.phase_name === 'Delivery') {
            if (project.phase_name !== currentPhase) {
                currentPhase = project.phase_name;
                tableHTML += `
                    <tr>
                        <td colspan="12" style="background-color:#ececec;font-weight: bold; text-align: center;">${currentPhase}</td>
                    </tr>`;
            }
            
            let backgroundColor = 'gray'; // default gray
            if (project.last_status && project.last_status.health) {
                let health = project.last_status.health.toLowerCase().trim();
                if (health === 'yellow') backgroundColor = 'yellow';
                else if (health === 'green') backgroundColor = 'green';
                else if (health === 'red') backgroundColor = 'red';
                else if (health === '#000') backgroundColor = 'red';
            }
            
            // Format dates
            const formatDate = (dateStr) => {
                if (!dateStr) return '';
                return new Date(dateStr).toLocaleDateString('en-US', { 
                    month: 'short', 
                    day: 'numeric', 
                    year: 'numeric' 
                });
            };
            
            tableHTML += `
                <tr>
                    <td style="background-color:${backgroundColor};color:black;font-weight: bold;min-width: 250px;">
                        ${project.project_name}&nbsp;<a href="/projects/edit/${project.project_id}"><i class="mdi mdi-border-color"></i></a>
                    </td>
                    <td>${formatDate(project.start_date)}</td>
                    <td>${formatDate(project.end_date)}</td>
                    <td>${formatDate(project.next_milestone_date)}</td>
                    <td>${project.last_status && project.last_status.health ? project.last_status.health : "N/A"}</td>
                    <td>${project.prime_first_name || ''} ${project.prime_last_name || ''}</td>
                    <td>${project.sponsor_first_name || ''} ${project.sponsor_last_name || ''}</td>
                    <td>${project.last_status ? project.last_status.issue || '' : ''}</td>
                    <td>${project.last_status ? project.last_status.actions || '' : ''}</td>
                    <td>${project.last_status ? (project.last_status.progress || '') + ' %' : ''}</td>
                </tr>`;
        }
    });
    
    tableHTML += `
                </tbody>
            </table>
        </div>`;
    
    container.innerHTML = tableHTML;
}

function clearHealthFilter() {
    document.getElementById('from_date').value = '';
    document.getElementById('to_date').value = '';
    
    // Reload page without filter parameters
    window.location.href = '/projects/health/view';
}

// CSV Export functionality
document.getElementById("btnExportCSV").addEventListener("click", function () {
  window.location.href = "/projects/export/health-data";
});

// Print/PDF functionality
document.getElementById("btnPrintPage").addEventListener("click", function () {
  // Get portfolio name from session data or set a default
  const portfolioName = "<%= portfolioName %>" || "Priority Pilot";

  // Create a style element for the print header
  const style = document.createElement("style");
  style.setAttribute("type", "text/css");
  style.setAttribute("media", "print");

  // Add CSS for the print header
  const css = `
    @page {
      size: landscape;
      margin-top: 3cm;
    }
    body::before {
      content: "${portfolioName} - Health Report";
      display: block;
      text-align: center;
      font-weight: bold;
      font-size: 1.5em;
      margin-bottom: 1cm;
    }
    #btnPrintPage,
    #btnExportCSV,
    .page-buttons,
    .button-menu-mobile,
    .page-title,
    .portfolio-title,
    .card:has(#start_date),
    .mb-3 {
      display: none !important;
    }
    td, th, tr, .table, .mini-stat, .card-body {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }
  `;

  style.appendChild(document.createTextNode(css));
  document.head.appendChild(style);

  // Save the current title
  const oldTitle = document.title;
  const today = new Date();
  const yyyy_mm_dd = today.toISOString().split('T')[0];
  
  document.title = yyyy_mm_dd + " - PriorityPilot - Health Report";

  // Print
  window.print();

  // Restore the old title after a short delay
  setTimeout(() => {
    document.title = oldTitle;
    // Remove the added style element
    document.head.removeChild(style);
  }, 1000);
});
</script>
