<%- contentFor('BottomJs') %>
<script>
  // Date filtering functions - Updated to use global filter system
  function filterRadar() {
    const fromDateElement = document.getElementById("from_date");
    const toDateElement = document.getElementById("to_date");
    const fromDate = fromDateElement ? fromDateElement.value : "";
    const toDate = toDateElement ? toDateElement.value : "";

    // Send filter data to server to save in persons table (same as dashboard)
    fetch('/update-filter', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        from_date: fromDate,
        to_date: toDate
      })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        console.log('Filter preferences saved successfully to persons table');
        // Reload the page to apply session-based filtering
        window.location.reload();
      } else {
        console.error('Error saving filter preferences:', data.error);
        alert('Error saving filter preferences. Please try again.');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Error saving filter preferences. Please try again.');
    });
  }

  function updateChartsWithFilteredData(data) {
    // Filter out any Planning phases from the incoming data
    if (data.phaseStats) {
      data.phaseStats = data.phaseStats.filter(p => 
        p.phaseName !== 'Planning' && !p.phaseName.toLowerCase().includes('planning')
      );
    }
    
    // Update global phaseStats variable
    window.phaseStats = data.phaseStats;

    // Redraw all charts with new data
    drawProjectsByPhaseChart();
    drawCostByPhaseChart();
    drawProgressAndHealthCharts(); // Add progress and health charts
    updatePortfolioHealthChart(data.portfolioHealth);
    drawTagCharts(); // Now will use the date parameters in API calls
  }
  function updatePortfolioHealthChart(portfolioHealthData) {
    const { labels, counts, colors } = portfolioHealthData;
    const customLabels = ["Healthy", "Caution", "In Trouble"];

    const total = counts.reduce((sum, count) => sum + count, 0);
    const percentages = counts.map((count) =>
      total > 0 ? Math.round((count / total) * 100) : 0,
    );

    const chartDataArray = [
      ["Status", "Count", { role: "tooltip", p: { html: false } }],
    ];
    labels.forEach((label, i) => {
      chartDataArray.push([
        customLabels[i],
        { v: counts[i], f: percentages[i] + "%" },
        `${customLabels[i]}\n${counts[i]} (${percentages[i]}%)`,
      ]);
    });

    const data = google.visualization.arrayToDataTable(chartDataArray);
    const options = {
      // title: "Portfolio Health3",
      //   titleTextStyle: {
      //   fontSize: 20,
      //   bold: true,
         
      // },
      pieHole: 0.4,
      backgroundColor: "transparent",
      width: 600,
      height: 350,
      colors: colors,
      legend: {
        position: "right",
        textStyle: { color: "#333", fontSize: 14, alignment: 'center', },
      },
      pieSliceText: "value",
      tooltip: { isHtml: false },
    };

    const pieChart = new google.visualization.PieChart(
      document.getElementById("pieChart"),
    );
    pieChart.draw(data, options);
  }

  function clearFilters() {
    // Clear the input fields
    const fromDateElement = document.getElementById("from_date");
    const toDateElement = document.getElementById("to_date");

    if (fromDateElement) fromDateElement.value = "";
    if (toDateElement) toDateElement.value = "";

    // Send empty filter data to server to clear saved preferences
    fetch('/update-filter', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        from_date: '',
        to_date: ''
      })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        console.log('Filter preferences cleared successfully');
        // Redirect to refresh the page without filters
        window.location.href = '/projects/radar/view/';
      } else {
        console.error('Error clearing filter preferences:', data.error);
        alert('Error clearing filter preferences. Please try again.');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Error clearing filter preferences. Please try again.');
    });
  }

  // Initialize Flatpickr for date inputs
  document.addEventListener("DOMContentLoaded", function () {
    // Get session values for date pickers
    var currentFromDate = '<%= currentFromDate || "" %>';
    var currentToDate = '<%= currentToDate || "" %>';

    function isValidDateString(dateStr) {
      // Accepts YYYY-MM-DD only
      return /^\d{4}-\d{2}-\d{2}$/.test(dateStr);
    }

    var fromPicker = flatpickr("#from_date", {
      dateFormat: "Y-m-d",
      allowInput: true,
      allowInvalidPreload: true
    });
    var toPicker = flatpickr("#to_date", {
      dateFormat: "Y-m-d",
      allowInput: true,
      allowInvalidPreload: true
    });

    // Force Flatpickr and input to session value after initialization
    if (isValidDateString(currentFromDate)) {
      fromPicker.setDate(currentFromDate, true);
    }
    if (isValidDateString(currentToDate)) {
      toPicker.setDate(currentToDate, true);
    }
  });
</script>

<script type="text/javascript">
      document.addEventListener("DOMContentLoaded", function() {
