    <script>
     // Print button event listener - ensure DOM is fully loaded
     console.log('Setting up window load listener for print button');
     window.addEventListener('load', function() {
       console.log('Window loaded, searching for print button');
       const btnPrintPage = document.getElementById("btnPrintPage");
       console.log('Print button element:', btnPrintPage);
       if (btnPrintPage) {
         console.log('Print button found, attaching event listener');
         btnPrintPage.addEventListener("click", function () {
           console.log('===== Print button clicked =====');
           // Get portfolio name from session data or set a default
           const portfolioName = "<%= portfolioName %>" || "Priority Pilot";
           console.log('Portfolio name:', portfolioName);

    // Create a style element for the print header
    console.log('Creating print style element');
    const style = document.createElement("style");
    style.setAttribute("type", "text/css");
    style.setAttribute("media", "print");
    console.log('Print style element created');    // Add CSS for the print header
    const css = `
      @page {
        size: landscape;
        margin-top: 3cm;
      }
      body::before {
        content: "${portfolioName} - Radar Report";
        display: block;
        text-align: center;
        font-weight: bold;
        font-size: 1.5em;
        margin-bottom: 1cm;
      }
      #btnPrintPage,
      .page-buttons,
      .button-menu-mobile,
      .page-title,
      .portfolio-title {
        display: none !important;
      }
      .filter-section,
      .mini-stat {
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
      }
    `;

    style.appendChild(document.createTextNode(css));
    document.head.appendChild(style);
    console.log('Print style added to document head');

    // Save the current title
    const oldTitle = document.title;
    const today = new Date();
    const yyyy_mm_dd = today.toISOString().split('T')[0];
    console.log('Current title:', oldTitle);
    console.log('New title will be:', yyyy_mm_dd + " - PriorityPilot - Radar Report");

    document.title = yyyy_mm_dd + " - PriorityPilot - Radar Report";
    console.log('Title updated, opening print dialog...');

    // Print
    window.print();
    console.log('Print dialog opened');

    // Restore the old title after a short delay
    setTimeout(() => {
      console.log('Restoring original title');
      document.title = oldTitle;
      // Remove the added style element
      document.head.removeChild(style);
      console.log('Print style removed, title restored');
    }, 1000);
         });
       } else {
         console.error('Print button not found in DOM');
       }
     });
  </script>
