              minValue: 0,
              format: '$#,###',
              gridlines: { color: '#eee' }
            },
            legend: {
              position: 'bottom',
              maxLines: 1,
              textStyle: { fontSize: 12 }
            },
            annotations: {
              alwaysOutside: false,
