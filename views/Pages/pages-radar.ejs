              title: 'Progress %',
              minValue: 0,
              maxValue: 100,
              format: '#\'%\'',
              gridlines: { color: '#eee' }
            },
            legend: {
              position: 'bottom',
              textStyle: { fontSize: 10 }
            },
            colors: ['#28a745', '#ffc107', '#dc3545'] // Green, Yellow, Red (removed gray for No Status)
          };

          const chart = new google.visualization.ColumnChart(
            document.getElementById('progressChart')
          );
          chart.draw(chartDataTable, options);
        }

        function drawHealthStatusChart(data) {
          if (!data || !data.project_names || data.project_names.length === 0) {
            document.getElementById("healthStatusChart").innerHTML = '<p>No health data available</p>';
            return;
          }

          // Count health statuses (excluding No Status)
          const healthCounts = { 'Green': 0, 'Yellow': 0, 'Red': 0 };

          data.colors.forEach(health => {
            if (health === 'green' || health === 'Green') {
              healthCounts['Green']++;
            } else if (health === 'yellow' || health === 'Yellow') {
              healthCounts['Yellow']++;
            } else if (health === 'red' || health === 'Red') {
              healthCounts['Red']++;
            }
            // Skip "No Status" entries - don't count them
          });

          const chartData = [["Health Status", "Count"]];
          Object.entries(healthCounts).forEach(([status, count]) => {
            if (count > 0) {
              chartData.push([status, count]);
