        // Global tag color mapping to ensure consistency across all charts
        const globalTagColors = new Map();

        function getTagColor(tagName, tagColor) {
          if (!globalTagColors.has(tagName)) {
            globalTagColors.set(tagName, tagColor || '#6c757d');
          }
          return globalTagColors.get(tagName);
        }

        // Convert colors array into Google Charts 'slices' option to assign per-slice colors
        function colorsToSlices(colors) {
          const slices = {};
          colors.forEach((c, i) => {
            slices[i] = { color: c };
          });
          return slices;
        }

        function parseFormattedCost(cost) {
          if (typeof cost === "string") {
            if (cost.endsWith("K")) {
              return parseFloat(cost.replace("K", "")) * 1000;
            } else if (cost.endsWith("M")) {
              return parseFloat(cost.replace("M", "")) * 1000000;
            }
          }
          return parseFloat(cost);
        }

        // Diagnostic logging for chart rendering
        console.log('Radar page: phaseStats from server: ' + '<%= JSON.stringify(Array.isArray(phaseStats) ? phaseStats : []) %>');
        google.charts.load('current', { packages: ['corechart'] });
        google.charts.setOnLoadCallback(function() {
          console.log('Google Charts loaded, drawing charts...');
          drawCharts();
        });

        function drawCharts() {
          // Draw all charts
          drawProjectsByPhaseChart();
          drawCostByPhaseChart();
          drawProgressAndHealthCharts();
          drawTagCharts();
        }

        // Make phaseStats a global variable and include Planning phases
        // Make phaseStats a global variable (no filter)
        window.phaseStats = JSON.parse('<%= JSON.stringify(Array.isArray(phaseStats) ? phaseStats : []) %>');

        function drawProjectsByPhaseChart() {
          // Defensive: ensure window.phaseStats is an array
          const stats = Array.isArray(window.phaseStats) ? window.phaseStats : [];
          const phases          = stats.map(p => p.phaseName);
          const troubleCounts   = stats.map(p => p.troubleCount);
          const cautionCounts   = stats.map(p => p.cautionCount);
          const healthyCounts   = stats.map(p => p.healthyCount);
          const noStatusCounts  = stats.map(p => p.noStatusCount);

          // Build annotations only for non‐zero values
          const ann = arr => arr.map(c => c > 0 ? String(c) : '');

          // Prepare DataTable rows
          const dataArray = [
            [
              'Phase',
              'Trouble',
              'Caution',
              'Healthy',
              'No Status'
            ]
          ];
          phases.forEach((phase, i) => {
            dataArray.push([
              phase,
              Number(troubleCounts[i]),
              Number(cautionCounts[i]),
              Number(healthyCounts[i]),
              Number(noStatusCounts[i])
            ]);
          });

          // Draw with Google Charts
          const data = google.visualization.arrayToDataTable(dataArray);
          const options = {
            // title: 'Initiatives by Phase',
            isStacked: true,
            width: 650,
            height: 300,
            chartArea: { left:60, top:60, width:'75%', height:'65%' },
            colors: ['#dc3545','#ffc107','#28a745','#42a5f5'],
            vAxis: {
              minValue: 0,
              gridlines: { color:'#eee' },
              textStyle: { fontSize: 12 }
            },
            legend: {
              position: 'bottom',
              maxLines: 1,
              textStyle: { fontSize: 12 }
            },
            annotations: {
              alwaysOutside: false,
              textStyle: {
                fontSize: 14,
                color: '#fff',
                bold: true,
                auraColor: 'none'
              },
              highContrast: false
            },
            backgroundColor: 'transparent'
          };
          const chartContainer = document.getElementById('columnchart_values');
          if (phases.length === 0 || (troubleCounts.every(c => c === 0) && cautionCounts.every(c => c === 0) && healthyCounts.every(c => c === 0) && noStatusCounts.every(c => c === 0))) {
            chartContainer.innerHTML = '<p style="color:#dc3545;font-weight:bold;">No data available for Initiatives by Phase</p>';
            return;
          }
          const chart = new google.visualization.ColumnChart(chartContainer);
          chart.draw(data, options);
        }

        function drawCostByPhaseChart() {
          // Defensive: ensure window.phaseStats is an array
          const stats = Array.isArray(window.phaseStats) ? window.phaseStats : [];
          const phases         = stats.map(p => p.phaseName);
          const troubleCosts   = stats.map(p => p.troubleCost);
          const cautionCosts   = stats.map(p => p.cautionCost);
          const healthyCosts   = stats.map(p => p.healthyCost);
          const noStatusCosts  = stats.map(p => p.noStatusCost);

          // Formatter: only show annotation if cost > 0, add commas & dollar sign
          const fmt = n => {
            if (n <= 0) return '';
            return '$' + n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
          };
          const troubleAnn   = troubleCosts.map(fmt);
          const cautionAnn   = cautionCosts.map(fmt);
          const healthyAnn   = healthyCosts.map(fmt);
          const noStatusAnn  = noStatusCosts.map(fmt);

          // Build the DataTable rows
          const dataArray = [
            [
              'Phase',
              'Trouble',   { type: 'string', role: 'annotation' },
              'Caution',   { type: 'string', role: 'annotation' },
              'Healthy',   { type: 'string', role: 'annotation' },
              'No Status', { type: 'string', role: 'annotation' }
            ]
          ];
          phases.forEach((phase, i) => {
            dataArray.push([
              phase,
              troubleCosts[i],  troubleAnn[i],
              cautionCosts[i],  cautionAnn[i],
              healthyCosts[i],  healthyAnn[i],
              noStatusCosts[i], noStatusAnn[i]
            ]);
          });

          // Convert to a Google DataTable
          const data = google.visualization.arrayToDataTable(dataArray);

          // Chart options – stacked, currency axis, white annotations, one‐row legend
          const options = {
            // title: 'Investment by Phase',
            isStacked: true,
            width: 650,
            height: 300,
            chartArea: { left:80, top:60, width:'75%', height:'65%' },
            colors: ['#dc3545','#ffc107','#28a745','#42a5f5'],
