<%- contentFor('HeaderCss') %>
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
/>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<style>
  /* Ensure filter section is visible */
  .page-content-wrapper .row:first-child {
    display: block !important;
  }
</style>

<%- contentFor('body') %>

<style>
    @media print {
    /* Hide buttons and other unnecessary elements */
    #btnPrintPage,
    #btnExportHealth,
    .page-title,
    .portfolio-title,
    .button-menu-mobile {
      display: none;
    }

    /* Ensure the table and charts fit within the page */
    .table-responsive {
      overflow: visible !important;
    }

    .page-content-wrapper {
      margin: 0;
      padding: 0;
    }

    /* Adjust font sizes for better readability */
    body {
      font-size: 12px;
    }
  }
</style>
<div class="page-content-wrapper">
  <div class="container-fluid">

    <!-- Download Report Button -->
    <div class="row mt-2 mb-3" style="margin-left: 0px;margin-right:0px;">
      <div class="col-md-12">
        <button
          type="button"
          class="btn btn-success waves-effect waves-light"
          id="btnPrintPage"
          name="btnPrintPage"
        >
          <i class="mdi mdi-download mr-1"></i> Download Report
        </button>
      </div>
    </div>
   
    <!-- Date Range Row -->
    <div class="row mb-2 align-items-center" style="margin-left: 0px;margin-right:0px;min-height: 50px;height:50px;background:hsl(197, 70%, 91%); box-shadow: 0 1px 2px rgba(0,0,0,0.04);">
      <div class="col-md-12 d-flex align-items-center">
        <span class="mdi mdi-calendar-check" style="font-size: 1.5rem; margin-right: 8px;"></span>
        <span style="font-weight: 500; margin-right: 12px;">Date Range: </span>
        <span class="text-muted" style="margin-right: 8px;">Start:</span>
        <input type="text" class="form-control flatpickr-input active" id="from_date" name="from_date" placeholder="YYYY-MM-DD" style="width: 150px; margin-right: 10px;" value="<%= currentFromDate %>">
        <span style="font-weight: 500; margin-right: 8px;">End:</span>
        <input type="text" class="form-control flatpickr-input active" id="to_date" name="to_date" placeholder="YYYY-MM-DD" style="width: 150px; margin-right: 10px;" value="<%= currentToDate %>">
        <button type="button" class="btn btn-primary btn-sm" style="margin-left: 10px;" id="updateBtn" onclick="filterDashboard()">Update</button>
        <span id="dayCount" style="margin-left: 15px; font-weight: 500; color: #495057;"></span>
      </div>
    </div>
    
    <script>
     
      // Calculate and display day count - make it globally available
      window.updateDayCount = function() {
        const from = document.getElementById('from_date') ? document.getElementById('from_date').value : '';
        const to = document.getElementById('to_date') ? document.getElementById('to_date').value : '';
        const dayCountSpan = document.getElementById('dayCount');
      
        
        if (!dayCountSpan) {
          console.error('dayCount span not found!');
          return;
        }
        
        if (from && to) {
          const fromDate = new Date(from);
          const toDate = new Date(to);
          
          if (!isNaN(fromDate.getTime()) && !isNaN(toDate.getTime())) {
            const diffTime = Math.abs(toDate - fromDate);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1; // +1 to include both start and end dates
            const dayText = `(${diffDays} day${diffDays !== 1 ? 's' : ''})`;
            dayCountSpan.textContent = dayText;
            
          } else {
            dayCountSpan.textContent = '';
            console.log('Invalid date format');
          }
        } else {
          dayCountSpan.textContent = '';
          console.log('Missing date(s) - from:', from, 'to:', to);
        }
      };

      // Wait for DOM to be fully loaded
      document.addEventListener('DOMContentLoaded', function() {
        // Initialize Flatpickr for date inputs
        flatpickr('#from_date', { dateFormat: 'Y-m-d', onChange: updateDayCount });
        flatpickr('#to_date', { dateFormat: 'Y-m-d', onChange: updateDayCount });
        
        // Update day count immediately
        updateDayCount();
      });
    </script>
    
    <script>
      // Filter function - needs to be available for onclick handler
      function filterDashboard() {
        const fromDate = document.getElementById('from_date').value;
        const toDate = document.getElementById('to_date').value;
        
        console.log('Filter clicked with dates:', fromDate, toDate);
        
        // Send filter data to server to save in persons table
        fetch('/update-filter', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            from_date: fromDate,
            to_date: toDate
          })
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            console.log('Filter preferences saved successfully');
            // Reload the page to apply session-based filtering
            window.location.reload();
          } else {
            console.error('Error saving filter preferences:', data.message);
            // Still reload to try to apply filters
            window.location.reload();
          }
        })
        .catch(error => {
          console.error('Error:', error);
          // Fallback: reload page
          window.location.reload();
        });
      }
    </script>
    
