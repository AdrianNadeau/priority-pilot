<style>
  /* Ensure filter section is visible */
  .page-content-wrapper .row:first-child {
    display: block !important;
    visibility: visible !important;
  }

  .mini-stat.bg-white.clearfix {
    background-color: #ffffff !important;
    border: 1px solid #dee2e6 !important;
    padding: 15px !important;
    margin-bottom: 15px !important;
  }

  .dashboard-container {
    width: 75%;
    margin: 0 auto; /* Center the container */
  }
  .chart-container {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
  }
  .chart {
    flex: 1;
    margin: 10px;
  }
  /* Add hover-over pointer effect for pie charts */
  #pieChart,
  #tag1Chart,
  #tag2Chart,
  #tag3Chart {
    cursor: pointer;
  }
  @media print {
    /* Hide buttons and other unnecessary elements */
    #btnPrintPage,
    #btnExportHealth,
    .page-title,
    .portfolio-title,
    .button-menu-mobile {
      display: none;
    }

    /* Ensure the table and charts fit within the page */
    .table-responsive {
      overflow: visible !important;
    }

    .page-content-wrapper {
      margin: 0;
      padding: 0;
    }

    /* Adjust font sizes for better readability */
    body {
      font-size: 12px;
    }
  }
</style>

