              document.getElementById('tag1NoTags').innerText = 'No data found for tag 1';
              return;
            }
            
            var chartData = [['Tag', 'Count']];
            var colors = [];
            tagsData.forEach(function(tag) {
              if (tag.tag_name && tag.project_count > 0) {
                chartData.push([tag.tag_name, parseInt(tag.project_count)]);
                colors.push(tag.tag_color || '#6c757d');
              }
            });
            
            var data = google.visualization.arrayToDataTable(chartData);
            var slices = {};
            colors.forEach(function(c, i) { slices[i] = { color: c }; });
            
            var options = {
              pieHole: 0.4,
              backgroundColor: 'transparent',
