        // Global tag color mapping to ensure consistency across all charts
        const globalTagColors = new Map();

        function getTagColor(tagName, tagColor) {
          if (!globalTagColors.has(tagName)) {
            globalTagColors.set(tagName, tagColor || '#6c757d');
          }
          return globalTagColors.get(tagName);
        }

        // Convert colors array into Google Charts 'slices' option to assign per-slice colors
        function colorsToSlices(colors) {
          const slices = {};
          colors.forEach((c, i) => {
            slices[i] = { color: c };
          });
          return slices;
        }

        function parseFormattedCost(cost) {
          if (typeof cost === "string") {
            if (cost.endsWith("K")) {
              return parseFloat(cost.replace("K", "")) * 1000;
            } else if (cost.endsWith("M")) {
              return parseFloat(cost.replace("M", "")) * 1000000;
            }
          }
          return parseFloat(cost);
