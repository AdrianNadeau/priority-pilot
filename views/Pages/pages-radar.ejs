        function drawProgressChart(data) {
          if (!data || !data.project_names || data.project_names.length === 0) {
            document.getElementById("progressChart").innerHTML = '<p>No progress data available</p>';
            return;
          }

          // Create separate series for each health status to enable different colors (excluding No Status)
          const chartData = [["Project", "Green", "Yellow", "Red"]];

          data.project_names.forEach((projectName, index) => {
            const progress = data.progress[index] || 0;
            const progressValue = typeof progress === 'number' ? progress :
                                  (typeof progress === 'string' && progress !== 'No status available') ?
                                  parseFloat(progress) : 0;

            const health = data.colors[index] || 'No status available';

            // Skip projects with no status - don't include them in the chart
            if (!health || health === 'No status available' || health === '' || health === null) {
              return; // Skip this project
            }

            // Initialize row with zeros for all health statuses
            const row = [projectName, 0, 0, 0];

            // Set the progress value only for the appropriate health status column
            if (health === 'green' || health === 'Green') {
              row[1] = progressValue; // Green column
            } else if (health === 'yellow' || health === 'Yellow') {
              row[2] = progressValue; // Yellow column
            } else if (health === 'red' || health === 'Red') {
              row[3] = progressValue; // Red column
            }
            // No longer handling "No Status" cases

            chartData.push(row);
          });

          const chartDataTable = google.visualization.arrayToDataTable(chartData);

          const options = {
            // title: 'Project Progress',
            backgroundColor: 'transparent',
            width: 650,
            height: 400,
            chartArea: { left: 80, top: 60, width: '75%', height: '70%' },
