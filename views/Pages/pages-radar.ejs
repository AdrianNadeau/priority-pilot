            document.getElementById('columnChartCost_values')
          );
          chart.draw(data, options);
        }

        function drawProgressAndHealthCharts() {
          // Fetch progress data - no need for query parameters since we use session-based filtering
          fetch(`/projects/radar/progress/`)
            .then((response) => response.json())
            .then((data) => {
              drawProgressChart(data);
              drawHealthStatusChart(data);
            })
            .catch((err) => console.error("Error loading Progress/Health data:", err));
