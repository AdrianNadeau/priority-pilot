<%- contentFor('BottomJs') %>
<script>
  // Date filtering functions - Updated to use global filter system
  function filterRadar() {
    const fromDateElement = document.getElementById("from_date");
    const toDateElement = document.getElementById("to_date");
    const fromDate = fromDateElement ? fromDateElement.value : "";
    const toDate = toDateElement ? toDateElement.value : "";

    // Send filter data to server to save in persons table (same as dashboard)
    fetch('/update-filter', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        from_date: fromDate,
        to_date: toDate,
        next_milestone_date_details: null
      })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        console.log('Filter preferences saved successfully to persons table');
        // Redirect to refresh the page with updated filter values from database
        window.location.href = '/projects/radar/view/';
      } else {
        console.error('Error saving filter preferences:', data.error);
        alert('Error saving filter preferences. Please try again.');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Error saving filter preferences. Please try again.');
    });
  }

  function updateChartsWithFilteredData(data) {
    // Update global phaseStats variable
    window.phaseStats = data.phaseStats;

    // Redraw all charts with new data
    drawProjectsByPhaseChart();
    drawCostByPhaseChart();
    drawProgressAndHealthCharts(); // Add progress and health charts
    updatePortfolioHealthChart(data.portfolioHealth);
    drawTagCharts(); // Now will use the date parameters in API calls
  }
  function updatePortfolioHealthChart(portfolioHealthData) {
    const { labels, counts, colors } = portfolioHealthData;
    const customLabels = ["Healthy", "Caution", "In Trouble"];

    const total = counts.reduce((sum, count) => sum + count, 0);
    const percentages = counts.map((count) =>
      total > 0 ? Math.round((count / total) * 100) : 0,
    );

    const chartDataArray = [
      ["Status", "Count", { role: "tooltip", p: { html: false } }],
    ];
    labels.forEach((label, i) => {
      chartDataArray.push([
        customLabels[i],
        { v: counts[i], f: percentages[i] + "%" },
        `${customLabels[i]}\n${counts[i]} (${percentages[i]}%)`,
      ]);
    });

    const data = google.visualization.arrayToDataTable(chartDataArray);
    const options = {
      title: "Portfolio Health",
      pieHole: 0.4,
      backgroundColor: "transparent",
      width: 600,
      height: 350,
      colors: colors,
      legend: {
        position: "right",
        textStyle: { color: "#333", fontSize: 14 },
      },
      pieSliceText: "value",
      tooltip: { isHtml: false },
    };

    const pieChart = new google.visualization.PieChart(
      document.getElementById("pieChart"),
    );
    pieChart.draw(data, options);
  }

  function clearFilters() {
    // Clear the input fields
    const fromDateElement = document.getElementById("from_date");
    const toDateElement = document.getElementById("to_date");

    if (fromDateElement) fromDateElement.value = "";
    if (toDateElement) toDateElement.value = "";

    // Send empty filter data to server to clear saved preferences
    fetch('/update-filter', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        from_date: '',
        to_date: '',
        next_milestone_date_details: null
      })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        console.log('Filter preferences cleared successfully');
        // Redirect to refresh the page without filters
        window.location.href = '/projects/radar/view/';
      } else {
        console.error('Error clearing filter preferences:', data.error);
        alert('Error clearing filter preferences. Please try again.');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Error clearing filter preferences. Please try again.');
    });
  }

  // Initialize Flatpickr for date inputs
  document.addEventListener("DOMContentLoaded", function () {
    flatpickr(".datepicker", {
      dateFormat: "Y-m-d", // Format the date as YYYY-MM-DD
      allowInput: true, // Allow manual input if needed
      allowInvalidPreload: true, // Allow invalid dates to be preloaded
    });
  });
</script>

<script type="text/javascript">
      document.addEventListener("DOMContentLoaded", function() {
        // const portfolioTitle = document.getElementById("portfolioTitle");
        // if (portfolioTitle) {
        //   portfolioTitle.textContent = portfolioTitle;
        // } else {
        //   console.error("Portfolio title element not found!");
        // }

        // Global tag color mapping to ensure consistency across all charts
        const globalTagColors = new Map();

        function getTagColor(tagName, tagColor) {
          if (!globalTagColors.has(tagName)) {
            globalTagColors.set(tagName, tagColor || '#6c757d');
          }
          return globalTagColors.get(tagName);
        }

        // Convert colors array into Google Charts 'slices' option to assign per-slice colors
        function colorsToSlices(colors) {
          const slices = {};
          colors.forEach((c, i) => {
            slices[i] = { color: c };
          });
          return slices;
        }

        function parseFormattedCost(cost) {
          if (typeof cost === "string") {
            if (cost.endsWith("K")) {
              return parseFloat(cost.replace("K", "")) * 1000;
            } else if (cost.endsWith("M")) {
              return parseFloat(cost.replace("M", "")) * 1000000;
            }
          }
          return parseFloat(cost);
        }

        google.charts.load('current', { packages: ['corechart'] });
        google.charts.setOnLoadCallback(drawCharts);

        function drawCharts() {
          // Draw all charts
          drawProjectsByPhaseChart();
          drawCostByPhaseChart();
          drawProgressAndHealthCharts();
          drawTagCharts();
        }

        // Make phaseStats a global variable
        window.phaseStats = <%- JSON.stringify(phaseStats) %>;

        function drawProjectsByPhaseChart() {
          const phases          = window.phaseStats.map(p => p.phaseName);
          const troubleCounts   = window.phaseStats.map(p => p.troubleCount);
          const cautionCounts   = window.phaseStats.map(p => p.cautionCount);
          const healthyCounts   = window.phaseStats.map(p => p.healthyCount);
          const noStatusCounts  = window.phaseStats.map(p => p.noStatusCount);

          // Build annotations only for non‐zero values
          const ann = arr => arr.map(c => c > 0 ? String(c) : '');

          // Prepare DataTable rows
          const dataArray = [
            [
              'Phase',
              'Trouble',   { type:'string', role:'annotation' },
              'Caution',   { type:'string', role:'annotation' },
              'Healthy',   { type:'string', role:'annotation' },
              'Danger', { type:'string', role:'annotation' }
            ]
          ];
          phases.forEach((phase, i) => {
            dataArray.push([
              phase,
              troubleCounts[i],  ann(troubleCounts)[i],
              cautionCounts[i],  ann(cautionCounts)[i],
              healthyCounts[i],  ann(healthyCounts)[i],
              noStatusCounts[i], ann(noStatusCounts)[i]
            ]);
          });

          // Draw with Google Charts
          const data = google.visualization.arrayToDataTable(dataArray);
          const options = {
            title: 'Initiatives by Phase',
            isStacked: true,
            width: 650,
            height: 300,
            chartArea: { left:60, top:60, width:'75%', height:'65%' },
            colors: ['#dc3545','#ffc107','#28a745','#42a5f5'],
            vAxis: {
              minValue: 0,
              gridlines: { color:'#eee' },
              textStyle: { fontSize: 12 }
            },
            legend: {
              position: 'bottom',
              maxLines: 1,
              textStyle: { fontSize: 12 }
            },
            annotations: {
              alwaysOutside: false,
              textStyle: {
                fontSize: 14,
                color: '#fff',
                bold: true,
                auraColor: 'none'
              },
              highContrast: false
            },
            backgroundColor: 'transparent'
          };
          const chart = new google.visualization.ColumnChart(
            document.getElementById('columnchart_values')
          );
          chart.draw(data, options);
        }

        function drawCostByPhaseChart() {
          // Extract names & per‐status cost arrays from phaseStats
          const phases         = window.phaseStats.map(p => p.phaseName);
          const troubleCosts   = window.phaseStats.map(p => p.troubleCost);
          const cautionCosts   = window.phaseStats.map(p => p.cautionCost);
          const healthyCosts   = window.phaseStats.map(p => p.healthyCost);
          const noStatusCosts  = window.phaseStats.map(p => p.noStatusCost);

          // Formatter: only show annotation if cost > 0, add commas & dollar sign
          const fmt = n => {
            if (n <= 0) return '';
            return '$' + n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
          };
          const troubleAnn   = troubleCosts.map(fmt);
          const cautionAnn   = cautionCosts.map(fmt);
          const healthyAnn   = healthyCosts.map(fmt);
          const noStatusAnn  = noStatusCosts.map(fmt);

          // Build the DataTable rows
          const dataArray = [
            [
              'Phase',
              'Trouble',   { type: 'string', role: 'annotation' },
              'Caution',   { type: 'string', role: 'annotation' },
              'Healthy',   { type: 'string', role: 'annotation' },
              'No Status', { type: 'string', role: 'annotation' }
            ]
          ];
          phases.forEach((phase, i) => {
            dataArray.push([
              phase,
              troubleCosts[i],  troubleAnn[i],
              cautionCosts[i],  cautionAnn[i],
              healthyCosts[i],  healthyAnn[i],
              noStatusCosts[i], noStatusAnn[i]
            ]);
          });

          // Convert to a Google DataTable
          const data = google.visualization.arrayToDataTable(dataArray);

          // Chart options – stacked, currency axis, white annotations, one‐row legend
          const options = {
            title: 'Investment by Phase',
            isStacked: true,
            width: 650,
            height: 300,
            chartArea: { left:80, top:60, width:'75%', height:'65%' },
            colors: ['#dc3545','#ffc107','#28a745','#42a5f5'],
            vAxis: {
              minValue: 0,
              format: '$#,###',
              gridlines: { color: '#eee' }
            },
            legend: {
              position: 'bottom',
              maxLines: 1,
              textStyle: { fontSize: 12 }
            },
            annotations: {
              alwaysOutside: false,
              textStyle: {
                fontSize: 12,
                color: '#fff',
                bold: true,
                auraColor: 'none'
              },
              highContrast: false
            },
            backgroundColor: 'transparent'
          };

          // 6) Draw the chart
          const chart = new google.visualization.ColumnChart(
            document.getElementById('columnChartCost_values')
          );
          chart.draw(data, options);
        }

        function drawProgressAndHealthCharts() {
          // Fetch progress data - no need for query parameters since we use session-based filtering
          fetch(`/projects/radar/progress/`)
            .then((response) => response.json())
            .then((data) => {
              drawProgressChart(data);
              drawHealthStatusChart(data);
            })
            .catch((err) => console.error("Error loading Progress/Health data:", err));
        }

        function drawProgressChart(data) {
          if (!data || !data.project_names || data.project_names.length === 0) {
            document.getElementById("progressChart").innerHTML = '<p>No progress data available</p>';
            return;
          }

          // Create separate series for each health status to enable different colors
          const chartData = [["Project", "Green", "Yellow", "Red", "No Status"]];

          data.project_names.forEach((projectName, index) => {
            const progress = data.progress[index] || 0;
            const progressValue = typeof progress === 'number' ? progress :
                                  (typeof progress === 'string' && progress !== 'No status available') ?
                                  parseFloat(progress) : 0;

            const health = data.colors[index] || 'No status available';

            // Initialize row with zeros for all health statuses
            const row = [projectName, 0, 0, 0, 0];

            // Set the progress value only for the appropriate health status column
            if (health === 'green' || health === 'Green') {
              row[1] = progressValue; // Green column
            } else if (health === 'yellow' || health === 'Yellow') {
              row[2] = progressValue; // Yellow column
            } else if (health === 'red' || health === 'Red') {
              row[3] = progressValue; // Red column
            } else {
              row[4] = progressValue; // No Status column
            }

            chartData.push(row);
          });

          const chartDataTable = google.visualization.arrayToDataTable(chartData);

          const options = {
            title: 'Project Progress',
            backgroundColor: 'transparent',
            width: 650,
            height: 400,
            chartArea: { left: 80, top: 60, width: '75%', height: '70%' },
            isStacked: true,
            bar: { groupWidth: '70%' },
            hAxis: {
              textStyle: { fontSize: 10 }
            },
            vAxis: {
              title: 'Progress %',
              minValue: 0,
              maxValue: 100,
              format: '#\'%\'',
              gridlines: { color: '#eee' }
            },
            legend: {
              position: 'bottom',
              textStyle: { fontSize: 10 }
            },
            colors: ['#28a745', '#ffc107', '#dc3545', '#6c757d'] // Green, Yellow, Red, Gray
          };

          const chart = new google.visualization.ColumnChart(
            document.getElementById('progressChart')
          );
          chart.draw(chartDataTable, options);
        }

        function drawHealthStatusChart(data) {
          if (!data || !data.project_names || data.project_names.length === 0) {
            document.getElementById("healthStatusChart").innerHTML = '<p>No health data available</p>';
            return;
          }

          // Count health statuses
          const healthCounts = { 'Green': 0, 'Yellow': 0, 'Red': 0, 'No Status': 0 };

          data.colors.forEach(health => {
            if (health === 'green' || health === 'Green') {
              healthCounts['Green']++;
            } else if (health === 'yellow' || health === 'Yellow') {
              healthCounts['Yellow']++;
            } else if (health === 'red' || health === 'Red') {
              healthCounts['Red']++;
            } else {
              healthCounts['No Status']++;
            }
          });

          const chartData = [["Health Status", "Count"]];
          Object.entries(healthCounts).forEach(([status, count]) => {
            if (count > 0) {
              chartData.push([status, count]);
            }
          });

          if (chartData.length === 1) {
            document.getElementById("healthStatusChart").innerHTML = '<p>No health status data available</p>';
            return;
          }

          const chartDataTable = google.visualization.arrayToDataTable(chartData);

          const options = {
            title: 'Project Health',
            backgroundColor: 'transparent',
            width: 650,
            height: 400,
            pieHole: 0.4,
            colors: ['#28a745', '#ffc107', '#dc3545', '#6c757d'],
            legend: {
              position: 'right',
              textStyle: { color: '#333', fontSize: 12 }
            },
            pieSliceText: 'value'
          };

          const chart = new google.visualization.PieChart(
            document.getElementById('healthStatusChart')
          );
          chart.draw(chartDataTable, options);
        }

        function drawTagCharts() {
          // Tag charts now use session-based filtering - no need for query parameters

          // Tag 1 Chart with session-based filtering
          fetch(`/projects/radar/countProjectsByTag1`)
            .then((response) => response.json())
            .then((tagsData) => {
              if (!tagsData || tagsData.length === 0) {
                document.getElementById("tag1NoTags").innerText =
                  "No data found for tag 1";
                return;
              }

              const chartData = [["Tag", "Count"]];
              const colors = [];
              tagsData.forEach((tag) => {
                if (tag.tag_name && tag.project_count > 0) {
                  chartData.push([tag.tag_name, parseInt(tag.project_count)]);
                  colors.push(getTagColor(tag.tag_name, tag.tag_color));
                }
              });

              const data = google.visualization.arrayToDataTable(chartData);

              const options = {
                title: "Initiatives ",
                pieHole: 0.4,
                backgroundColor: "transparent",
                width: 550,
                height: 300,
                slices: colorsToSlices(colors),
              };

              const chart = new google.visualization.PieChart(
                document.getElementById("tag1Chart")
              );
              chart.draw(data, options);
            })
            .catch((err) => console.error("Error loading Tag 1 Chart:", err));

          // Tag 1 Cost Chart with date filtering
          fetch(`/projects/radar/countCostsByTag1`)
            .then((response) => response.json())
            .then((tagsData) => {
              if (!tagsData || tagsData.length === 0) {
                document.getElementById("tag1NoCostTags").innerText =
                  "No data found for tag 1 cost";
                return;
              }

              const chartData = [["Tag", "Cost"]];
              const colors = [];
              tagsData.forEach((tag) => {
                if (tag.tag_name && parseFloat(tag.total_cost) > 0) {
                  chartData.push([
                    tag.tag_name,
                    parseFloat(tag.total_cost),
                  ]);
                  colors.push(getTagColor(tag.tag_name, tag.tag_color));
                }
              });

              const data = google.visualization.arrayToDataTable(chartData);

              const options = {
                title: "Cost",
                pieHole: 0.4,
                backgroundColor: "transparent",
                width: 550,
                height: 300,
                slices: colorsToSlices(colors),
              };

              const chart = new google.visualization.PieChart(
                document.getElementById("tag1CostChart")
              );
              chart.draw(data, options);
            })
            .catch((err) => console.error("Error loading Tag 1 Cost Chart:", err));

          // Tag 1 Effort Chart with date filtering
          fetch(`/projects/radar/countEffortByTag1`)
            .then((response) => response.json())
            .then((tagsData) => {
              if (!tagsData || tagsData.length === 0) {
                document.getElementById("tag1NoEffortTags").innerText =
                  "No data found for tag 1 effort";
                return;
              }

              const chartData = [["Tag", "Effort"]];
              const colors = [];
              tagsData.forEach((tag) => {
                if (tag.tag_name && parseFloat(tag.total_effort) > 0) {
                  chartData.push([
                    tag.tag_name,
                    parseFloat(tag.total_effort),
                  ]);
                  colors.push(getTagColor(tag.tag_name, tag.tag_color));
                }
              });

              const data = google.visualization.arrayToDataTable(chartData);

              const options = {
                title: "Effort",
                pieHole: 0.4,
                backgroundColor: "transparent",
                width: 550,
                height: 300,
