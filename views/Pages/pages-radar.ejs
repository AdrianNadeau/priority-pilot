      function drawPortfolioHealthChart() {
        var portfolioHealth = window.radarPageData.portfolioHealth;
        if (!portfolioHealth || !portfolioHealth.counts) {
          document.getElementById('pieChart').innerHTML = '<p style="color:#999;">No health data available</p>';
          return;
        }
        
        var dataArray = [['Status', 'Count']];
        var labels = ['Healthy', 'Caution', 'In Trouble'];
        portfolioHealth.counts.forEach(function(count, i) {
          if (count > 0) {
            dataArray.push([labels[i], count]);
          }
        });
        
        if (dataArray.length === 1) {
          document.getElementById('pieChart').innerHTML = '<p style="color:#999;">No health data available</p>';
          return;
        }
        
        var data = google.visualization.arrayToDataTable(dataArray);
        var options = {
          pieHole: 0.4,
          backgroundColor: 'transparent',
          width: 600,
          height: 350,
          colors: portfolioHealth.colors,
          legend: { position: 'right' },
          pieSliceText: 'value'
        };
        
        var chart = new google.visualization.PieChart(document.getElementById('pieChart'));
        chart.draw(data, options);
        console.log('Portfolio Health chart drawn');
      }
      
      function drawProgressAndHealthChartsInline() {
      
        fetch('/projects/radar/progress/')
          .then(function(response) { return response.json(); })
          .then(function(data) {
            
            drawProgressChartInline(data);
            drawHealthStatusChartInline(data);
          })
          .catch(function(err) {
            console.error('Error loading Progress/Health data:', err);
          });
      }
      
      function drawProgressChartInline(data) {
        
        if (!data || !data.project_names || data.project_names.length === 0) {
          document.getElementById('progressChart').parentElement.innerHTML = '<p style="color:#999;">No progress data available</p>';
          return;
        }
        
        var labels = [];
        var progressValues = [];
        var backgroundColors = [];
        
        data.project_names.forEach(function(projectName, index) {
          var progress = data.progress[index] || 0;
          var progressValue = typeof progress === 'number' ? progress :
                             (typeof progress === 'string' && progress !== 'No status available') ?
                             parseFloat(progress) : 0;
          
          var health = data.colors[index] || 'No status available';
          
          if (!health || health === 'No status available' || health === '' || health === null) {
            return;
          }
          
          labels.push(projectName);
          progressValues.push(progressValue);
          
          if (health === 'green' || health === 'Green') {
            backgroundColors.push('#28a745');
          } else if (health === 'yellow' || health === 'Yellow') {
            backgroundColors.push('#ffc107');
          } else if (health === 'red' || health === 'Red') {
            backgroundColors.push('#dc3545');
          }
        });
        
        if (labels.length === 0) {
          document.getElementById('progressChart').parentElement.innerHTML = '<p style="color:#999;">No progress data available</p>';
          return;
        }
        
        var ctx = document.getElementById('progressChart').getContext('2d');
        
        if (window.progressChartInstance) {
          window.progressChartInstance.destroy();
        }
        
        window.progressChartInstance = new Chart(ctx, {
          type: 'bar',
          data: {
            labels: labels,
            datasets: [{
              label: 'Progress %',
              data: progressValues,
              backgroundColor: backgroundColors,
              borderWidth: 1
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              x: {
                ticks: {
                  font: {
                    size: 10
                  },
                  maxRotation: 45,
                  minRotation: 45
                }
              },
              y: {
                beginAtZero: true,
                max: 100,
                title: {
                  display: true,
                  text: 'Progress (%)'
                },
                grid: {
                  color: '#eee'
                }
              }
            },
            plugins: {
              legend: {
                display: false
              },
              tooltip: {
                callbacks: {
                  label: function(context) {
                    return context.parsed.y + '%';
                  }
                }
              }
            }
          }
        });
        
      }
      
      function drawHealthStatusChartInline(data) {
        
        if (!data || !data.project_names || data.project_names.length === 0) {
          document.getElementById('healthStatusChart').innerHTML = '<p style="color:#999;">No health data available</p>';
          return;
        }
        
        var healthCounts = { 'Green': 0, 'Yellow': 0, 'Red': 0 };
        
        data.colors.forEach(function(health) {
          if (health === 'green' || health === 'Green') {
            healthCounts['Green']++;
          } else if (health === 'yellow' || health === 'Yellow') {
            healthCounts['Yellow']++;
          } else if (health === 'red' || health === 'Red') {
            healthCounts['Red']++;
          }
        });
        
        var chartData = [['Health Status', 'Count']];
        Object.keys(healthCounts).forEach(function(status) {
          if (healthCounts[status] > 0) {
            chartData.push([status, healthCounts[status]]);
          }
        });
        
        if (chartData.length === 1) {
          document.getElementById('healthStatusChart').innerHTML = '<p style="color:#999;">No health status data available</p>';
          return;
        }
        
        var dataTable = google.visualization.arrayToDataTable(chartData);
        var options = {
          backgroundColor: 'transparent',
          width: 650,
          height: 400,
          pieHole: 0.4,
          colors: ['#28a745', '#ffc107', '#dc3545'],
          legend: { position: 'right' },
          pieSliceText: 'value'
        };
        
        var chart = new google.visualization.PieChart(document.getElementById('healthStatusChart'));
        chart.draw(dataTable, options);
        
      }
      
      function drawInitiativesByPhaseChart() {
        
        var stats = window.radarPageData.phaseStats;
        if (!stats || stats.length === 0) {
          document.getElementById('columnchart_values').innerHTML = '<p style="color:#999;">No data available</p>';
          return;
        }
        
        var dataArray = [['Phase', 'Trouble', 'Caution', 'Healthy', 'No Status']];
        stats.forEach(function(s) {
          dataArray.push([
            s.phaseName,
            s.troubleCount || 0,
            s.cautionCount || 0,
            s.healthyCount || 0,
            s.noStatusCount || 0
          ]);
        });
        
        var data = google.visualization.arrayToDataTable(dataArray);
        var options = {
          isStacked: true,
          width: 650,
          height: 300,
          colors: ['#dc3545','#ffc107','#28a745','#42a5f5'],
          legend: { position: 'bottom' },
          backgroundColor: 'transparent'
        };
        
        var chart = new google.visualization.ColumnChart(document.getElementById('columnchart_values'));
        chart.draw(data, options);
       
      }
      
