<%- contentFor('HeaderCss') %>
<!-- Add this to your existing <style> block -->
<style>
  /* Base styling for icons */
  .mdi-pencil, .mdi-delete, .mdi-notepad {
    margin-left: 8px !important;
    font-size: 16px !important;
    color: #6c757d !important;
    transition: all 0.2s ease-in-out !important;
    cursor: pointer !important;
  }

  /* Hover effects with higher specificity */
  i.mdi-pencil:hover {
    color: #28a745 !important; /* Green for edit */
    transform: scale(1.1) !important;
  }
  
  i.mdi-notepad:hover {
    color: #17a2b8 !important; /* Teal for notepad */
    transform: scale(1.1) !important;
  }
  
  i.mdi-delete:hover {
    color: #dc3545 !important; /* Red for delete */
    transform: scale(1.1) !important;
  }

  /* Remove the ::after tooltips for now to test if hover works */
</style>

