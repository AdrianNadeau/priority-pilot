<style>
    .color-box {
      width: 50px !important;
      height:50px !important;
      margin-top: 20px;
      border: 1px solid #ccc;
      display: inline-block;
    }
    label {
      font-family: sans-serif;
      margin-right: 10px;
    }
    
    /* Tag styling */
    .tag-item {
      display: block; 
      color: #333; 
      padding: 4px 0; 
      margin: 2px 0; 
      font-size: 14px;
      position: relative;
      transition: transform 0.2s ease;
    }
    
    .tag-item:hover {
      transform: translateX(4px);
    }
    
    .tag-bullet {
      display: inline-block;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      margin-right: 8px;
      vertical-align: middle;
    }
    
    .tag-item .mdi {
      margin-left: 6px; 
      cursor: pointer; 
      opacity: 0.6;
      transition: opacity 0.2s ease;
      color: #666;
    }
    
    .tag-item .mdi:hover {
      opacity: 1;
      transform: scale(1.1);
    }
  </style>
