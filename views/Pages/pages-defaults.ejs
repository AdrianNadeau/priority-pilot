<%- contentFor('HeaderCss') %>

<style>
  .tag-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 0;
    font-size: 14px;
    transition: transform 0.2s ease;
  }

  .tag-item:hover {
    transform: translateX(4px);
  }

  .tag-bullet {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .mdi {
    cursor: pointer;
    opacity: 0.7;
    transition: all 0.2s ease;
  }

  .mdi:hover {
    opacity: 1;
    transform: scale(1.2);
  }

  .mdi-pencil:hover {
    filter: brightness(1.2);
  }

  .mdi-delete:hover {
    color: #dc3545 !important;
    filter: brightness(1.2);
  }
</style>

<%- contentFor('breadcrumb') %>
<%- contentFor('body') %>

<div class="page-content-wrapper">
  <div class="container-fluid">
    <div class="row">
      <div class="col-lg-12">
        <div class="card-body">

          <!-- ================= DEFAULTS FORM ================= -->
          <form action="/companies/set/defaults" method="POST" novalidate>
            <input type="hidden" name="company_id" value="<%= company.id %>">

            <div class="row">
              <div class="col-md-6">

                <div class="form-group">
                  <label>Portfolio Name</label>
                  <input class="form-control" name="company_headline" value="<%= company.company_headline %>">
                </div>

                <div class="form-group">
                  <label>Portfolio Budget ($)</label>
                  <input class="form-control" name="portfolio_budget"
                         value="<%= company.portfolio_budget %>"
                         oninput="formatNumberWithCommas(this)">
                </div>

                <div class="form-group">
                  <label>Portfolio Effort</label>
                  <input class="form-control" name="portfolio_effort"
                         value="<%= company.effort %>"
                         oninput="formatNumberWithCommas(this)">
                </div>

                <div class="modal-footer">
                  <button type="submit" class="btn btn-primary">Update</button>
                </div>
              </div>

              <!-- ================= TAGS ================= -->
              <div class="col-md-6">
                <label>Company Tags</label>
                <ul style="list-style:none;padding-left:0">

                  <% tags.forEach(tag => { %>
                    <li class="tag-item">
                      <span class="tag-bullet"
                            style="background:<%= tag.tag_color || '#6c757d' %>"></span>

                      <span><%= tag.tag_name %></span>

                      <i class="mdi mdi-pencil edit-tag"
                         data-toggle="modal"
                         data-target="#editTagModal"
                         data-id="<%= tag.id %>"
                         data-name="<%= tag.tag_name %>"
                         data-company="<%= tag.company_id_fk %>"
                         data-color="<%= tag.tag_color || '#6c757d' %>"
                         title="Edit"
                         style="color: <%= tag.tag_color || '#6c757d' %>;"
                         onclick="editTag(this)">
                      </i>

                      <i class="mdi mdi-delete delete-tag"
                         data-toggle="modal"
                         data-target="#deleteTagModal"
                         data-id="<%= tag.id %>"
                         data-name="<%- tag.tag_name %>"
                         data-company="<%= tag.company_id_fk %>"
                         title="Delete"
                         onclick="deleteTag(this)">
                      </i>
                    </li>
                  <% }) %>

                </ul>

                <!-- ADD TAG -->
                <form action="/tags" method="POST">
                  <input type="hidden" name="company_id_fk" value="<%= company.id %>">

                  <label>Tag Color</label>
                  <input type="color" id="colorInput" value="#000000">
                  <input type="text" id="tag_color" name="tag_color" value="#000000">

                  <label>Tag Name</label>
                  <input class="form-control" name="tag_name" required>

                  <button class="btn btn-primary mt-2">Add</button>
                </form>

              </div>
            </div>
          </form>

        </div>
      </div>
    </div>
  </div>
</div>

<!-- ================= EDIT MODAL ================= -->
<div class="modal fade" id="editTagModal">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header"><h5>Edit Tag</h5></div>
      <div class="modal-body">
        <form id="editTagForm">
          <input type="hidden" id="edit_tag_id">
          <input type="hidden" id="edit_company_id_fk">

          <label>Color</label>
          <input type="color" id="edit_colorInput" style="width: 60px; height: 40px;">
          <input type="text" id="edit_tag_color" class="form-control" readonly style="display: inline-block; width: 120px; margin-left: 10px;">

          <label>Name</label>
          <input class="form-control" id="edit_tag_name" required>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" id="cancelTagBtn">Cancel</button>
        <button type="button" class="btn btn-primary" id="saveTagBtn">Save</button>
      </div>
    </div>
  </div>
</div>

<!-- ================= DELETE MODAL ================= -->
<div class="modal fade" id="deleteTagModal">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header"><h5>Delete Tag</h5></div>
      <div class="modal-body">
        <input type="hidden" id="delete_tag_id">
        <p>Are you sure you want to delete the tag: <strong id="delete_tag_name"></strong>?</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
      </div>
    </div>
  </div>
</div>

<script>
// ================= EDIT TAG =================
function editTag(el) {
  const tagId = el.dataset.id;
  const companyId = el.dataset.company;
  const tagName = el.dataset.name;
  const tagColor = el.dataset.color;

  console.log('Edit tag - Raw data:', { tagId, companyId, tagName, tagColor });

  // Ensure tagColor is a valid hex code
  const hexColor = (tagColor && tagColor.startsWith('#')) ? tagColor.toUpperCase() : '#000000';
  console.log('Hex color formatted:', hexColor);

  // Set values using vanilla JavaScript
  document.getElementById('edit_tag_id').value = tagId || '';
  document.getElementById('edit_company_id_fk').value = companyId || '';
  document.getElementById('edit_tag_name').value = tagName || '';
  document.getElementById('edit_tag_color').value = hexColor;
  document.getElementById('edit_colorInput').value = hexColor;

  console.log('Form values set:');
  console.log('  - Tag Name:', document.getElementById('edit_tag_name').value);
  console.log('  - Tag Color (text input):', document.getElementById('edit_tag_color').value);
  console.log('  - Color Input (picker):', document.getElementById('edit_colorInput').value);

  $('#editTagModal').modal('show');
}

// ================= DELETE TAG =================
function deleteTag(el) {
  const tagId = el.dataset.id;
  const tagName = el.dataset.name;

  console.log('Delete tag:', { tagId, tagName, allData: el.dataset });

  $('#delete_tag_id').val(tagId || '');
  $('#delete_tag_name').text(tagName || 'this tag');

  console.log('Modal text set to:', $('#delete_tag_name').text());

  $('#deleteTagModal').modal('show');
}

document.addEventListener('DOMContentLoaded', function() {


  // ================= CANCEL TAG =================
  document.getElementById('cancelTagBtn').addEventListener('click', () => {
    $('#editTagModal').modal('hide');
  });

  // ================= SAVE TAG =================
  document.getElementById('saveTagBtn').addEventListener('click', () => {
    const id = edit_tag_id.value;
    fetch(`/tags/${id}`, {
      method: 'PUT',
      body: new URLSearchParams({
        tag_name: edit_tag_name.value,
        tag_color: edit_tag_color.value
      }),
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
    }).then(() => location.reload());
  });

  // ================= DELETE TAG =================
  document.getElementById('confirmDeleteBtn').addEventListener('click', () => {
    const id = document.getElementById('delete_tag_id').value;
    if (!id) {
      console.error('No tag ID found');
      return;
    }
    fetch(`/tags/${id}`, { method: 'DELETE' })
      .then(response => {
        if (response.ok) {
          location.reload();
        } else {
          console.error('Failed to delete tag');
        }
      })
      .catch(error => {
        console.error('Error deleting tag:', error);
      });
  });

  // ================= COLOR SYNC =================
  colorInput.addEventListener('input', () => tag_color.value = colorInput.value);
  edit_colorInput.addEventListener('input', () => edit_tag_color.value = edit_colorInput.value);

});
</script>
