    border-bottom: 2px solid #dee2e6 !important;
  }
  .sortable:hover {
    background-color: #e9ecef !important;
    cursor: pointer;
  }
  .sortable {
    cursor: pointer;
    position: relative;
    user-select: none;
    padding: 12px 8px !important;
    background-color: #f8f9fa;
    border-bottom: 2px solid #dee2e6 !important;
  }
  .sortable:hover {
    background-color: #e9ecef !important;
    cursor: pointer;
  }
  .sort-arrow {
    display: inline-block;
    margin-left: 8px;
    font-size: 16px;
    font-weight: bold;
    color: #6c757d;
    vertical-align: middle;
