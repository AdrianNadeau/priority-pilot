<form action="/projects" class="needs-validation" novalidate method="POST">
  <input type="hidden" name="funnelPage" id="funnelPage" value="n">
  
  <!-- Display validation errors if they exist -->
  <% if (typeof validationErrors !== 'undefined' && validationErrors && validationErrors.length > 0) { %>
    <div class="alert alert-danger" role="alert">
      <h6><i class="fas fa-exclamation-triangle"></i> Please fix the following errors:</h6>
      <ul class="mb-0">
        <% validationErrors.forEach(function(error) { %>
          <li><%= error %></li>
        <% }); %>
      </ul>
    </div>
  <% } %>

  <div class="container">
    <div class="row">
      <div class="col-md-6">
        <!-- Left Column -->
        <div class="mb-2">
          <small class="text-danger"><i class="mdi mdi-asterisk"></i> Required</small>
        </div>
        <div class="form-group">
          <label for="project_name">Project Name:</label> <span class="required_star"><i class="mdi mdi-asterisk"></i></span>
          <input type="text" class="form-control" id="project_name" maxlength="255" name="project_name" required 
                
                 title="Project name is required"
                 value="<%= (typeof formData !== 'undefined' && formData && formData.project_name) ? formData.project_name : '' %>">
          <div class="invalid-feedback">
            Project name is required.
          </div>
        </div>
        <div class="form-group">
          <label for="project_headline">Headline:</label> <span class="required_star"><i class="mdi mdi-asterisk"></i></span>
          <input type="text" class="form-control" id="project_headline" name="project_headline" maxlength="250" required value="<%= (typeof formData !== 'undefined' && formData && formData.project_headline) ? formData.project_headline : '' %>">
          <div class="invalid-feedback">
            Headline is required.
          </div>
        </div>
        <div class="form-group">
          <label for="project_why">Why:</label> <span class="required_star"><i class="mdi mdi-asterisk"></i></span>
          <textarea class="form-control" id="project_why" name="project_why" maxlength="1000" required placeholder="Explain why this project is important and the problem it solves..."><%= (typeof formData !== 'undefined' && formData && formData.project_why) ? formData.project_why : '' %></textarea>
          <div class="invalid-feedback">
            Why is required.
          </div>
        </div>
        <div class="form-group">
          <label for="project_what">What:</label> <span class="required_star"><i class="mdi mdi-asterisk"></i></span>
          <textarea class="form-control" id="project_what" name="project_what" maxlength="500" required placeholder="Describe what will be delivered and the scope of work..."><%= (typeof formData !== 'undefined' && formData && formData.project_what) ? formData.project_what : '' %></textarea>
          <div class="invalid-feedback">
            What is required.
          </div>
        </div>

        <div class="form-group" id="date_section">
          <label for="dates">Start Date and End Date: <span class="required_star"><i class="mdi mdi-asterisk"></i></span></label>
          <div class="form-row">
            <div class="col">
              <label for="start_date">Start:</label>
              <input type="date" class="form-control" id="start_date" name="start_date" required value="<%= (typeof formData !== 'undefined' && formData && formData.start_date) ? formData.start_date : '' %>">
              <div class="invalid-feedback">
                Start date is required.
              </div>
            </div>
            <div class="col">
              <label for="end_date">End:</label>
              <input type="date" class="form-control" id="end_date" name="end_date" required value="<%= (typeof formData !== 'undefined' && formData && formData.end_date) ? formData.end_date : '' %>">
              <div class="invalid-feedback">
                End date is required.
              </div>
            </div>
            <div class="col">
              <label for="next_milestone_date">Next Milestone:</label>
              <input type="date" class="form-control" id="next_milestone_date" name="next_milestone_date" value="<%= (typeof formData !== 'undefined' && formData && formData.next_milestone_date) ? formData.next_milestone_date : '' %>">
            </div>
          </div>
          <div class="form-row" id="milestone_details_row" style="padding-top:5px;">
            <div class="col">
              <input type="text" class="form-control" id="next_milestone_date_details" name="next_milestone_date_details" placeholder="Next Milestone Details" maxlength="100">
              <small class="form-text text-muted">Maximum 100 characters</small>
            </div>
          </div>
         
        </div>
      </div>

      <div class="col-md-6">
        <!-- Right Column -->
        <div class="form-row">
          <div class="col">
            <div class="form-group">
              <label for="phase">Phase:</label>
              <select name="phase_id_fk" id="phase_id_fk" class="form-control">
                <% 
                // Remove duplicate phases by creating a unique array
                const uniquePhases = phases.filter((phase, index, self) => 
                  index === self.findIndex(p => p.id === phase.id && p.phase_name === phase.phase_name)
                );
                uniquePhases.forEach(function(phase){ %>
                <option value="<%= phase.id %>"><%= phase.phase_name %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="col">
            <div class="form-group">
              <label for="priority">Priority:</label>
              <select name="priority_id_fk" id="priority_id_fk" class="form-control">
                <% 
                // Remove duplicate priorities by creating a unique array
                const uniquePriorities = priorities.filter((priority, index, self) => 
                  index === self.findIndex(p => p.id === priority.id && p.priority_name === priority.priority_name)
                );
                uniquePriorities.forEach(function(priority){ %>
                <option value="<%= priority.id %>"><%= priority.priority_name %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </div>
        <div class="form-row">
          <div class="col">
            <div class="form-group">
              <label for="sponsor">Sponsor:</label>
              <select name="sponsor_id_fk" id="sponsor_id_fk" class="form-control">
                <% 
                // Remove duplicate sponsors by creating a unique array
                const uniqueSponsors = sponsors.filter((sponsor, index, self) => 
                  index === self.findIndex(s => s.id === sponsor.id && s.first_name === sponsor.first_name && s.last_name === sponsor.last_name)
                );
                uniqueSponsors.forEach(function(sponsor){ %>
                <option value="<%= sponsor.id %>"><%= sponsor.last_name %>, <%= sponsor.first_name %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="col">
            <div class="form-group">
              <label for="prime">Prime:</label>
              <select name="prime_id_fk" id="prime_id_fk" class="form-control">
                <% 
                // Remove duplicate primes by creating a unique array
                const uniquePrimes = primes.filter((prime, index, self) => 
                  index === self.findIndex(p => p.id === prime.id && p.first_name === prime.first_name && p.last_name === prime.last_name)
                );
                uniquePrimes.forEach(function(prime){ %>
                <option value="<%= prime.id %>"><%= prime.last_name %>, <%= prime.first_name %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </div>
        <div class="form-row">
          <div class="col">
            <div class="form-group">
              <label for="effort">Effort (PH)</label>
              <input type="text" class="form-control" id="effort" oninput="formatNumberWithCommas(this);" name="effort" value="0">
            </div>
          </div>
          <div class="col">
            <div class="form-group">
              <label for="project_cost">Cost ($)</label>
              <input type="text" class="form-control" id="project_cost" oninput="formatNumberWithCommas(this);" name="project_cost" value="0">
            </div>
          </div>
          <div class="col">
            <div class="form-group">
              <label for="benefit">Benefit (ROI or $)</label>
              <input type="text" class="form-control" id="benefit" oninput="formatNumberWithCommas(this);" name="benefit" value="0">
            </div>
          </div>
        </div>
       
        <div class="form-row">
          <div class="col">
            <div class="form-group">
              <label for="tag_1">Tag 1:</label>
              <select name="tag_1" id="tag_1" class="form-control">
                <% if (tags && tags.length > 0) { %>
                <% tags.forEach(function(tag){ %>
                <option value="<%= tag.id %>"><%= tag.tag_name %></option>
                <% }) %>
                <% } else { %>
                <option value="">No tags available</option>
                <% } %>
              </select>
            </div>
          </div>
        </div>
        <div class="form-row">
          <div class="col">
            <div class="form-group">
              <label for="tag_2">Tag 2:</label>
              <select name="tag_2" id="tag_2" class="form-control">
                <% if (tags && tags.length > 0) { %>
                <% tags.forEach(function(tag){ %>
                <option value="<%= tag.id %>"><%= tag.tag_name %></option>
                <% }) %>
                <% } else { %>
                <option value="">No tags available</option>
                <% } %>
              </select>
            </div>
          </div>
        </div>
        <div class="form-row">
          <div class="col">
            <div class="form-group">
              <label for="tag_3">Tag 3:</label>
              <select name="tag_3" id="tag_3" class="form-control">
                <% if (tags && tags.length > 0) { %>
                <% tags.forEach(function(tag){ %>
                <option value="<%= tag.id %>"><%= tag.tag_name %></option>
                <% }) %>
                <% } else { %>
                <option value="">No tags available</option>
                <% } %>
              </select>
            </div>
          </div>
        </div>
        <div class="form-row">
          <div class="col">
            <div class="form-group">
              <label for="reference">Reference:</label>
              <input type="text" class="form-control" id="reference" name="reference">
              <div class="invalid-feedback">
                Please enter a reference.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-secondary waves-effect" data-dismiss="modal">Cancel</button>
      <button class="btn btn-primary w-md waves-effect waves-light" type="submit">Submit</button>
    </div>
  </div>
</form>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const nextMilestoneDateInput = document.getElementById('next_milestone_date');
    const milestoneDetailsRow = document.getElementById('milestone_details_row');
    const phaseSelect = document.getElementById('phase_id_fk');
    const dateSection = document.getElementById('date_section');
    
    // Function to toggle date section and milestone details visibility
    function toggleDateSectionVisibility() {
        const selectedPhase = phaseSelect.options[phaseSelect.selectedIndex];
        const phaseName = selectedPhase ? selectedPhase.text.toLowerCase() : '';

        if (dateSection) {
            if (phaseName === 'pitch') {
                // Hide entire date section when phase is Pitch
                dateSection.style.display = 'none';
                // Clear all date inputs when hiding
                if (document.getElementById('start_date')) {
                    document.getElementById('start_date').value = '';
                    document.getElementById('start_date').removeAttribute('required');
                }
                if (document.getElementById('end_date')) {
                    document.getElementById('end_date').value = '';
                    document.getElementById('end_date').removeAttribute('required');
                }
                if (nextMilestoneDateInput) nextMilestoneDateInput.value = '';
                if (document.getElementById('next_milestone_date_details')) document.getElementById('next_milestone_date_details').value = '';
            } else {
                // Show date section for all other phases
                dateSection.style.display = 'block';
                // Make dates required for non-Pitch phases
                if (document.getElementById('start_date')) {
                    document.getElementById('start_date').setAttribute('required', 'required');
                }
                if (document.getElementById('end_date')) {
                    document.getElementById('end_date').setAttribute('required', 'required');
                }
                // Show milestone details if phase is not pitch and not empty
                toggleMilestoneDetails();
            }
        }
    }
    
    // Function to toggle milestone details visibility (separate from date section)
    function toggleMilestoneDetails() {
        const shouldShow = (nextMilestoneDateInput && nextMilestoneDateInput.value) || 
                          (phaseSelect && checkPhaseTransition());
        
        if (milestoneDetailsRow) {
            if (shouldShow) {
                milestoneDetailsRow.style.display = 'block';
            } else {
                milestoneDetailsRow.style.display = 'none';
                // Clear the details input when hiding
                const detailsInput = document.getElementById('next_milestone_date_details');
                if (detailsInput) {
                    detailsInput.value = '';
                }
            }
        }
    }
    
    // Function to check if phase has changed from Pitch to another phase
    function checkPhaseTransition() {
        if (!phaseSelect) return false;
        
        const selectedPhase = phaseSelect.options[phaseSelect.selectedIndex];
        const phaseName = selectedPhase ? selectedPhase.text.toLowerCase() : '';
        
        // Hide milestone details if phase is Pitch, show for all other phases
        return phaseName !== 'pitch' && phaseName !== '';
    }
    
    // Add event listener to next milestone date input
    if (nextMilestoneDateInput) {
        nextMilestoneDateInput.addEventListener('change', toggleMilestoneDetails);
        nextMilestoneDateInput.addEventListener('input', toggleMilestoneDetails);
    }
    
    // Add event listener to phase selection for both date section and milestone details
    if (phaseSelect) {
        phaseSelect.addEventListener('change', function() {
            toggleDateSectionVisibility();
        });
    }
    
    // Initial check on page load
    if (phaseSelect) {
        toggleDateSectionVisibility();
    }

    // Enhanced form validation
    const form = document.querySelector('.needs-validation');
    const projectNameInput = document.getElementById('project_name');
    const headlineInput = document.getElementById('project_headline');
    const whyInput = document.getElementById('project_why');
    const whatInput = document.getElementById('project_what');
    const startDateInput = document.getElementById('start_date');
    const endDateInput = document.getElementById('end_date');

    // Custom validation function
    function validateForm() {
        let isValid = true;
        let errorMessages = [];

        // Validate project name
        const projectNameValue = projectNameInput.value.trim();

        if (!projectNameValue) {
            projectNameInput.setCustomValidity('Project name is required.');
            errorMessages.push('Project name is required.');
            isValid = false;
        } else if (projectNameValue.length < 3) {
            projectNameInput.setCustomValidity('Project name must be at least 3 characters long.');
            errorMessages.push('Project name must be at least 3 characters long.');
            isValid = false;
        } else if (projectNameValue.length > 255) {
            projectNameInput.setCustomValidity('Project name cannot exceed 255 characters.');
            errorMessages.push('Project name cannot exceed 255 characters.');
            isValid = false;
        } else if (!/^[a-zA-Z0-9\s\-_\.\(\)]+$/.test(projectNameValue)) {
            projectNameInput.setCustomValidity('Project name can only contain letters, numbers, spaces, hyphens, underscores, dots, and parentheses.');
            errorMessages.push('Project name contains invalid characters.');
            isValid = false;
        } else if (/^[\s\-_\.\(\)]+$/.test(projectNameValue)) {
            projectNameInput.setCustomValidity('Project name must contain meaningful text, not just spaces or symbols.');
            errorMessages.push('Project name must contain meaningful text.');
            isValid = false;
        } else if (projectNameValue.toLowerCase() === 'test' || projectNameValue.toLowerCase() === 'temp' ||
                   projectNameValue.toLowerCase() === 'example' || projectNameValue.toLowerCase() === 'sample') {
            projectNameInput.setCustomValidity('Please use a more descriptive project name.');
            errorMessages.push('Please use a more descriptive project name.');
            isValid = false;
        } else {
            projectNameInput.setCustomValidity('');
        }

        // Validate headline
        if (!headlineInput.value.trim()) {
            headlineInput.setCustomValidity('Headline is required.');
            errorMessages.push('Headline is required.');
            isValid = false;
        } else {
            headlineInput.setCustomValidity('');
        }

        // Validate why
        if (!whyInput.value.trim()) {
            whyInput.setCustomValidity('Why is required.');
            errorMessages.push('Why is required.');
            isValid = false;
        } else {
            whyInput.setCustomValidity('');
        }

        // Validate what
        if (!whatInput.value.trim()) {
            whatInput.setCustomValidity('What is required.');
            errorMessages.push('What is required.');
            isValid = false;
        } else {
            whatInput.setCustomValidity('');
        }

        // Validate dates only if date section is visible (not Pitch phase)
        const selectedPhase = phaseSelect.options[phaseSelect.selectedIndex];
        const phaseName = selectedPhase ? selectedPhase.text.toLowerCase() : '';

        if (phaseName !== 'pitch') {
            // Validate start date
            if (!startDateInput.value) {
                startDateInput.setCustomValidity('Start date is required.');
                errorMessages.push('Start date is required.');
                isValid = false;
            } else {
                startDateInput.setCustomValidity('');
            }

            // Validate end date
            if (!endDateInput.value) {
                endDateInput.setCustomValidity('End date is required.');
                errorMessages.push('End date is required.');
                isValid = false;
            } else {
                endDateInput.setCustomValidity('');
            }

            // Validate end date is after start date
            if (startDateInput.value && endDateInput.value) {
                const startDate = new Date(startDateInput.value);
                const endDate = new Date(endDateInput.value);
                if (endDate < startDate) {
                    endDateInput.setCustomValidity('End date must be after start date.');
                    errorMessages.push('End date must be after start date.');
                    isValid = false;
                }
            }
        } else {
            // Clear date validations for Pitch phase
            startDateInput.setCustomValidity('');
            endDateInput.setCustomValidity('');
        }

        return isValid;
    }

    // Add real-time validation listeners
    projectNameInput.addEventListener('input', validateForm);
    headlineInput.addEventListener('input', validateForm);
    whyInput.addEventListener('input', validateForm);
    whatInput.addEventListener('input', validateForm);
    startDateInput.addEventListener('change', validateForm);
    endDateInput.addEventListener('change', validateForm);

    // Form submission validation
    form.addEventListener('submit', function(event) {
        event.preventDefault();
        event.stopPropagation();

        console.log('Form submit event triggered');
        const isFormValid = validateForm();
        const isCheckValid = form.checkValidity();
        console.log('Custom validation:', isFormValid, 'HTML5 validation:', isCheckValid);

        if (!isFormValid || !isCheckValid) {
            // Show validation errors
            form.classList.add('was-validated');

            // Collect all error messages
            let errorMessages = [];
            if (!projectNameInput.value.trim()) errorMessages.push('Project Name is required');
            if (!headlineInput.value.trim()) errorMessages.push('Headline is required');
            if (!whyInput.value.trim()) errorMessages.push('Why is required');
            if (!whatInput.value.trim()) errorMessages.push('What is required');

            const selectedPhase = phaseSelect.options[phaseSelect.selectedIndex];
            const phaseName = selectedPhase ? selectedPhase.text.toLowerCase() : '';

            if (phaseName !== 'pitch') {
                if (!startDateInput.value) errorMessages.push('Start Date is required');
                if (!endDateInput.value) errorMessages.push('End Date is required');
            }

            // Display error messages if any
            if (errorMessages.length > 0) {
                alert('Please fill in all required fields:\n\n' + errorMessages.join('\n'));
            }

            // Focus on first invalid field
            const firstInvalid = form.querySelector(':invalid');
            if (firstInvalid) {
                console.log('First invalid field:', firstInvalid.name, firstInvalid.validationMessage);
                firstInvalid.focus();
                firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        } else {
            // Form is valid, submit it
            console.log('Form is valid, submitting...');
            form.classList.add('was-validated');
            form.submit();
        }
    });

    // Initialize validation on page load
    validateForm();
});
</script>
