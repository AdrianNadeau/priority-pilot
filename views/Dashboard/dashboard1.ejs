<%
/* -----------------------------------------
   Helper: sanitize percent / numeric values
----------------------------------------- */
function sanitizeNumber(val) {
  if (typeof val === 'number') return val;
  if (typeof val !== 'string') return NaN;
  const cleaned = val.replace(/[^0-9.\-]/g, '');
  const parsed = parseFloat(cleaned);
  return isNaN(parsed) ? NaN : parsed;
}

/* -----------------------------------------
   Helper: Pad + Normalize Numbers
----------------------------------------- */
function padFormatNumber(val) {
  const numRaw = (typeof val === 'number')
    ? val
    : parseFloat(String(val).replace(/[^0-9.\-]/g, ''));

  if (isNaN(numRaw)) return '00.00';

  let num = numRaw;

  // Business rule: Huge numbers interpreted as percentages
  if (Math.abs(numRaw) >= 1000) {
    num = Math.round(numRaw / 100);
  }

  const fixed = num.toFixed(2);
  const parts = fixed.split('.');
  let intPart = parts[0];
  const decPart = parts[1] || '00';

  const sign = intPart.startsWith('-') ? '-' : '';
  if (sign) intPart = intPart.slice(1);

  if (intPart.length < 2) {
    intPart = intPart.padStart(2, '0');
  }

  return `${sign}${intPart}.${decPart}`;
}

/* -----------------------------------------
   Helper: Render project buttons by phase
----------------------------------------- */
function renderPhaseButtons(phaseName) {
  let html = '';
  projects.forEach(project => {
    if (project.phase_name &&
        project.phase_name.trim().toLowerCase() === phaseName) {

      let health = (project.latest_status_health || '').trim().toLowerCase();
      let borderColor =
        (health === 'green') ? 'green' :
        (health === 'yellow') ? 'yellow' :
        (health === 'red') ? 'red' :
        'black';

      const btnStyle =
        `margin-bottom:10px; border-color:${borderColor}; ` +
        `border-width:2px; border-radius:10px;`;

      html += `
        <button type="button"
          onclick="loadProject('${project.id}')"
          class="btn btn-light project-btn"
          data-style="${btnStyle}">
          ${project.project_name}
        </button>&nbsp;&nbsp;&nbsp;`;
    }
  });
  return html;
}

/* -----------------------------------------
   Helper: Format number with commas
----------------------------------------- */
function formatNumberWithCommas(x) {
  if (x == null) return '0';
  let parts = x.toString().split('.');
  parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ",");
  return parts.join('.');
}

/* -----------------------------------------
   Portfolio Budget / Effort + Delivery Totals
----------------------------------------- */
let deliveryTotalCost = 0,
    deliveryUsedCost = 0,
    deliveryAvailCost = 0;

let deliveryTotalEffort = 0,
    deliveryUsedEffort = 0,
    deliveryAvailEffort = 0;

let portfolioBudget = 0,
    portfolioEffort = 0;

// Load portfolio budget
if (companies && companies.length > 0) {
  portfolioBudget = Number(String(companies[0].portfolio_budget || 0).replace(/,/g, ''));
  portfolioEffort = Number(companies[0].effort || 20000);
}

// Calculate totals based on filteredDays
if (filteredDays) {
  deliveryTotalCost = Math.round((portfolioBudget / 365) * filteredDays);
  deliveryTotalEffort = Math.round((portfolioEffort / 365) * filteredDays);
} else {
  deliveryTotalCost = Math.round(portfolioBudget);
  deliveryTotalEffort = Math.round(portfolioEffort);
}

// Sum used cost/effort for Delivery
projects.forEach(project => {
  if (project.phase_name &&
      project.phase_name.trim().toLowerCase() === 'delivery') {

    const usedCost = (typeof getFilteredValue === 'function')
      ? getFilteredValue(project, currentFromDate, currentToDate, 'project_cost')
      : 0;

    const usedEffort = (typeof getFilteredValue === 'function')
      ? getFilteredValue(project, currentFromDate, currentToDate, 'effort')
      : 0;

    deliveryUsedCost += usedCost;
    deliveryUsedEffort += usedEffort;
  }
});

deliveryAvailCost = deliveryTotalCost - deliveryUsedCost;
deliveryAvailEffort = deliveryTotalEffort - deliveryUsedEffort;

// Debug
console.log("COMPANY:", companies[0]);
console.log("Dashboard totals:", {
  deliveryTotalCost,
  deliveryTotalEffort
});
