                                  else if (health === 'yellow') borderColor = 'yellow';
                                  else if (health === 'red') borderColor = 'red';
                                  else borderColor = 'black'; // default
                                  const btnStyle = 'margin-bottom:10px; border-color:' + borderColor + '; border-width:2px; border-radius:10px;';
                                  var filteredCost = getFilteredValue(project, currentFromDate, currentToDate, 'project_cost');
                                  var filteredEffort = getFilteredValue(project, currentFromDate, currentToDate, 'effort');
                            %>
                                <button type="button" onclick="loadProject('<%= project.id %>')" class="btn btn-light project-btn" data-style="<%= btnStyle %>" title="Filtered Cost: $<%= filteredCost %> | Filtered Effort: <%= filteredEffort %> PH">
                                  <%= project.project_name %>
                                </button>&nbsp;&nbsp;&nbsp;
                              <%  } 
                            }); %>
                            </div>
                        </div>
                    </div>

          
            </div> <!-- close inner delivery/done row -->

            <!-- Budget and Effort Summary Section -->
            <!-- Filtered Date Range Totals Section -->
            <% 
              let totalBudget = 0, totalEffort = 0, usedCost = 0, usedEffort = 0;
              projects.forEach(function(project) {
                totalBudget += Number(project.project_cost) || 0;
                totalEffort += Number(project.effort) || 0;
              });
              let showFiltered = currentFromDate && currentToDate && filteredDays;
              let mainTotalCost, mainUsedCost, mainAvailCost, mainTotalEffort, mainUsedEffort, mainAvailEffort;
              if (showFiltered) {
                usedCost = 0; usedEffort = 0;
                projects.forEach(function(project) {
                  if (typeof getFilteredValue === 'function') {
                    usedCost += getFilteredValue(project, currentFromDate, currentToDate, 'project_cost');
                    usedEffort += getFilteredValue(project, currentFromDate, currentToDate, 'effort');
                  }
                });
                mainTotalCost = Math.round((totalBudget / 365) * filteredDays);
                mainTotalEffort = Math.round((totalEffort / 365) * filteredDays);
                mainUsedCost = usedCost;
                mainUsedEffort = usedEffort;
                mainAvailCost = mainTotalCost - mainUsedCost;
                mainAvailEffort = mainTotalEffort - mainUsedEffort;
              } else {
                // No filter: show all-time totals
                mainTotalCost = totalBudget;
                mainTotalEffort = totalEffort;
                mainUsedCost = 0;
                mainUsedEffort = 0;
                projects.forEach(function(project) {
                  mainUsedCost += Number(project.used_cost) || 0;
                  mainUsedEffort += Number(project.used_effort) || 0;
                });
                mainAvailCost = mainTotalCost - mainUsedCost;
                mainAvailEffort = mainTotalEffort - mainUsedEffort;
              }
            %>
            <div class="row" style="margin-top: 15px;">
              <div class="col-md-12">
                <div class="alert alert-success" style="margin-bottom: 15px; padding: 15px; background-color: #d4edda; border: 1px solid #28a745; border-radius: 4px;">
                  <div style="display: flex; align-items: center;">
                    <div style="width: 50%; display: flex; align-items: flex-start; flex-direction: column;">
                      <div style="display: flex; align-items: center;">
                        <i class="mdi mdi-calculator" style="margin-right: 8px; font-size: 20px; color: #155724;"></i>
                        <strong style="color: #155724; font-size: 16px;padding-right:5px;">Cost:</strong>
                        <span style="color: #155724; font-weight: bold;padding-right:5px;">Total: $<%= totalCost %></span>
                        <span style="color: #155724; font-weight: bold; margin-left:5px;">Used: $<%= usedCost %></span>
                        <span style="color: #155724; font-weight: bold; margin-left:5px;">Avail: $<%= availableCost %></span>
                      </div>
                    </div>
                    <div style="width: 50%; display: flex; align-items: flex-start; flex-direction: column;">
                      <div style="display: flex; align-items: center;">
                        <i class="mdi mdi-calculator" style="margin-right: 8px; font-size: 20px; color: #155724;"></i>
                        <strong style="color: #155724; font-size: 16px;padding-right:5px;">Effort:</strong>
                        <span style="color: #155724; font-weight: bold;padding-right:5px;">Total: <%= totalPH %> PH</span>
                        <span style="color: #155724; font-weight: bold; margin-left:5px;">Used: <%= totalUsedPH %> PH</span>
                        <span style="color: #155724; font-weight: bold; margin-left:5px;">Avail: <%= totalAvailPH %> PH</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
                     </div>

            <div class="col-md-2">
              <div>
                      
                    </div>
                <div class="mini-stat bg-white text-center clearfix" style="padding-top:15px;">
                   <div><button type="button" class="btn btn-primary waves-effect waves-light" data-toggle="modal" data-target="#addProject" id="btnAddProject" style="width: 150px;">Add Project</button></div>
                    <hr/>
                    <div><button class="btn btn-primary w-md waves-effect waves-light"  style="margin-bottom: 10px;width: 150px" onClick="loadRadar();">Radar</button></div>
                   
                    <div><button class="btn btn-primary w-md waves-effect waves-light" style="margin-bottom: 10px;width: 150px" onClick="loadHealth();" >Health Check</button></div>
                    <div><button class="btn btn-primary w-md waves-effect waves-light" style="margin-bottom: 10px;width: 150px" onClick="loadFlightFull();" >Flight Plan</button></div>
                      <div><button class="btn btn-primary w-md waves-effect waves-light" style="margin-bottom: 10px;width: 150px" onClick="loadAccomplishments();" >Accomplishments</button></div>
                    
                    <% 
                      const costColor = typeof availableCostColor !== 'undefined' && availableCostColor !== null ? availableCostColor : '#000';
                      // sanitize percent values: strip commas, dollar signs, percent signs, and whitespace
                      function sanitizeNumber(val) {
                        if (typeof val === 'number') return val;
                        if (typeof val !== 'string') return NaN;
                        const cleaned = val.replace(/[^0-9.\-]/g, '');
                        const parsed = parseFloat(cleaned);
                        return isNaN(parsed) ? NaN : parsed;
                      }

                      function padFormatNumber(val) {
                        // val expected numeric or numeric-string
                        const numRaw = (typeof val === 'number') ? val : parseFloat(String(val).replace(/[^0-9.\-]/g, ''));
                        if (isNaN(numRaw)) return '00.00';
                        let num = numRaw;
                        // Special business rule: if magnitude is very large (>= 1000),
                        // treat as percentage scaled by 100 (divide by 100) and round to nearest integer
                        // so -15189.60 -> -152.00
                        if (Math.abs(numRaw) >= 1000) {
                          // divide by 100 then round to nearest integer
                          const scaled = Math.round(numRaw / 100);
                          num = scaled; // treat as integer percent value
                        }
                        const fixed = num.toFixed(2); // ensure two decimals
                        const parts = fixed.split('.');
                        let intPart = parts[0];
                        const decPart = parts[1] || '00';
                        const sign = intPart.startsWith('-') ? '-' : '';
                        if (sign) intPart = intPart.slice(1);
                        if (intPart.length < 2) intPart = intPart.padStart(2, '0');
                        return `${sign}${intPart}.${decPart}`;
                      }

                      const rawCost = (typeof availableCostPercent !== 'undefined' && availableCostPercent !== null) ? sanitizeNumber(availableCostPercent) : NaN;
                      const costPercent = !isNaN(rawCost) ? padFormatNumber(rawCost) : '00.00';
                      const effColor = typeof availablePHColor !== 'undefined' && availablePHColor !== null ? availablePHColor : '#000';
                      const rawEff = (typeof availableEffortPercent !== 'undefined' && availableEffortPercent !== null) ? sanitizeNumber(availableEffortPercent) : NaN;
                      const effPercent = !isNaN(rawEff) ? padFormatNumber(rawEff) : '00.00';
                    %>
                    <div class="row text-center" style="padding-top: 20px;padding-bottom: 20px;">
                        <div class="col-md-12">
                          
                          <% 
                            // Always show percent block, using same logic for all-time and filtered
                            let costPercentVal = (typeof usedCost !== 'undefined' && typeof totalCost !== 'undefined' && sanitizeNumber(totalCost) && !isNaN(sanitizeNumber(totalCost)))
                              ? ((sanitizeNumber(usedCost) / sanitizeNumber(totalCost)) * 100).toFixed(1) + '%'
                              : '0%';
                            let effortPercentVal = (typeof totalUsedPH !== 'undefined' && typeof totalPH !== 'undefined' && sanitizeNumber(totalPH) && !isNaN(sanitizeNumber(totalPH)))
                              ? ((sanitizeNumber(totalUsedPH) / sanitizeNumber(totalPH)) * 100).toFixed(1) + '%'
                              : '0%';
                          %>
                          <strong class="list-percent">COST</strong><br/>
                          <span id="cost-percentage" class="list-percent percent-cost" data-color="<%= costColor %>"><%= costPercentVal %></span><br/>
                          <strong class="list-percent">EFFORT</strong><br/>
                          <span id="effort-percentage" class="list-percent percent-effort" data-color="<%= effColor %>"><%= effortPercentVal %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
   <div id="addProject" class="modal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
