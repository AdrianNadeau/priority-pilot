<script>
  // Global navigation functions - must be available before onclick handlers
  function loadProject(projectId) {
    window.location.href = '/projects/cockpit/' + projectId;
  }
  
  function loadRadar() {
    window.location.href = '/projects/radar/view/';
  }
  
  function loadHealth() {
    window.location.href = '/projects/health/view/';
  }
  
  function loadFlightFull() {
    window.location.href = '/projects/flightview/view/';
  }
  
  function loadAccomplishments() {
    window.location.href = '/projects/accomplishments/view/';
  }
  
  function filterDashboard() {
    const fromDate = document.getElementById('from_date').value;
    const toDate = document.getElementById('to_date').value;
    
    // Send filter data to server to save in persons table
    fetch('/update-filter', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        from_date: fromDate,
        to_date: toDate
      })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        console.log('Filter preferences saved successfully');
        // Redirect to current page with filters
        window.location.href = window.location.pathname;
      } else {
        console.error('Error saving filter preferences:', data.message);
        // Still redirect to try to apply filters
        const params = new URLSearchParams();
        if (fromDate) params.append('from_date', fromDate);
        if (toDate) params.append('to_date', toDate);
        const queryString = params.toString();
        const url = queryString ? `${window.location.pathname}?${queryString}` : window.location.pathname;
        window.location.href = url;
      }
    })
    .catch(error => {
      console.error('Error:', error);
      // Fallback: redirect with query parameters
      const params = new URLSearchParams();
      if (fromDate) params.append('from_date', fromDate);
      if (toDate) params.append('to_date', toDate);
      const queryString = params.toString();
      const url = queryString ? `${window.location.pathname}?${queryString}` : window.location.pathname;
      window.location.href = url;
    });
  }

  function updateDayCount() {
    const fromDate = document.getElementById('from_date').value;
    const toDate = document.getElementById('to_date').value;
    const dayCountEl = document.getElementById('dayCount');
    
    if (fromDate && toDate) {
      const start = new Date(fromDate);
      const end = new Date(toDate);
      const diffTime = Math.abs(end - start);
      const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;
      
      if (dayCountEl) {
        dayCountEl.textContent = `(${diffDays} days)`;
      }
    } else {
      if (dayCountEl) {
        dayCountEl.textContent = '';
      }
    }
  }
</script>

