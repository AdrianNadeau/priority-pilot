<%- contentFor('BottomJs') %>
<script>
  document.addEventListener("DOMContentLoaded", function() {
    'use strict';
   // Fetch all the forms we want to apply custom Bootstrap validation styles to
   var forms = document.querySelectorAll(".needs-validation");

    // Loop over them and prevent submission
    Array.prototype.slice.call(forms).forEach(function (form) {
      form.addEventListener(
        "submit",
        function (event) {
          if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
          }

          form.classList.add("was-validated");
        },
        false,
      );
    });

    
    // Numeric input validation for specific fields
    const numericFields = ['project_cost', 'effort', 'benefit'];
    numericFields.forEach(function(fieldId) {
        document.getElementById(fieldId).addEventListener('keydown', function(event) {
            if (![46, 8, 9, 27, 13, 110, 190].includes(event.keyCode) &&
                !((event.keyCode >= 48 && event.keyCode <= 57) || (event.keyCode >= 96 && event.keyCode <= 105)) &&
                !(event.ctrlKey || event.metaKey)) {
                alert("Only numbers are allowed.")
                event.preventDefault();
            }
        });
    });

    // Table row click navigation to edit page
    document.querySelectorAll(".table tbody tr").forEach(function(row) {
        row.addEventListener('click', function() {
            var id = row.cells[0].textContent;
            window.location.replace('/projects/edit/' + id);
        });
    });

    // Input formatting with commas for project cost and benefit
    ['project_cost', 'benefit'].forEach(function(fieldId) {
        document.getElementById(fieldId).addEventListener('input', function () {
            let input = this.value.replace(/[^0-9.]/g, '');
            if (input.includes('.')) {
                const parts = input.split('.');
                parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ',');
                input = parts.join('.');
            } else {
                input = input.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
            }
            this.value = input;
        });
    });
    
    // Calculate initial day count on page load
    updateDayCount();
    
    // Initialize Flatpickr - check multiple times if needed
    function initializeFlatpickr() {
      console.log('Checking for Flatpickr...', typeof flatpickr);
      console.log('from_date element:', document.getElementById('from_date'));
      console.log('to_date element:', document.getElementById('to_date'));
      
      if (typeof flatpickr !== 'undefined') {
        console.log('Initializing Flatpickr...');
        
        var fromPicker = flatpickr("#from_date", {
          dateFormat: "Y-m-d",
          allowInput: true,
          allowInvalidPreload: true,
          onChange: function() {
            updateDayCount();
          }
        });
        
        var toPicker = flatpickr("#to_date", {
          dateFormat: "Y-m-d",
          allowInput: true,
          allowInvalidPreload: true,
          onChange: function() {
            updateDayCount();
          }
        });
        
        console.log('Flatpickr initialized successfully!', fromPicker, toPicker);
        return true;
      } else {
        console.error('Flatpickr library not loaded!');
        return false;
      }
    }
    
    // Try initializing immediately and with delays
    if (!initializeFlatpickr()) {
      setTimeout(function() {
        if (!initializeFlatpickr()) {
          setTimeout(initializeFlatpickr, 500);
        }
      }, 100);
    }

    // Apply colors to COST and EFFORT percentage values based on thresholds
    function applyPercentageColors() {
      const costEl = document.getElementById('cost-percentage');
      const effortEl = document.getElementById('effort-percentage');
      
      function setColor(element) {
        if (!element) return;
        
        const text = element.textContent || '';
        const match = text.match(/-?\d+\.?\d*/);
        const number = match ? parseFloat(match[0]) : 0;
        
        // Color thresholds: 0-95% green, 95-110% yellow, >110% red
        if (number >= 0 && number < 95) {
          element.style.color = '#28a745'; // Green
        } else if (number >= 95 && number <= 110) {
          element.style.color = '#ffc107'; // Yellow
        } else if (number > 110) {
          element.style.color = '#dc3545'; // Red
        } else {
          element.style.color = '#000'; // Black/default
        }
      }
      
      setColor(costEl);
      setColor(effortEl);
    }
    
    // Apply colors immediately and with delays to ensure DOM is fully rendered
    applyPercentageColors();
    setTimeout(applyPercentageColors, 100);
    setTimeout(applyPercentageColors, 500);

    // Show or hide date_section based on phase selection
    const phaseSelect = document.getElementById("phase_id_fk");
    const dateSection = document.getElementById("date_section");
    const startDateInput = document.getElementById('start_date');
    const endDateInput = document.getElementById('end_date');
    const nextMilestoneDateInput = document.getElementById('next_milestone_date');
    const dateRequired = document.getElementById('dates_required');

    function toggleDateSection() {
      if (phaseSelect.value == "1" || phaseSelect.value == "6") {
        // Phase is pitch, hide dates and clear validation messages
        dateSection.style.display = 'none';
        startDateInput.required = false;
        endDateInput.required = false;
        dateRequired.style.display = 'none';
        startDateInput.value = "";
        endDateInput.value = "";
        nextMilestoneDateInput.value = "";
      } else {
        // Phase is not pitch, show dates and set required
        dateSection.style.display = 'block';
        startDateInput.required = true;
        endDateInput.required = true;
        if (!startDateInput.value) {
          // Set the placeholder
          startDateInput.placeholder = "Start Date";
        }
        if (!endDateInput.value) {
          endDateInput.placeholder = "End Date";
        }
        if (!nextMilestoneDateInput.value) {
          nextMilestoneDateInput.placeholder = "Milestone Date";
        }
      }
    }

    // Initial check
    toggleDateSection();

    // Add event listener to phase selection change
    phaseSelect.addEventListener("change", toggleDateSection);
  });

  function submitForm() {
    document.getElementById('editProjectForm').submit();
  }

  function cancelForm(){
    window.location.replace("/projects");
  }
  
  function loadFunnel() {
    window.location.replace('/projects/funnel/view/');
  }
  
  function loadFreezer() {
    window.location.replace('/projects/freezer/view/');
  }
  
  function loadFlightPlan() {
    window.location.replace('/projects/flight/view/');
  }
 
  function getProjects() {
    window.location.replace('/projects/');
  }
</script>