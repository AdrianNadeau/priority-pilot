<%- contentFor('HeaderCss') %>
<!-- Flatpickr CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<style>
  /* Add small internal gap to all mini-stat white boxes */
  .mini-stat.bg-white.clearfix { padding: 5px !important; }
  .phase-buttons { padding-left: 5px; margin-left: 0; padding-top: 6px; }
  
  /* Add 15px spacing between phase columns */
  .phase-column {
    padding-left: 7.5px !important;
    padding-right: 7.5px !important;
  }
  
  /* First column - only right padding */
  .phase-column:first-child {
    padding-left: 0 !important;
    padding-right: 7.5px !important;
  }
  
  /* Last column - only left padding */
  .phase-column:last-child {
    padding-left: 7.5px !important;
    padding-right: 0 !important;
  }
</style>

<%- contentFor('breadcrumb') %>

<%- contentFor('body') %>

<div class="page-content-wrapper">
    <div class="container-fluid">
        

        

        
        <!-- Filter Row with Date Range Display -->
        <div class="row">
            <div class="col-md-12" style="min-height: 50px; padding-bottom: 15px;">
                <div class="mini-stat clearfix" style="background-color: #e3f2fd; border: 1px solid #2196f3; border-radius: 4px; padding: 10px;">
                    <div class="mini-stat-info d-flex align-items-center">
                        <div class="d-flex align-items-center">
                            <span class="counter" style="color: black; margin-right: 20px;"><strong>Date Range:</strong></span>
                            
                            <div class="d-flex align-items-center" style="margin-right: 15px;">
                                <strong style="margin-right: 10px;">Start:</strong>
                                <input type="text" class="form-control datepicker" id="from_date" name="from_date" placeholder="From" style="width: 150px;" value="<%= currentFromDate %>">
                            </div>
                            
                            <div class="d-flex align-items-center" style="margin-right: 15px;">
                                <strong style="margin-right: 10px;">End:</strong>
                                <input type="text" class="form-control datepicker" id="to_date" name="to_date" placeholder="To" style="width: 150px;" value="<%= currentToDate %>">
                            </div>
                            
                            <div class="d-flex">
                                <button type="button" class="btn btn-primary btn-sm" style="margin-right: 5px;" onclick="filterDashboard()">Update</button>
                            </div>
                            
                            <!-- Display number of days in date range -->
                            <% if (currentFromDate && currentToDate && filteredDays) { %>
                                <div class="d-flex align-items-center" style="margin-left: 20px;">
                                    <span class="counter" style="color: #2196f3; font-size: 14px;">
                                        <strong>(<%= filteredDays %> days)</strong>
                                    </span>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <% // Calculate total filtered cost/effort and used cost/effort for all projects %>
                <% let totalFilteredCost = 0, totalFilteredEffort = 0, usedFilteredCost = 0, usedFilteredEffort = 0;
                   projects.forEach(function(project) {
                     var filteredCost = (typeof getFilteredValue === 'function') ? getFilteredValue(project, currentFromDate, currentToDate, 'project_cost') : 0;
                     var filteredEffort = (typeof getFilteredValue === 'function') ? getFilteredValue(project, currentFromDate, currentToDate, 'effort') : 0;
                     totalFilteredCost += filteredCost;
                     totalFilteredEffort += filteredEffort;
                     if (filteredCost > 0) usedFilteredCost += filteredCost;
                     if (filteredEffort > 0) usedFilteredEffort += filteredEffort;
                   });
                %>
               
            </div>
        </div>
        
        <div class="row">
            <!-- Main content -->
            <div class="col-md-10">
                <div class="row">
 
                    
           <div class="col-md-6 phase-column" style="min-height: 50px;padding-bottom:15px;">
            <div class="mini-stat bg-white clearfix" >
              <div class="mini-stat-info" style="background-color:#ffea99">
                <% function formatNumberWithCommas(x) { if (x == null) return '0'; var parts = x.toString().split('.'); parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ","); return parts.join('.'); } %>
                <a href="/projects/funnel/view/"><span class="counter" style="color:black;background-color: #FFEA99;"><strong>Funnel</strong> (<%= pitch.count %> / $0 / <%= formatNumberWithCommas(pitch.ph) %> PH)</span></a>
              </div>
            </div>
            </div>
                      <div class="col-md-6 phase-column">
                        <div class="mini-stat bg-white clearfix" style="min-height: 50px;">
                            <div class="mini-stat-info" style="background-color: #FFEA99;" data-phase="Archive">
                                <a href="/projects/freezer/view/"><span class="counter" style="color:black;background-color: #FFEA99;"><strong>Archive</strong> (<%= archived.count %> / $<%= formatNumberWithCommas(archived.cost) %> / <%= formatNumberWithCommas(archived.ph) %> PH)</span></a>
                            </div>
                        </div>
                      </div>
                    <div class="col-md-6 phase-column">
                        <div class="mini-stat bg-white clearfix" style="min-height: 150px;">
                            <div class="mini-stat-info">
                                <span class="counter"><strong>Planning</strong> (<%= planning.count %> / $<%= formatNumberWithCommas(planning.cost) %> / <%= formatNumberWithCommas(planning.ph) %> PH)</span>
                            </div>
                            <div class="phase-buttons" style="padding-left: 10px;">

                            <% 
                            function getFilteredValue(project, fromDate, toDate, field) {
                              if (!project.start_date || !project.end_date) return 0;
                              var projectStart = new Date(project.start_date);
                              var projectEnd = new Date(project.end_date);
                              var filterStart = fromDate ? new Date(fromDate) : projectStart;
                              var filterEnd = toDate ? new Date(toDate) : projectEnd;
                              var overlapStart = projectStart > filterStart ? projectStart : filterStart;
                              var overlapEnd = projectEnd < filterEnd ? projectEnd : filterEnd;
                              var msInDay = 1000 * 60 * 60 * 24;
                              var overlapDays = Math.max(0, Math.ceil((overlapEnd - overlapStart) / msInDay) + 1);
                              var totalDays = Math.max(1, Math.ceil((projectEnd - projectStart) / msInDay) + 1);
                              var percent = overlapDays / totalDays;
                              var value = Number(project[field]) || 0;
                              return Math.round(value * percent);
                            }
                            projects.forEach(function(project) { 
                                if (project.phase_name && project.phase_name.trim().toLowerCase() === 'planning') { 
                                  let health = project.latest_status_health ? project.latest_status_health.trim().toLowerCase() : '';
                                  let borderColor = '';
                                  if (health === 'green') borderColor = 'green';
                                  else if (health === 'yellow') borderColor = 'yellow';
                                  else if (health === 'red') borderColor = 'red';
                                  else borderColor = 'black'; // default
                              %>
                                <% const btnStyle = 'margin-bottom:10px; border-color:' + borderColor + '; border-width:2px; border-radius:10px;'; %>
                                <button type="button" onclick="loadProject('<%= project.id %>')" class="btn btn-light project-btn" data-style="<%= btnStyle %>">
                                  <%= project.project_name %>
                                </button>&nbsp;&nbsp;&nbsp;
                                <% 
                                  let projBudget = Number(project.project_cost) || 0;
                                  let projEffort = Number(project.effort) || 0;
                                  let projUsedCost = 0, projUsedEffort = 0, projTotalCost = 0, projTotalEffort = 0, projAvailCost = 0, projAvailEffort = 0;
                                  if (currentFromDate && currentToDate && filteredDays) {
                                    projUsedCost = (typeof getFilteredValue === 'function') ? getFilteredValue(project, currentFromDate, currentToDate, 'project_cost') : 0;
                                    projUsedEffort = (typeof getFilteredValue === 'function') ? getFilteredValue(project, currentFromDate, currentToDate, 'effort') : 0;
                                    projTotalCost = Math.round((projBudget / 365) * filteredDays);
                                    projTotalEffort = Math.round((projEffort / 365) * filteredDays);
                                    projAvailCost = projTotalCost - projUsedCost;
                                    projAvailEffort = projTotalEffort - projUsedEffort;
                                  } else {
                                    projUsedCost = Number(project.used_cost) || 0;
                                    projUsedEffort = Number(project.used_effort) || 0;
                                    projTotalCost = projBudget;
                                    projTotalEffort = projEffort;
                                    projAvailCost = projTotalCost - projUsedCost;
                                    projAvailEffort = projTotalEffort - projUsedEffort;
                                  }
                                %>
                                <div class="alert alert-success" style="margin: 10px 0 10px 0; padding: 10px; background-color: #eafbe7; border: 1px solid #28a745; border-radius: 4px;">
                                  <div style="display: flex; align-items: center;">
                                    <div style="width: 50%; display: flex; align-items: flex-start; flex-direction: column;">
                                      <div style="display: flex; align-items: center;">
                                        <i class="mdi mdi-currency-usd" style="margin-right: 8px; font-size: 16px; color: #155724;"></i>
                                        <strong style="color: #155724; font-size: 14px;padding-right:5px;">Budget:<% if (currentFromDate && currentToDate && filteredDays) { %> (Filtered)<% } %>:</strong>
                                        <span style="color: #155724; font-weight: bold;padding-right:5px;">Total: $<%= formatNumberWithCommas(projTotalCost) %></span>
                                        <span style="color: #155724; font-weight: bold; margin-left:5px;">Used: $<%= formatNumberWithCommas(projUsedCost) %></span>
                                        <span style="color: #155724; font-weight: bold; margin-left:5px;">Avail: $<%= formatNumberWithCommas(projAvailCost) %></span>
                                      </div>
                                    </div>
                                    <div style="width: 50%; display: flex; align-items: flex-start; flex-direction: column;">
                                      <div style="display: flex; align-items: center;">
                                        <i class="mdi mdi-firework" style="margin-right: 8px; font-size: 16px; color: #155724;"></i>
                                        <strong style="color: #155724; font-size: 14px;padding-right:5px;">Effort<% if (currentFromDate && currentToDate && filteredDays) { %> (Filtered)<% } %>:</strong>
                                        <span style="color: #155724; font-weight: bold;padding-right:5px;">Total: <%= formatNumberWithCommas(projTotalEffort) %> PH</span>
                                        <span style="color: #155724; font-weight: bold; margin-left:5px;">Used: <%= formatNumberWithCommas(projUsedEffort) %> PH</span>
                                        <span style="color: #155724; font-weight: bold; margin-left:5px;">Avail: <%= formatNumberWithCommas(projAvailEffort) %> PH</span>
                                      </div>
                                    </div>
                                  </div>
                                </div>
                              <%  } 
                            }); %>
                            </div>
                          </div>
                      </div>
                      
                        <script>
                          // Apply inline styles stored in data-style to elements to avoid embedding EJS in CSS attributes
                          document.addEventListener('DOMContentLoaded', function () {
                            document.querySelectorAll('.project-btn').forEach(function (el) {
                            var s = el.getAttribute('data-style');
                            if (s) el.style.cssText = s;
                          });
                        });
                      </script>
           <div class="col-md-6 phase-column" style="padding-bottom: 15px;">
            <div class="mini-stat bg-white clearfix" style="min-height: 150px;">
              <div class="mini-stat-info">
                                <span class="counter"><strong>Discovery</strong> (<%= discovery.count %> / $<%= formatNumberWithCommas(discovery.cost) %> / <%= formatNumberWithCommas(discovery.ph) %> PH)</span>
                            </div>
                            <div class="phase-buttons" style="padding-left: 10px;">
                            <% projects.forEach(function(project) { 
