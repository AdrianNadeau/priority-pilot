  // Centralized date filtering functions
  function filterDashboard() {
    const fromDate = document.getElementById('from_date').value;
    const toDate = document.getElementById('to_date').value;
    
    // Send filter data to server to save in persons table
    fetch('/update-filter', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        from_date: fromDate,
        to_date: toDate
      })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        console.log('Filter preferences saved successfully to persons table');
        // Redirect to refresh the page with updated filter values from database
        window.location.href = '/';
      } else {
        console.error('Error saving filter preferences:', data.message);
        // Still redirect to try to apply filters
        const params = new URLSearchParams();
        if (fromDate) params.append('from_date', fromDate);
        if (toDate) params.append('to_date', toDate);
        const queryString = params.toString();
        const url = queryString ? `/?${queryString}` : '/';
        window.location.href = url;
      }
    })
    .catch(error => {
      console.error('Error:', error);
      // Fallback: redirect with query parameters
      const params = new URLSearchParams();
      if (fromDate) params.append('from_date', fromDate);
      if (toDate) params.append('to_date', toDate);
      const queryString = params.toString();
      const url = queryString ? `/?${queryString}` : '/';
      window.location.href = url;
    });
  }
  
  function clearFilters() {
    // Clear the input fields first
    document.getElementById('from_date').value = '';
    document.getElementById('to_date').value = '';

    // Send clear filter data to server to update persons table and session, and show all projects
    fetch('/update-filter', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        from_date: null,
        to_date: null,
        clear_all: true // instruct backend to clear all filter/session/db values
      })
    })
    .then(response => response.json())
    .then(data => {
      // Always reload to show all projects regardless of backend response
      window.location.href = '/';
    })
    .catch(error => {
      // Fallback: reload to show all projects
      window.location.href = '/';
    });
  }  // Global function to get current filter values for other pages
  function getGlobalFilterValues() {
    return {
      fromDate: '<%= currentFromDate %>',
      toDate: '<%= currentToDate %>'
    };
  }

  // Make the function globally available
  window.getGlobalFilterValues = getGlobalFilterValues;

</script>

