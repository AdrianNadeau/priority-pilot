  // Calculate deliveryTotalCost as (portfolio_budget / 365) * filteredDays
  let deliveryTotalCost = 0, deliveryUsedCost = 0, deliveryAvailCost = 0;
  let deliveryTotalEffort = 0, deliveryUsedEffort = 0, deliveryAvailEffort = 0;
    let portfolioBudget = 500000;
    let portfolioEffort = 20000;
    if (typeof companies !== 'undefined' && companies && companies.length > 0) {
      if (typeof companies[0].portfolio_budget !== 'undefined') {
        portfolioBudget = Number(companies[0].portfolio_budget) || 500000;
      }
      if (typeof companies[0].effort !== 'undefined') {
        portfolioEffort = Number(companies[0].effort) || 20000;
      }
    }
    if (typeof filteredDays !== 'undefined' && filteredDays) {
      deliveryTotalCost = Math.round((portfolioBudget / 365) * filteredDays);
      deliveryTotalEffort = Math.round((portfolioEffort / 365) * filteredDays);
    } else {
      deliveryTotalCost = Math.round(portfolioBudget);
      deliveryTotalEffort = Math.round(portfolioEffort);
    }
  // Optionally, you can still sum up used/available as before if needed
  projects.forEach(function(project) {
    if (project.phase_name) {
        const phase = project.phase_name.trim().toLowerCase();
        if (phase === 'delivery') {
            let usedCost = (typeof getFilteredValue === 'function') ? getFilteredValue(project, currentFromDate, currentToDate, 'project_cost') : 0;
            let usedEffort = (typeof getFilteredValue === 'function') ? getFilteredValue(project, currentFromDate, currentToDate, 'effort') : 0;
            deliveryUsedCost += usedCost;
            deliveryUsedEffort += usedEffort;
        }
      }
  });
  deliveryAvailCost = deliveryTotalCost - deliveryUsedCost;
  deliveryAvailEffort = deliveryTotalEffort - deliveryUsedEffort;

  // Debug: Output totals to server console
  console.log('Dashboard totals:', {
    deliveryTotalCost,
    deliveryTotalEffort,
    filteredDays,
    portfolioBudget: (companies && companies[0] && companies[0].company_budget) ? companies[0].company_budget : 500000,
    portfolioEffort: (companies && companies[0] && companies[0].effort) ? companies[0].effort : 20000
  });
