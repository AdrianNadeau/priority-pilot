<script>
  // Global navigation functions - must be available before onclick handlers
  function loadProject(projectId) {
    window.location.href = '/projects/cockpit/' + projectId;
  }
  
  function loadRadar() {
    window.location.href = '/projects/radar/view/';
  }
  
  function loadHealth() {
    window.location.href = '/projects/health/view/';
  }
  
  function loadFlightFull() {
    window.location.href = '/projects/flightview/view/';
  }
  
  function loadAccomplishments() {
    window.location.href = '/projects/accomplishments/view/';
  }
  
  // Calculate and display day count - make it globally available
  window.updateDayCount = function() {
    const from = document.getElementById('from_date') ? document.getElementById('from_date').value : '';
    const to = document.getElementById('to_date') ? document.getElementById('to_date').value : '';
    const dayCountSpan = document.getElementById('dayCount');
  
    
    if (!dayCountSpan) {
      console.error('dayCount span not found!');
      return;
    }
    
    if (from && to) {
      const fromDate = new Date(from);
      const toDate = new Date(to);
      
      if (!isNaN(fromDate.getTime()) && !isNaN(toDate.getTime())) {
        const diffTime = Math.abs(toDate - fromDate);
        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1; // +1 to include both start and end dates
        const dayText = `(${diffDays} day${diffDays !== 1 ? 's' : ''})`;
        dayCountSpan.textContent = dayText;
        
      } else {
        dayCountSpan.textContent = '';
        console.log('Invalid date format');
      }
    } else {
      dayCountSpan.textContent = '';
    }
  };

  // Wait for DOM to be fully loaded
  document.addEventListener('DOMContentLoaded', function() {
    // Initialize Flatpickr for date inputs
    flatpickr('#from_date', { dateFormat: 'Y-m-d', onChange: updateDayCount });
    flatpickr('#to_date', { dateFormat: 'Y-m-d', onChange: updateDayCount });

    // Update day count immediately
    updateDayCount();
  });
</script>

<script>
  // Filter function - needs to be available for onclick handler
  function filterDashboard() {
    const fromDate = document.getElementById('from_date').value;
    const toDate = document.getElementById('to_date').value;
    
    console.log('Filter clicked with dates:', fromDate, toDate);
    
    // Send filter data to server to save in persons table
    fetch('/update-filter', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        from_date: fromDate,
        to_date: toDate
      })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        console.log('Filter preferences saved successfully');
        // Reload the page to apply session-based filtering
        window.location.reload();
      } else {
        console.error('Error saving filter preferences:', data.message);
        // Still reload to try to apply filters
        window.location.reload();
      }
    })
    .catch(error => {
      console.error('Error:', error);
      // Fallback: reload page
      window.location.reload();
    });
  }
</script>

