<script>
  document.addEventListener("DOMContentLoaded", function() {
    'use strict';
    
   // Fetch all the forms we want to apply custom Bootstrap validation styles to
   var forms = document.querySelectorAll(".needs-validation");

    // Loop over them and prevent submission
    Array.prototype.slice.call(forms).forEach(function (form) {
      form.addEventListener(
        "submit",
        function (event) {
          if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
          }

          form.classList.add("was-validated");
        },
        false,
      );
    });

    
    // Numeric input validation for specific fields
    const numericFields = ['project_cost', 'effort', 'benefit'];
    numericFields.forEach(function(fieldId) {
        document.getElementById(fieldId).addEventListener('keydown', function(event) {
            if (![46, 8, 9, 27, 13, 110, 190].includes(event.keyCode) &&
                !((event.keyCode >= 48 && event.keyCode <= 57) || (event.keyCode >= 96 && event.keyCode <= 105)) &&
                !(event.ctrlKey || event.metaKey)) {
                alert("Only numbers are allowed.")
                event.preventDefault();
            }
        });
    });

   

    // Input formatting with commas for project cost and benefit
    ['project_cost', 'benefit'].forEach(function(fieldId) {
        document.getElementById(fieldId).addEventListener('input', function () {
            let input = this.value.replace(/[^0-9.]/g, '');
            if (input.includes('.')) {
                const parts = input.split('.');
                parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ',');
                input = parts.join('.');
            } else {
                input = input.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
            }
            this.value = input;
        });
    });
    
    // Basic form validation without complex date picker manipulation
    console.log("Basic form setup complete");

    // Show or hide date_section based on phase selection
    const phaseSelect = document.getElementById("phase_id_fk");
    const dateSection = document.getElementById("date_section");
    const startDateInput = document.getElementById('start_date');
    const endDateInput = document.getElementById('end_date');
    const nextMilestoneDateInput = document.getElementById('next_milestone_date');
    const dateRequired = document.getElementById('dates_required');

    function toggleDateSection() {
      if (phaseSelect.value == "1" || phaseSelect.value == "6") {
        // Phase is pitch, hide dates and clear validation messages
        dateSection.style.display = 'none';
        startDateInput.required = false;
        endDateInput.required = false;
        dateRequired.style.display = 'none';
        startDateInput.value = "";
        endDateInput.value = "";
        nextMilestoneDateInput.value = "";
      } else {
        // Phase is not pitch, show dates and set required
        dateSection.style.display = 'block';
        startDateInput.required = true;
        endDateInput.required = true;
        if (!startDateInput.value) {
          // Set the placeholder
          startDateInput.placeholder = "Start Date";
        }
        if (!endDateInput.value) {
          endDateInput.placeholder = "End Date";
        }
        if (!nextMilestoneDateInput.value) {
          nextMilestoneDateInput.placeholder = "Milestone Date";
        }
      }
    }

    // Initial check
    toggleDateSection();

    // Add event listener to phase selection change
    phaseSelect.addEventListener("change", toggleDateSection);
    

 
    // avail-effort elements
    document.querySelectorAll('.avail-effort').forEach(function(el) {
      var color = el.getAttribute('data-color');
      if (color) el.style.color = color;
    });

    // percent-cost and percent-effort elements: apply Bootstrap color classes
    function applyPercentColors(selector) {
      const elements = document.querySelectorAll(selector);
      console.log('Found elements for selector "' + selector + '":', elements.length);
      
      elements.forEach(function(el, index) {
        var txt = el.textContent || el.innerText || '';
        // Remove commas, K/M/B suffixes and percent signs before parsing
        var cleaned = String(txt).replace(/[,\s]/g, '').replace(/K|M|B|%/gi, '');
        var num = parseFloat(cleaned) || 0;
        
        console.log('Element', index, ':', el, 'Text:', txt, 'Cleaned:', cleaned, 'Number:', num);
        
        // Remove any previous text color classes and inline styles
        el.classList.remove('text-danger', 'text-success');
        el.style.color = ''; // Clear any inline color styles
        el.removeAttribute('data-color'); // Remove data-color attribute
        
        // Apply color based on percentage value with !important to override any CSS
        if (num < 0) {
          // Negative values = red
          el.style.cssText = 'color: #dc3545 !important;';
          console.log('Applied red color for negative value:', num);
        } else if (num > 0) {
          // Positive values = green
          el.style.cssText = 'color: #28a745 !important;';
          console.log('Applied green color for positive value:', num);
        } else {
          // Zero values = default black
          el.style.cssText = 'color: #000 !important;';
          console.log('Applied default color for zero value:', num);
        }
      });
    }
    
    // Wait for DOM to be fully loaded and try multiple times
    function applyColorsWithRetry() {
      console.log('Attempting to apply percent colors...');
      applyPercentColors('.percent-cost');
      applyPercentColors('.percent-effort');
      
      // Direct approach using IDs as backup
      const costEl = document.getElementById('cost-percentage');
      const effortEl = document.getElementById('effort-percentage');
      
      if (costEl) {
        const costText = costEl.textContent || '';
        const costNum = parseFloat(costText.replace(/[^-0-9.]/g, '')) || 0;
        console.log('Direct cost element found:', costText, 'Number:', costNum);
        if (costNum < 0) {
          costEl.style.cssText = 'color: #dc3545 !important;';
        } else if (costNum > 0) {
          costEl.style.cssText = 'color: #28a745 !important;';
        } else {
          costEl.style.cssText = 'color: #000 !important;';
        }
      }
      
      if (effortEl) {
        const effortText = effortEl.textContent || '';
        const effortNum = parseFloat(effortText.replace(/[^-0-9.]/g, '')) || 0;
        console.log('Direct effort element found:', effortText, 'Number:', effortNum);
        if (effortNum < 0) {
          effortEl.style.cssText = 'color: #dc3545 !important;';
        } else if (effortNum > 0) {
          effortEl.style.cssText = 'color: #28a745 !important;';
        } else {
          effortEl.style.cssText = 'color: #000 !important;';
        }
      }
      
      // If no elements found, try again after a delay
      if (document.querySelectorAll('.percent-cost, .percent-effort').length === 0) {
        console.log('No percentage elements found, retrying in 500ms...');
        setTimeout(applyColorsWithRetry, 500);
      }
    }
    
    applyColorsWithRetry();
  });

  // Additional function to ensure colors are applied after page is fully loaded
  window.addEventListener('load', function() {
    setTimeout(function() {
      console.log('Window loaded - applying colors...');
      
      // Direct approach with specific targeting
      const costElement = document.querySelector('#cost-percentage');
      const effortElement = document.querySelector('#effort-percentage');
      
      function setColor(element, elementName) {
        if (!element) {
          console.log(elementName + ' element not found');
          return;
        }
        
        const text = element.textContent || element.innerText || '';
        console.log(elementName + ' text content:', text);
        
        // Extract number from text (handle negative signs)
        const match = text.match(/-?\d+\.?\d*/);
        const number = match ? parseFloat(match[0]) : 0;
        
        console.log(elementName + ' extracted number:', number);
        
        // Apply color based on value
        if (number > 0) {
          element.style.setProperty('color', '#28a745', 'important'); // Green
          console.log(elementName + ' set to GREEN for positive value');
        } else if (number < 0) {
          element.style.setProperty('color', '#dc3545', 'important'); // Red
          console.log(elementName + ' set to RED for negative value');
        } else {
          element.style.setProperty('color', '#000000', 'important'); // Black
          console.log(elementName + ' set to BLACK for zero value');
        }
      }
      
      setColor(costElement, 'Cost percentage');
      setColor(effortElement, 'Effort percentage');
      
    }, 1000); // Wait 1 second to ensure everything is rendered
  });

  function submitForm() {
    document.getElementById('editProjectForm').submit();
  }

  function cancelForm(){
    window.location.replace("/projects");
  }
</script>
