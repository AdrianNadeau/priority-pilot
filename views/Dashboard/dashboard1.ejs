    <div class="container-fluid">
        

        





        
        <% 
  // Calculate deliveryTotalCost as (portfolio_budget / 365) * filteredDays
  let deliveryTotalCost = 0, deliveryUsedCost = 0, deliveryAvailCost = 0;
  let deliveryTotalEffort = 0, deliveryUsedEffort = 0, deliveryAvailEffort = 0;
  let discoveryTotalCost = 0, discoveryTotalEffort = 0;
    let portfolioBudget = 0, portfolioEffort  = 0;
    if (typeof companies !== 'undefined' && companies && companies.length > 0) {
      if (typeof companies[0].portfolio_budget !== 'undefined') {
        // Remove commas before converting to number
        portfolioBudget = Number(String(companies[0].portfolio_budget).replace(/,/g, ''));
      }
      if (companies[0].effort != null && companies[0].effort !== '') {
        portfolioEffort = Number(String(companies[0].effort).replace(/,/g, ''));
      }
    }
    if (typeof filteredDays !== 'undefined' && filteredDays) {
      deliveryTotalCost = Math.round((portfolioBudget / 365) * filteredDays);
      deliveryTotalEffort = Math.round((portfolioEffort / 365) * filteredDays);
      discoveryTotalCost = Math.round((portfolioBudget / 365) * filteredDays);
      discoveryTotalEffort = Math.round((portfolioEffort / 365) * filteredDays);
    } else {
      deliveryTotalCost = Math.round(portfolioBudget);
      deliveryTotalEffort = Math.round(portfolioEffort);
      discoveryTotalCost = Math.round(portfolioBudget);
      discoveryTotalEffort = Math.round(portfolioEffort);
    }
  // Calculate used values across all relevant phases (planning, discovery, delivery, done)
  const relevantPhases = ['planning', 'discovery', 'delivery', 'done'];
  projects.forEach(function(project) {
    if (project.phase_name) {
        const phase = project.phase_name.trim().toLowerCase();
        if (relevantPhases.indexOf(phase) !== -1) {
            let usedCost = (typeof getFilteredValue === 'function') ? Math.round(getFilteredValue(project, currentFromDate, currentToDate, 'project_cost')) : 0;
            let usedEffort = (typeof getFilteredValue === 'function') ? Math.round(getFilteredValue(project, currentFromDate, currentToDate, 'effort')) : 0;
            deliveryUsedCost += usedCost;
            deliveryUsedEffort += usedEffort;
        }
      }
  });
  deliveryAvailCost = deliveryTotalCost - deliveryUsedCost;
  // Effort left = default effort - calculated effort (NOT calculated - used)
  const effortLeft = Math.round(portfolioEffort - deliveryTotalEffort);
 
