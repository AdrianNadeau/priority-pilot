                    <% 
                      const costColor = typeof availableCostColor !== 'undefined' && availableCostColor !== null ? availableCostColor : '#000';
                      // sanitize percent values: strip commas, dollar signs, percent signs, and whitespace
                      function sanitizeNumber(val) {
                        if (typeof val === 'number') return val;
                        if (typeof val !== 'string') return NaN;
                        const cleaned = val.replace(/[^0-9.\-]/g, '');
                        const parsed = parseFloat(cleaned);
                        return isNaN(parsed) ? NaN : parsed;
                      }

                      function padFormatNumber(val) {
                        // val expected numeric or numeric-string
                        const numRaw = (typeof val === 'number') ? val : parseFloat(String(val).replace(/[^0-9.\-]/g, ''));
                        if (isNaN(numRaw)) return '00.00';
                        let num = numRaw;
                        // Special business rule: if magnitude is very large (>= 1000),
                        // treat as percentage scaled by 100 (divide by 100) and round to nearest integer
                        // so -15189.60 -> -152.00
                        if (Math.abs(numRaw) >= 1000) {
                          // divide by 100 then round to nearest integer
                          const scaled = Math.round(numRaw / 100);
                          num = scaled; // treat as integer percent value
                        }
                        const fixed = num.toFixed(2); // ensure two decimals
                        const parts = fixed.split('.');
                        let intPart = parts[0];
                        const decPart = parts[1] || '00';
                        const sign = intPart.startsWith('-') ? '-' : '';
                        if (sign) intPart = intPart.slice(1);
                        if (intPart.length < 2) intPart = intPart.padStart(2, '0');
                        return `${sign}${intPart}.${decPart}`;
                      }

                      const rawCost = (typeof availableCostPercent !== 'undefined' && availableCostPercent !== null) ? sanitizeNumber(availableCostPercent) : NaN;
                      const costPercent = !isNaN(rawCost) ? padFormatNumber(rawCost) : '00.00';
                      const effColor = typeof availablePHColor !== 'undefined' && availablePHColor !== null ? availablePHColor : '#000';
                      const rawEff = (typeof availableEffortPercent !== 'undefined' && availableEffortPercent !== null) ? sanitizeNumber(availableEffortPercent) : NaN;
                      const effPercent = !isNaN(rawEff) ? padFormatNumber(rawEff) : '00.00';
                    %>
                    <div class="row text-center" style="padding-top: 20px;padding-bottom: 20px;">
                        <div class="col-md-12">
                          
                          <% 
                            // Always show percent block, using same logic for all-time and filtered
                            let costPercentVal = (typeof usedCost !== 'undefined' && typeof totalCost !== 'undefined' && sanitizeNumber(totalCost) && !isNaN(sanitizeNumber(totalCost)))
                              ? ((sanitizeNumber(usedCost) / sanitizeNumber(totalCost)) * 100).toFixed(1) + '%'
                              : '0%';
                            let effortPercentVal = (typeof totalUsedPH !== 'undefined' && typeof totalPH !== 'undefined' && sanitizeNumber(totalPH) && !isNaN(sanitizeNumber(totalPH)))
                              ? ((sanitizeNumber(totalUsedPH) / sanitizeNumber(totalPH)) * 100).toFixed(1) + '%'
                              : '0%';
                          %>
                          <strong class="list-percent">COST</strong><br/>
                          <span id="cost-percentage" class="list-percent percent-cost" data-color="<%= costColor %>"><%= costPercentVal %></span><br/>
                          <strong class="list-percent">EFFORT</strong><br/>
                          <span id="effort-percentage" class="list-percent percent-effort" data-color="<%= effColor %>"><%= effortPercentVal %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
