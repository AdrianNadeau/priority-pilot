                                <button type="button" onclick="loadProject('<%= project.id %>')" class="btn btn-light project-btn" data-style="<%= btnStyle %>" title="Filtered Cost: $<%= filteredCost %> | Filtered Effort: <%= filteredEffort %> PH">
                                  <%= project.project_name %>
                                </button>&nbsp;&nbsp;&nbsp;
                              <%  } 
                            }); %>
                            </div>
                        </div>
                    </div>
                </div>
                
        <div class="row">
          <!-- Delivery (left), Done (center), Dates (right) -->
      <div class="col-md-6 phase-column">
            <div class="mini-stat bg-white clearfix" style="min-height: 150px;">
                            <div class="mini-stat-info">
                                <span class="counter"><strong>Delivery</strong> (<%= delivery.count %> / $<%= formatNumberWithCommas(delivery.cost) %> / <%= formatNumberWithCommas(delivery.ph) %> PH)</span>
                            </div>
                            <div class="phase-buttons" style="padding-left: 10px;">
                            <% projects.forEach(function(project) { 
                                if (project.phase_name && project.phase_name.trim().toLowerCase() === 'delivery') { 
                                  let health = project.latest_status_health ? project.latest_status_health.trim().toLowerCase() : '';
                                  let borderColor = '';
                                  if (health === 'green') borderColor = 'green';
